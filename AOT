-- Repair BannerPity after NaN bug (Anime Paradox)
-- БАГ: RequestBannerSummon("Jujutsu", 0/0) отправляет NaN → сервер портит BannerPity → Replica шлёт nan клиенту
-- Что ещё ломается NaN: RequestPod, ClaimIndexReward, ClaimReward, ClaimMilestone, ClaimAFKMilestone, UseItem, SellItem
-- Методы: 1) Хук Replica* remotes, 2) Хук RequestBannerSummon (санитизация), 3) ReplicaClient cache

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

if not game:IsLoaded() then game.Loaded:Wait() end

local LOG = true       -- логи на все хуки
local LOG_REPLICA = true -- логировать каждый Replica fire (поставь false если спам)
local function log(...) if LOG then print("[BannerPity Repair]", ...) end end

local function isNaN(x)
    return type(x) == "number" and x ~= x
end

local function patchTable(t)
    if type(t) ~= "table" then return 0 end
    local n = 0
    for k, v in pairs(t) do
        if isNaN(v) then
            local ok = pcall(rawset, t, k, 0)
            if ok then n = n + 1 end
        elseif type(v) == "table" then
            n = n + patchTable(v)
        end
    end
    return n
end

-- Общий обработчик для Replica remotes: патчит таблицы в args, логирует
local function hookReplicaRemote(name, remote)
    if not remote then return end
    remote.OnClientEvent:Connect(function(...)
        local args = {...}
        local total = 0
        for i, v in ipairs(args) do
            if type(v) == "table" then
                total = total + patchTable(v)
            elseif isNaN(v) then
                log(name, "arg", i, "= NaN (singleton, can't patch)")
            end
        end
        if LOG_REPLICA or total > 0 then
            log(name, "fired | args:", #args, "| patched NaN:", total)
        end
        if total > 0 then
            warn("[BannerPity Repair] Patched", total, "NaN in", name)
        end
    end)
    log("Hooked", name)
end

-- Хук всех Replica remotes (данные могут идти через любой)
local RemoteEvents = ReplicatedStorage:WaitForChild("RemoteEvents", 3)
if not RemoteEvents then log("RemoteEvents not found — Replica hooks skipped") end
local replicaRemotes = {
    "ReplicaSet", "ReplicaSetValues", "ReplicaCreate", "ReplicaWrite",
    "ReplicaTableInsert", "ReplicaTableRemove", "ReplicaRequestData", "ReplicaParent"
}

for _, rname in ipairs(replicaRemotes) do
    local r = RemoteEvents and RemoteEvents:FindFirstChild(rname)
    if r then hookReplicaRemote(rname, r) end
end

-- Хук RequestBannerSummon — санитизация ДО отправки (предотвращает баг)
-- Требует hookfunction (Synapse/KRNL/Fluxus и др.)
local Remotes = ReplicatedStorage:FindFirstChild("Remotes")
local RequestBannerSummon = Remotes and Remotes:FindFirstChild("RequestBannerSummon")
local hookfn = rawget(_G, "hookfunction")
if type(hookfn) ~= "function" then hookfn = nil end
if RequestBannerSummon and hookfn then
    local orig = RequestBannerSummon.InvokeServer
    hookfn(orig, function(self, ...)
        local args = {...}
        for i, v in ipairs(args) do
            if isNaN(v) or (type(v) == "number" and (v ~= v or v == math.huge or v == -math.huge)) then
                args[i] = 1
                log("RequestBannerSummon: sanitized arg", i, "-> 1")
                warn("[BannerPity Repair] RequestBannerSummon sanitized NaN/Inf")
            end
        end
        return orig(self, unpack(args))
    end)
    log("Hooked RequestBannerSummon (hookfunction)")
elseif RequestBannerSummon then
    log("RequestBannerSummon NOT hooked (no hookfunction) — run repair BEFORE summon")
end

task.wait(1)

local function wfc(p, n, t) return p:WaitForChild(n, t or 5) end
local RS = ReplicatedStorage
local Modules = wfc(RS, "Modules")
local Shared = wfc(Modules, "Shared")
local Handlers = Shared:FindFirstChild("Handlers")
local ReplicaHandler = Handlers and Handlers:FindFirstChild("ReplicaHandler")

-- Способ 1: Хук WaitForPlayerData — возвращаем proxy с подменой nan
local function createNaNProxy(t)
    if type(t) ~= "table" then return t end
    return setmetatable({}, {
        __index = function(_, k)
            local v = t[k]
            if isNaN(v) then return 0 end
            if type(v) == "table" then return createNaNProxy(v) end
            return v
        end,
    })
end

-- Способ E: скан _G на таблицы с BannerPity
local function scanGlobalForBannerPity()
    for k, v in pairs(_G) do
        if type(v) == "table" and v.BannerPity then
            local n = patchTable(v)
            if n > 0 then
                log("scanGlobal: patched", k, ":", n)
                return n
            end
        end
    end
    return 0
end

local function repair()
    log("repair() attempt")
    -- Способ E: скан _G
    if scanGlobalForBannerPity() > 0 then return true end
    local player = Players.LocalPlayer
    if not player or not player.UserId then
        log("repair skip: LocalPlayer not ready")
        return false, "LocalPlayer not ready"
    end

    -- Сначала пробуем ReplicaClient (без ReplicaHandler — избегаем UserId error)
    local ps = player:FindFirstChild("PlayerScripts")
    local rc = ps and ps:FindFirstChild("ClientCache") and ps.ClientCache:FindFirstChild("Utility") and ps.ClientCache.Utility:FindFirstChild("ReplicaClient")
    if rc then
        local ok, mod = pcall(require, rc)
        if ok and mod then
            -- ReplicaClient: ищем Replicas, _replicas, GetReplica, .Data в любых полях
            local function scan(obj, depth)
                if depth > 3 then return 0 end
                if type(obj) ~= "table" then return 0 end
                for k, v in pairs(obj) do
                    if type(v) == "table" and (v.Data or v.RawData or v.BannerPity or (v.ClientData and v.ClientData.BannerPity)) then
                        local t = v.Data or v.RawData or v
                        if type(t) == "table" then
                            local patched = patchTable(t)
                            if patched > 0 then
                                print("[BannerPity Repair] Patched via ReplicaClient", tostring(k), ":", patched)
                                return patched
                            end
                        end
                    elseif type(v) == "table" and not rawequal(v, mod) then
                        local n = scan(v, depth + 1)
                        if n > 0 then return n end
                    end
                end
                return 0
            end
            if scan(mod, 0) > 0 then return true end
            log("ReplicaClient scan: no BannerPity/ClientData found")
        else
            log("ReplicaClient require failed or nil")
        end
    else
        log("ReplicaClient not found (ps/rc)")
    end

    if not ReplicaHandler then
        log("repair skip: no ReplicaHandler")
        return false, "no ReplicaHandler"
    end
    local ok, handler = pcall(require, ReplicaHandler)
    if not ok or not handler then
        log("repair skip: ReplicaHandler require failed", ok and "nil" or handler)
        return false, "require failed"
    end

    -- Инжект LocalPlayer: handler может брать player из script.Parent или upvalue
    local function injectIntoFn(fn)
        if type(fn) ~= "function" then return end
        for i = 1, 50 do
            local name, val = debug.getupvalue(fn, i)
            if not name then break end
            if val == nil and type(name) == "string" then
                local lower = name:lower()
                if lower:find("player") or lower:find("plr") or lower:find("local") then
                    pcall(debug.setupvalue, fn, i, player)
                end
            end
        end
    end
    for k, v in pairs(handler) do
        injectIntoFn(v)
    end
    injectIntoFn(handler.WaitForPlayerData)

    local pd
    local waitFn = handler.WaitForPlayerData
    if type(waitFn) == "function" then
        local ok, res = pcall(waitFn, handler, player)
        if not ok and res and tostring(res):find("UserId") then
            log("repair skip: WaitForPlayerData UserId error —", tostring(res):sub(1, 60))
            return false, "ReplicaHandler needs game context (UserId nil) — use ReplicaSetValues hook"
        end
        if ok and res then pd = res end
        if not pd then
            ok, res = pcall(waitFn, handler)
            if not ok and res and tostring(res):find("UserId") then
                return false, "ReplicaHandler needs game context"
            end
            if ok and res then pd = res end
        end
    end
    if not pd then
        log("repair skip: no PlayerData from WaitForPlayerData")
        return false, "no PlayerData"
    end

    -- Способ A: Прямая запись (если не read-only)
    local n = patchTable(pd)
    if n > 0 then
        print("[BannerPity Repair] Patched", n, "nan values")
        return true, "patched"
    end

    -- Способ B: Ищем upvalue с данными
    for _, method in ipairs({"WaitForPlayerData", "GetPlayerData", "RequestData"}) do
        local fn = handler[method]
        if type(fn) == "function" then
            for i = 1, 50 do
                local name, val = debug.getupvalue(fn, i)
                if not name then break end
                if type(val) == "table" and (val.BannerPity or val.ClientData) then
                    local patched = patchTable(val)
                    if patched > 0 then
                        print("[BannerPity Repair] Patched via upvalue", method, name, ":", patched)
                        return true
                    end
                end
            end
        end
    end

    -- Способ C: Хук WaitForPlayerData (если ReplicaHandler требует player context)
    if not handler._RepairHooked then
        local orig = handler.WaitForPlayerData
        if type(orig) == "function" then
            handler.WaitForPlayerData = function(...)
                local result = orig(...)
                if result and type(result) == "table" then
                    return createNaNProxy(result)
                end
                return result
            end
            handler._RepairHooked = true
            print("[BannerPity Repair] Hooked WaitForPlayerData — новые вызовы получат proxy")
            return true
        end
    end

    log("repair: all methods failed (read-only)")
    return false, "read-only"
end

-- Запуск (с задержкой — ReplicaHandler может грузиться после входа)
task.spawn(function()
    for attempt = 1, 5 do
        task.wait(attempt * 2)
        local ok, success = pcall(repair)
        if ok and success then
            print("[BannerPity Repair] Done. Try summon.")
            return
        end
    end
    warn("[BannerPity Repair] Failed after 5 attempts. Run when in lobby with inventory open.")
end)

-- Периодический repair
task.spawn(function()
    while true do
        task.wait(8)
        pcall(repair)
    end
end)

-- Startup summary
log("=== Started ===")
log("Replica hooks:", table.concat(replicaRemotes, ", "))
log("RequestBannerSummon hook:", hookfn and "YES (hookfunction)" or "NO")
log("Run BEFORE summon if already corrupted. Replica hooks log every event.")
