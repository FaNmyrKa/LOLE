    -- If that fails (module not loaded / unknown hero), we SKIP the unit to
    -- avoid accidentally deleting something valuable.
    local function collectSellBatch()
        local data = getClientData()
        if not data or not data.Unit then return {} end
        local equippedTeam = data.Team and data.Team[data.Team.TeamEquipping] or {}
        local equippedLookup = {}
        if type(equippedTeam) == "table" then
            for _, u in pairs(equippedTeam) do equippedLookup[u] = true end
