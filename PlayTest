-- FINALIZE: Minimizer + config load + load report
-- ════════════════════════════════════════════════════════════════

-- Collect pcall results from every wrapped tab for a single summary Notify
local _tabResults = {
    SUMMON   = _ok_summon,   UNITS    = _ok_units,    AUTOJOIN = _ok_autojoin,
    MACROS   = _ok_macros,   SHOPS    = _ok_shops,
    CLAIMS   = _ok_claims,   EVENTS   = _ok_events,
    CODES    = _ok_codes,    TELEPORT = _ok_teleport, MISC     = _ok_misc,
    SETTINGS = _ok_settings,
}
local _failed = {}
for name, ok in pairs(_tabResults) do
    if ok == false then table.insert(_failed, name) end
end
table.sort(_failed)

task.spawn(function()
    task.wait(0.2)
    pcall(function()
        Window:CreateMinimizer({
            Size = UDim2.fromOffset(50, 50),
            Position = UDim2.new(1, -10, 0.5, 0),
            Icon = "rbxassetid://138310609771261",
        })
    end)
end)

task.spawn(function()
    task.wait(0.5)
    pcall(function() MacLib:SetFolder("ApelHub") end)
    pcall(function() MacLib:LoadAutoLoadConfig() end)
    dbg("Config autoload ran")
end)

if #_failed > 0 then
    local msg = "Failed tabs: " .. table.concat(_failed, ", ")
    warn("[ApelHub] " .. msg)
    print("[ApelHub] " .. msg)
    Notify("⚠ " .. msg .. " — check console for details", 8)
else
    local okCount = 0
    for _, ok in pairs(_tabResults) do if ok then okCount = okCount + 1 end end
    Notify(("Apel Hub loaded · %d tabs OK · %s"):format(
        okCount, _AR.IsGameplayServer and "GAMEPLAY" or "LOBBY"), 4)
end
dbg("Ready")
