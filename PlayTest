-- Extract the hero type name from a data.Unit[uuid] entry.
-- Lobby server uses .id, gameplay server uses .UnitName — accept both.
local function heroNameOf(info)
    if type(info) ~= "table" then return nil end
    if type(info.UnitName) == "string" and info.UnitName ~= "" then return info.UnitName end
    if type(info.id) == "string" and info.id ~= "" then return info.id end
    return nil
end

-- Read remaining stock for a shop item. Different shops store data differently:
--   CoinsShop / RagnarokEvent → data.<shop>.Stock[item]  (nested)
--   RaidShop / WitchEvent / TokyoEvent / FateEvent → data.<shop>[item]  (flat)
-- Returns nil if unknown / unlimited (caller falls back to buying 1).
local SHOP_STOCK_NESTED = { CoinsShop = true, RagnarokEvent = true }
local function shopStockRemaining(shopKey, itemName)
    local data = getClientData()
    if not (data and type(data[shopKey]) == "table") then return nil end
    local container
    if SHOP_STOCK_NESTED[shopKey] then
        container = data[shopKey].Stock
    else
        container = data[shopKey]
    end
    if type(container) ~= "table" then return nil end
    local v = container[itemName]
    if type(v) == "number" then return v end
    return nil
end

