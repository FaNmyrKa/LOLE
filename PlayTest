    -- Unified diagnostic dump: forces PlayerData refresh, serializes
    -- ClientData + Remotes tree, copies everything to clipboard so user
    -- can paste it back to us for analysis.
    -- ───────────────────────────────────────────────────────────────
    local function serializeValue(v, depth, maxDepth, seen)
        depth = depth or 0
        maxDepth = maxDepth or 6
        seen = seen or {}
        local t = typeof(v)
        if t == "nil" then return "nil" end
        if t == "boolean" then return tostring(v) end
        if t == "number" then return tostring(v) end
        if t == "string" then
            if #v > 200 then v = v:sub(1, 200) .. "…" end
            return string.format("%q", v)
        end
        if t == "Instance" then return ("<%s %q>"):format(v.ClassName, v:GetFullName()) end
        if t == "CFrame" then return "CFrame.new(" .. tostring(v) .. ")" end
        if t == "Vector3" then return "Vector3(" .. tostring(v) .. ")" end
        if t == "Color3" then return "Color3(" .. tostring(v) .. ")" end
        if t == "Enum" or t == "EnumItem" then return tostring(v) end
        if t == "function" then return "<function>" end
        if t == "table" then
            if seen[v] then return "<cycle>" end
            seen[v] = true
            if depth >= maxDepth then return "{...}" end
            -- Check if array-like (consecutive integer keys)
            local n = 0
            for _ in pairs(v) do n = n + 1 end
            if n == 0 then return "{}" end

            local indent  = string.rep("  ", depth + 1)
            local closing = string.rep("  ", depth)
            local parts = {}
            -- Sort keys for stable output
            local keys = {}
            for k in pairs(v) do keys[#keys + 1] = k end
            table.sort(keys, function(a, b)
                local ta, tb = type(a), type(b)
                if ta ~= tb then return ta < tb end
                return tostring(a) < tostring(b)
            end)
            -- Truncate if way too big
            local MAX_ENTRIES = 300
            local shown = 0
            for _, k in ipairs(keys) do
                if shown >= MAX_ENTRIES then
                    parts[#parts + 1] = indent .. ("-- ...+ %d more keys"):format(n - shown)
                    break
                end
                shown = shown + 1
                local keyStr
                if type(k) == "string" and k:match("^[_%a][_%w]*$") then
                    keyStr = k
                else
                    keyStr = "[" .. serializeValue(k, depth + 1, maxDepth, seen) .. "]"
                end
                parts[#parts + 1] = indent .. keyStr .. " = " .. serializeValue(v[k], depth + 1, maxDepth, seen)
            end
            seen[v] = nil
            return "{\n" .. table.concat(parts, ",\n") .. "\n" .. closing .. "}"
        end
        return "<" .. t .. ">"
    end

    sec.MiscR:Button({
        Name = "📋 Dump Everything → Clipboard",
        Callback = function()
            Notify("Building dump…", 3)
            task.spawn(function()
                local lines = {}
                local function push(s) lines[#lines + 1] = s end

