-- AUTO JOIN TAB
-- ════════════════════════════════════════════════════════════════
local _ok_autojoin, _err_autojoin = pcall(function()
    -- Special modes that use dedicated remotes (not ConfirmPlay).
    -- Listed in Mode dropdown prefixed with "★" so user picks them alongside
    -- regular modes; Join Now / AutoStart then fires the right remote.
    local SPECIAL_MODES = {
        { label = "★ Challenge",        doorKind = "Challenge", fire = function() Remotes.Play.JoinChallenge:FireServer("Challenge") end },
        { label = "★ Daily Challenge",  doorKind = "Challenge", fire = function() Remotes.Play.JoinChallenge:FireServer("DailyChallenge") end },
        { label = "★ Legend Stage",     doorKind = "Story",     fire = function() Remotes.Play.JoinChallenge:FireServer("LegendStage") end },
        { label = "★ Tournament",       doorKind = "Story",     fire = function() Remotes.Play.StartPlay:FireServer("Tournament") end },
        { label = "★ FireFist Event",   doorKind = "Story",     fire = function() Remotes.Play.PlayFireFist:FireServer() end },
        { label = "★ Thar (Ragnarok)",  doorKind = "Story",     fire = function() Remotes.Play.PlayThar:FireServer() end },
        { label = "★ Witch Event",      doorKind = "Story",     fire = function() Remotes.Play.WitchEvent:FireServer() end },
        { label = "★ Gilgamash (Fate)", doorKind = "Story",     fire = function() Remotes.Play.GilgamashCastle:FireServer() end },
        { label = "★ Kuromi Event",     doorKind = "Story",     fire = function() Remotes.Play.PlayKuromi:FireServer() end },
    }
    local SPECIAL_BY_LABEL = {}
    for _, s in ipairs(SPECIAL_MODES) do SPECIAL_BY_LABEL[s.label] = s end

    -- Build mode list: StageData modes first, then special ones
    local MODES = {}
    for modeName in pairs(StageData) do table.insert(MODES, modeName) end
    table.sort(MODES)
    for _, s in ipairs(SPECIAL_MODES) do table.insert(MODES, s.label) end
    if #MODES == 0 then MODES = { "None" } end

    local function isSpecialMode(label) return SPECIAL_BY_LABEL[label] ~= nil end

    local function getStagesForMode(mode)
        if isSpecialMode(mode) then return { "—" } end
        local out = {}
        local m = StageData[mode]
        if type(m) == "table" then
            for k, v in pairs(m) do
                if type(v) == "table" then table.insert(out, k) end
            end
        end
        table.sort(out)
        if #out == 0 then out = { "None" } end
        return out
    end

    local function getChaptersForStage(mode, stage)
        if isSpecialMode(mode) then return { "—" } end
        local out = {}
        local m = StageData[mode]
        if m and m[stage] and type(m[stage]) == "table" then
            local n = m[stage][1] or 5
            for i = 1, tonumber(n) or 5 do
                table.insert(out, "Chapter" .. i)
            end
        end
        if #out == 0 then out = { "Chapter1" } end
        return out
    end

    -- Default selection
    local defaultMode = (type(StageData.Story) == "table" and "Story") or MODES[1]
    local stageOpts    = getStagesForMode(defaultMode)
    local chapterOpts  = getChaptersForStage(defaultMode, stageOpts[1])
    _AR.SelectedMode       = defaultMode
    _AR.SelectedStage      = stageOpts[1]
    _AR.SelectedChapter    = chapterOpts[1]
    _AR.SelectedDifficulty = "Normal"
    _AR.FriendsOnly        = false

    -- ─── Door teleport helpers ─────────────────────────────────
    -- These indices match the lobby workspace layout. If the game moves
    -- things around we fall back to scanning by Model name.
    local DOORS = {
        Story     = 143,  -- Story / LegendStage door
        Challenge = 22,   -- Challenge / DailyChallenge door
        Raid      = 2,    -- Raid door
    }

    local function getDoorCFrame(kind)
        local lobby = Workspace:FindFirstChild("Map")
        lobby = lobby and lobby:FindFirstChild("Lobby")
        if not lobby then return nil end
        local idx = DOORS[kind]
        local children = lobby:GetChildren()
        local candidate = children[idx]
        -- Resolve candidate.Model.Model to a positional part
        local function pickCFrame(root)
            if not root then return nil end
            local m1 = root:FindFirstChild("Model")
            if not m1 then return nil end
            local m2 = m1:FindFirstChild("Model")
            local part = (m2 and m2.PrimaryPart) or (m1 and m1.PrimaryPart)
            if not part then
                -- find any BasePart descendant
                for _, d in ipairs((m2 or m1):GetDescendants()) do
                    if d:IsA("BasePart") then part = d; break end
                end
            end
            return part and part.CFrame
        end
        return pickCFrame(candidate)
    end

    local function teleportToDoor(kind)
        local char = LocalPlayer.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then
            Notify("Character not loaded", 3)
            return false
        end
        local cf = getDoorCFrame(kind)
        if not cf then
            Notify("Door not found: " .. kind, 3)
            return false
        end
        -- Teleport with small Y offset so we don't clip inside the door
        hrp.CFrame = cf + Vector3.new(0, 3, 0)
        return true
    end

    -- Determine which door to use for the currently selected mode
    local function doorKindForMode(mode)
        local spec = SPECIAL_BY_LABEL[mode]
        if spec and spec.doorKind then return spec.doorKind end
        if mode == "Raid" then return "Raid" end
        return "Story"  -- Story, LegendStage, and default
    end
    -- Normal flow: ConfirmPlay → creates a portal in workspace → StartPlay
    -- begins the match. Auto Start toggle does both.
    local function fireConfirmPlay()
        local p = Remotes:FindFirstChild("Play")
        local cp = p and p:FindFirstChild("ConfirmPlay")
        if not cp then
            Notify("Play.ConfirmPlay missing (need lobby server)", 3)
            return false
        end
        local ok, err = pcall(function()
            cp:FireServer(
                _AR.SelectedStage,
                _AR.SelectedChapter,
                _AR.SelectedDifficulty,
                _AR.FriendsOnly,
                _AR.SelectedMode
            )
        end)
        if not ok then
            Notify("ConfirmPlay error: " .. tostring(err), 4)
            return false
        end
        return true
    end

    local function fireStartPlay()
        local p = Remotes:FindFirstChild("Play")
        local sp = p and p:FindFirstChild("StartPlay")
        if not sp then return false end
        local ok = pcall(function() sp:FireServer() end)
        return ok
    end

    -- Join-only (creates portal / joins challenge). No StartPlay.
    -- Teleports to the correct door first so the game's UI / tile spawn.
    local function performJoin()
        local mode = _AR.SelectedMode
        teleportToDoor(doorKindForMode(mode))
        task.wait(0.3)
        local spec = SPECIAL_BY_LABEL[mode]
        if spec then
            local ok, err = pcall(spec.fire)
            if ok then
                Notify("Joined: " .. mode:gsub("^★ ", ""), 3)
            else
                Notify("Failed: " .. tostring(err), 4)
            end
            return
        end
        if fireConfirmPlay() then
            Notify(("Portal created: %s · %s · %s · %s"):format(
                mode, tostring(_AR.SelectedStage),
                tostring(_AR.SelectedChapter),
                tostring(_AR.SelectedDifficulty)), 3)
        end
    end

    -- Full start flow: teleport to door → ConfirmPlay → StartPlay
    local function performJoinAndStart()
        local mode = _AR.SelectedMode
        teleportToDoor(doorKindForMode(mode))
        task.wait(0.3)
        local spec = SPECIAL_BY_LABEL[mode]
        if spec then
            pcall(spec.fire)
            Notify("Starting: " .. mode:gsub("^★ ", ""), 3)
            return
        end
        if fireConfirmPlay() then
            Notify(("Starting: %s · %s · %s · %s"):format(
                mode, tostring(_AR.SelectedStage),
                tostring(_AR.SelectedChapter),
                tostring(_AR.SelectedDifficulty)), 3)
            task.delay(0.6, function()
                fireStartPlay()
            end)
        end
    end

    -- ═══ LEFT — main selection + toggles ═══
    sec.PlayL:Header({ Text = "Match Selection" })

    local modeDD, stageDD, chapterDD, diffDD

    modeDD = sec.PlayL:Dropdown({
        Name = "Mode",
        Options = MODES,
        Default = defaultMode,
        Callback = function(v)
            _AR.SelectedMode = v
            local stages = getStagesForMode(v)
            pcall(function() stageDD:ClearOptions() end)
            pcall(function() stageDD:InsertOptions(stages) end)
            pcall(function() stageDD:UpdateSelection(stages[1]) end)
            _AR.SelectedStage = stages[1]
            local chaps = getChaptersForStage(v, stages[1])
            pcall(function() chapterDD:ClearOptions() end)
            pcall(function() chapterDD:InsertOptions(chaps) end)
            pcall(function() chapterDD:UpdateSelection(chaps[1]) end)
            _AR.SelectedChapter = chaps[1]
        end,
    }, "PlayMode")

    stageDD = sec.PlayL:Dropdown({
        Name = "Stage",
        Options = stageOpts,
        Default = stageOpts[1],
        Callback = function(v)
            _AR.SelectedStage = v
            local chaps = getChaptersForStage(_AR.SelectedMode, v)
            pcall(function() chapterDD:ClearOptions() end)
            pcall(function() chapterDD:InsertOptions(chaps) end)
            pcall(function() chapterDD:UpdateSelection(chaps[1]) end)
            _AR.SelectedChapter = chaps[1]
        end,
    }, "PlayStage")

    chapterDD = sec.PlayL:Dropdown({
        Name = "Chapter",
        Options = chapterOpts,
        Default = chapterOpts[1],
        Callback = function(v) _AR.SelectedChapter = v end,
    }, "PlayChapter")

    diffDD = sec.PlayL:Dropdown({
        Name = "Difficulty",
        Options = { "Normal", "Hard", "Nightmare" },
        Default = "Normal",
        Callback = function(v) _AR.SelectedDifficulty = v end,
    }, "PlayDifficulty")

    sec.PlayL:Toggle({
        Name = "Friends Only",
        Default = false,
        Callback = function(v) _AR.FriendsOnly = v end,
    }, "FriendsOnly")

    sec.PlayL:Divider()
    sec.PlayL:Header({ Text = "Auto" })

    sec.PlayL:Toggle({
        Name = "AutoStart",
        Default = false,
        Callback = function(v)
            _AR.AutoQueueEnabled = v
            if v then Notify("AutoStart ON — " .. _AR.SelectedMode, 2) end
        end,
    }, "AutoStart")

    sec.PlayL:Button({
        Name = "Start Match Now",
        Callback = performJoinAndStart,
    })

    -- On gameplay server: add Return/Replay/PlayNext buttons (match-end flow)
    if _AR.IsGameplayServer then
        sec.PlayL:Divider()
        sec.PlayL:Header({ Text = "Match controls" })
        sec.PlayL:Button({
            Name = "▶ Replay match",
            Callback = function()
                safe(function()
                    local r = Remotes:FindFirstChild("Replay")
                    if r then r:FireServer() end
                end)
            end,
        })
        sec.PlayL:Button({
            Name = "⟳ Play Next (sequel map)",
            Callback = function()
                safe(function()
                    local r = Remotes:FindFirstChild("PlayNext")
                    if r then r:FireServer() end
                end)
            end,
        })
        sec.PlayL:Button({
            Name = "← Return to Lobby",
            Callback = function()
                safe(function()
                    local r = Remotes:FindFirstChild("ReturnToLobby")
                    if r then r:FireServer() end
                end)
            end,
        })
    end

    -- ═══ RIGHT — live status ═══
    sec.PlayR:Header({ Text = "Status" })
    local statusPara = sec.PlayR:Paragraph({ Header = "Live", Body = "Idle" })
    task.spawn(function()
        while getgenv()._ARRunning do
            task.wait(1)
            local body
            if _AR.IsGameplayServer then
                -- In a match: show stage info from workspace
                local pf = Workspace:FindFirstChild("PlayFolder")
                local sf = pf and pf:FindFirstChild("StageFolder")
                local stage = sf and sf:FindFirstChild("Stage")
                local chapter = sf and sf:FindFirstChild("Chapter")
                local mode = sf and sf:FindFirstChild("Mode")
                local diff = sf and sf:FindFirstChild("Difficult")
                body = ("● IN MATCH\n%s · %s\n%s · %s\n\nSaved selection:\n%s · %s · %s · %s"):format(
                    (stage and stage.Value) or "?",
                    (chapter and chapter.Value) or "?",
                    (mode and mode.Value) or "?",
                    (diff and diff.Value) or "?",
                    tostring(_AR.SelectedMode),
                    tostring(_AR.SelectedStage),
                    tostring(_AR.SelectedChapter),
                    tostring(_AR.SelectedDifficulty))
            elseif isInQueue() then
                body = ("● IN QUEUE\n%s · %s\n%s · %s"):format(
                    _AR.SelectedMode, tostring(_AR.SelectedStage),
                    tostring(_AR.SelectedChapter), tostring(_AR.SelectedDifficulty))
            elseif _AR.AutoQueueEnabled then
                body = ("AutoStart ON · waiting\nNext join: %s"):format(_AR.SelectedMode)
            else
                body = "Idle"
            end
            pcall(function() statusPara:UpdateBody(body) end)
        end
    end)

    if _AR.IsGameplayServer then
        sec.PlayR:Paragraph({
            Header = "Gameplay server",
            Body = "Queue / Portal / AutoStart don't apply here. Saved selection "
                .. "will be used on lobby when you're back. Use Match controls "
                .. "above to Replay / PlayNext / Return.",
        })
    else
        sec.PlayR:Paragraph({
            Header = "Tip",
            Body = "Modes prefixed with ★ are event / one-shot plays (Tournament, Fate, "
                .. "Challenges, etc.). Stage/Chapter/Difficulty only apply to normal modes.",
        })
    end

    -- ═══ AutoStart loop ═══
    -- Checks every second: if not already in a match, runs the full flow
    -- (teleport to door → ConfirmPlay → StartPlay). Cooldown 11s prevents
    -- rapid-fire spam.
    _AR._lastQueueAt = _AR._lastQueueAt or 0
    task.spawn(function()
        while getgenv()._ARRunning do
            task.wait(1)
            if _AR.AutoQueueEnabled and _AR.ModulesLoaded then
                if not isInQueue() and (tick() - _AR._lastQueueAt) > 11 then
                    _AR._lastQueueAt = tick()
                    performJoinAndStart()
                end
            end
        end
    end)
end)
if not _ok_autojoin then warn("[ApelHub] AUTOJOIN tab setup failed: " .. tostring(_err_autojoin)) print("[ApelHub] AUTOJOIN:", _err_autojoin) end

