    -- ═══════════════════════════════════════════════════════════════
    -- Place Anywhere (bypass client placement zone check)
    --
    -- Flow:
    -- 1. User holds a unit (ghost model appears in workspace).
    -- 2. User clicks somewhere. Two cases:
    --    (a) valid tile: game script fires CreateUnits(uuid, cf). Our
    --        namecall hook rewrites cf → mouse-hit position and also
    --        bumps _ARLastCreateUnitsFire. Placement succeeds.
    --    (b) invalid tile (roof, water, etc): game script's own validator
    --        rejects the click and CreateUnits is NOT fired. Our LMB
    --        listener waits 80 ms, sees _ARLastCreateUnitsFire wasn't
    --        bumped, and fires CreateUnits itself with mouse-hit position.
    -- ═══════════════════════════════════════════════════════════════
    sec.MiscR:Divider()
    sec.MiscR:Header({ Text = "Place Anywhere" })

    sec.MiscR:Paragraph({
        Header = "How to use",
        Body = "Turn ON, then in-match grab a unit from team slots (Unit1..6) "
             .. "as usual. Click anywhere — paths, roofs, water, air, off-map. "
