local okLoad, errLoad = pcall(function()
    Remotes = awaitChild(RS, "Remotes", 15)
    Modules = awaitChild(RS, "Modules", 15)
    Assets  = RS:FindFirstChild("Assets") or RS:WaitForChild("Assets", 5)
    Banner  = RS:FindFirstChild("Banner") -- may not exist on gameplay server

    -- Core modules — these MUST exist on any server for the hub to function.
    PlayerDataClient = require(awaitChild(Modules, "PlayerDataClient"))
    UnitModule       = require(awaitChild(Modules, "UnitModule"))
    ItemModule       = require(awaitChild(Modules, "ItemModule"))
    StageData        = require(awaitChild(Modules, "StageData"))
    QuestData        = require(awaitChild(Modules, "QuestData"))
    Pity             = require(awaitChild(Modules, "Pity"))

    -- Optional modules — present only on lobby server. On the gameplay server
    -- we fall back to empty tables so shop/craft/evo tabs still build (they
    -- just show "None" in dropdowns). This lets macros record in gameplay.
    local function tryRequire(name)
        local mod = Modules:FindFirstChild(name)
        if not mod then return {} end
        local ok, result = pcall(require, mod)
        if ok and type(result) == "table" then return result end
        return {}
    end

    BattlePassData   = tryRequire("BattlePassData")
    LevelRewardData  = tryRequire("LevelRewardData")
    CoinsShopData    = tryRequire("CoinsShopData")
    RaidShopData     = tryRequire("RaidShopData")
    WitchEventData   = tryRequire("WitchEventData")
    TokyoEventData   = tryRequire("TokyoEventData")
    FateEventData    = tryRequire("FateEventData")
    RagnarokData     = tryRequire("RagnarokData")
    StoreConfig      = tryRequire("StoreConfig")
    PassiveData      = tryRequire("Passive")
    SkinData         = tryRequire("Skin")
    LinkDatabase     = tryRequire("LinkDatabase")
    QueueGenerator   = Modules:FindFirstChild("QueueGenerator")
    StageConvert     = Modules:FindFirstChild("StageConvert")
    if QueueGenerator then pcall(function() QueueGenerator = require(QueueGenerator) end) end
    if StageConvert   then pcall(function() StageConvert   = require(StageConvert)   end) end

    -- Detect which server we're on (by presence of CoinsShopData)
    _AR.IsGameplayServer = (type(CoinsShopData) ~= "table" or next(CoinsShopData) == nil)

    -- Warm up PlayerDataClient. On gameplay server, .Unit is populated via
    -- PlayerData.ReturnData — invoke it once if data comes back empty.
    local t0 = tick()
    while tick() - t0 < 8 do
        local ok, data = pcall(PlayerDataClient.GetClientData)
        if ok and data then break end
        task.wait(0.1)
    end
    if _AR.IsGameplayServer then
        pcall(function()
            local rf = Remotes:FindFirstChild("PlayerData")
                and Remotes.PlayerData:FindFirstChild("ReturnData")
            if rf and rf:IsA("RemoteFunction") then rf:InvokeServer() end
        end)
    end

    _AR.ModulesLoaded = true
end)
