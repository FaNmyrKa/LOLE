    })

    -- Use camera+viewport raycast instead of LocalPlayer:GetMouse().
    -- Raycast excludes LocalPlayer character and the ghost itself so we
    -- never hit them by accident.
    local function raycastMouse()
        local cam = Workspace.CurrentCamera
        if not cam then return nil end
        local mp = UserInputService:GetMouseLocation()
        local ray = cam:ViewportPointToRay(mp.X, mp.Y, 0)
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        local filter = {}
        if LocalPlayer.Character then table.insert(filter, LocalPlayer.Character) end
        params.FilterDescendantsInstances = filter
        local hit = Workspace:Raycast(ray.Origin, ray.Direction * 1500, params)
        if hit then
            return CFrame.new(hit.Position)
        end
        -- Fallback: project a fixed distance into the ray
        return CFrame.new(ray.Origin + ray.Direction * 200)
    end

    -- Find the holding-ghost model. The game puts it in workspace.HoldingUnit
    -- (not workspace root) — see decompile line v_u_54.Parent = v_u_10 where
    -- v_u_10 = workspace:WaitForChild("HoldingUnit"). Fallback: scan root for
    -- a Model with UnitRealName attribute but no Stats child (in case game
    -- version differs).
    local function findHoldingGhost()
        local hu = Workspace:FindFirstChild("HoldingUnit")
        if hu then
            for _, m in ipairs(hu:GetChildren()) do
                if m:IsA("Model") and m:GetAttribute("UnitRealName") then
                    return m
                end
            end
        end
        -- Fallback: old heuristic (root workspace scan)
        local playFolder = Workspace:FindFirstChild("PlayFolder")
        local ownFolder  = playFolder and playFolder:FindFirstChild(LocalPlayer.Name)
        for _, m in ipairs(Workspace:GetChildren()) do
            if m:IsA("Model")
                and m ~= ownFolder
                and m:GetAttribute("UnitRealName")
                and not m:FindFirstChild("Stats") then
                return m
            end
        end
        return nil
    end

    -- CFrame to send to server: mouse world-hit + ghost rotation
    local function paMouseCF()
        local hit = raycastMouse()
        if not hit then return nil end
        local ghost = findHoldingGhost()
        if ghost and ghost.PrimaryPart then
            local gCF = ghost.PrimaryPart.CFrame
            local rot = gCF - gCF.Position
            return CFrame.new(hit.Position) * rot
        end
        return hit
    end
    -- Register callback the namecall hook reads via getgenv()
    getgenv()._ARMouseCFFn = paMouseCF

    sec.MiscR:Toggle({
        Name = "Enable Place Anywhere",
        Default = false,
        Callback = function(v)
            _AR.PlaceAnywhereEnabled = v
            getgenv()._ARPlaceAnywhereEnabled = v
