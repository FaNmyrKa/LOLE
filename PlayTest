-- MACROS TAB (Record/Playback unit placement & upgrades)
-- ════════════════════════════════════════════════════════════════
local _ok_macros, _err_macros = pcall(function()
    -- ─── CFrame serialization (12 floats) ─────────────────────────
    local function cfToArr(cf)
        local c = { cf:GetComponents() }
        local out = {}
        for i = 1, #c do out[i] = math.floor(c[i] * 10000 + 0.5) / 10000 end
        return out
    end
    local function arrToCf(a)
        if type(a) ~= "table" or #a < 12 then return CFrame.new() end
        return CFrame.new(a[1], a[2], a[3], a[4], a[5], a[6],
                          a[7], a[8], a[9], a[10], a[11], a[12])
    end

    -- ─── Team slot helpers ────────────────────────────────────────
    -- Cache the Slots folder reference — avoid expensive GetDescendants()
    -- on every placement event during recording.
    local _cachedSlots = nil
    local function findTeamSlotsFolder()
        if _cachedSlots and _cachedSlots.Parent then return _cachedSlots end
        local pg = LocalPlayer:FindFirstChild("PlayerGui")
        if not pg then return nil end
        -- Direct path first (fast)
        local direct = pg:FindFirstChild("Main")
        local bottom = direct and direct:FindFirstChild("BottomMain")
        local unitTeam = bottom and bottom:FindFirstChild("UnitTeam")
        local slots = unitTeam and unitTeam:FindFirstChild("Slots")
        if slots then _cachedSlots = slots; return slots end
        -- Fallback: recursive scan
        for _, d in ipairs(pg:GetDescendants()) do
            if d.Name == "Slots" and d.Parent and d.Parent.Name == "UnitTeam" then
                _cachedSlots = d
                return d
            end
        end
        return nil
    end

    local function getTeamSlotButtons()
        local slots = findTeamSlotsFolder()
        if not slots then return {} end
        local out = {}
        for i = 1, 6 do
            local btn = slots:FindFirstChild("Unit" .. i)
            if btn then out[i] = btn end
        end
        return out
    end

    -- Resolve UUID → UnitName (hero type) by scanning team slot attributes
    local function uuidToUnitName(uuid)
        if not uuid or uuid == "" then return nil end
        for _, btn in ipairs(getTeamSlotButtons()) do
            if btn:GetAttribute("UnitRealName") == uuid then
                return btn:GetAttribute("UnitName"), btn
            end
        end
        return nil
    end

    -- Resolve UnitName (hero type) → UUID from current team (for playback)
    local function unitNameToUuid(unitName)
        if not unitName or unitName == "" then return nil end
        for _, btn in ipairs(getTeamSlotButtons()) do
            if btn:GetAttribute("UnitName") == unitName then
                return btn:GetAttribute("UnitRealName")
            end
        end
        return nil
    end

    local function getOwnPlayFolder()
        local pf = Workspace:FindFirstChild("PlayFolder")
        if not pf then return nil end
        return pf:FindFirstChild(LocalPlayer.Name)
    end

    -- ─── File I/O ─────────────────────────────────────────────────
    local function macroPath(name)
        return MacroFolder .. "/" .. name .. ".json"
    end

    local function listMacros()
        local out = {}
        if not isfolder(MacroFolder) then return out end
        local ok, files = pcall(listfiles, MacroFolder)
        if not ok or type(files) ~= "table" then return out end
        for _, f in ipairs(files) do
            local base = f:match("([^/\\]+)%.json$")
            if base then table.insert(out, base) end
        end
        table.sort(out)
        return out
    end

    local function saveMacro(name, macro)
        if not name or name == "" then return false, "empty name" end
        local path = macroPath(name)
        local ok, encoded = pcall(HttpService.JSONEncode, HttpService, macro)
        if not ok then return false, tostring(encoded) end
        local wrote, err = pcall(writefile, path, encoded)
        if not wrote then return false, tostring(err) end
        return true
    end

    local function loadMacro(name)
        local path = macroPath(name)
        if not isfile(path) then return nil, "not found" end
        local ok, text = pcall(readfile, path)
        if not ok then return nil, tostring(text) end
        local okD, decoded = pcall(HttpService.JSONDecode, HttpService, text)
        if not okD then return nil, tostring(decoded) end
        return decoded
    end

    local function deleteMacro(name)
        local path = macroPath(name)
        if isfile(path) then pcall(delfile, path) end
    end

    -- ─── Record hook (install ONCE per Roblox session) ───────────
    -- Stored in getgenv() so that re-running the script doesn't chain hooks.
    --
    -- KILL SWITCH: the hook checks getgenv()._ARHookActive FIRST. While this
    -- flag is false (default), the hook returns instantly without doing any
    -- table lookups — this is critical because the game may issue tens of
    -- thousands of namecalls per second during unit placement, and even an
    -- O(1) table lookup can stack up to game-crashing overhead.
    --
    -- The flag is flipped to true only when the user enables Record, starts
    -- a Playback, or enables Place Anywhere. It flips back to false when all
    -- three are inactive.
    do
        -- Build a fast { [Instance] = "Name" } lookup table.
        local targetRemotes = getgenv()._ARTargetRemotes or {}
        for k in pairs(targetRemotes) do targetRemotes[k] = nil end
        for _, rname in ipairs({
            "CreateUnits", "Upgrades", "SellUnit", "ChangeOrder",
            "ActiveSkill", "SkipWave", "UseItem",
        }) do
            local r = Remotes:FindFirstChild(rname)
            if r then targetRemotes[r] = rname end
        end
        getgenv()._ARTargetRemotes = targetRemotes
        -- Default OFF. Callers enable only when they need hook behavior.
        if getgenv()._ARHookActive == nil then
            getgenv()._ARHookActive = false
        end

        -- V4 sentinel: adds kill-switch. Replaces V3 hook if present.
        if not getgenv()._ARNamecallHookV4 and hookmetamethod then
            getgenv()._ARNamecallHookV4 = true
            local TARGETS = targetRemotes
            local oldNamecall
            oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
                -- SUPER-FAST PATH: kill switch. One upvalue check, done.
                -- Stays here 99%+ of the time when hub features are idle.
                if not getgenv()._ARHookActive then
                    return oldNamecall(self, ...)
                end
                -- FAST PATH: single table lookup by Instance reference.
                local remoteName = TARGETS[self]
                if not remoteName then
                    return oldNamecall(self, ...)
                end
                if getnamecallmethod() ~= "FireServer" then
                    return oldNamecall(self, ...)
                end

                -- SLOW PATH: this is one of our target remotes.
                local isExternal = not checkcaller()

                if isExternal then
                    local fn = getgenv()._ARMacroRecordFn
                    if fn then pcall(fn, self, ...) end
                end

                if remoteName == "CreateUnits" then
                    getgenv()._ARLastCreateUnitsFire = tick()
                    if isExternal and getgenv()._ARPlaceAnywhereEnabled then
                        local cb = getgenv()._ARMouseCFFn
                        if cb then
                            local ok, newCF = pcall(cb)
                            if ok and typeof(newCF) == "CFrame" then
                                local args = { ... }
                                args[2] = newCF
                                return oldNamecall(self, unpack(args))
                            end
                        end
                    end
                end

                return oldNamecall(self, ...)
            end)
        end
    end

    -- Helper to recompute whether the hook should be active. Called whenever
    -- Record / Playback / PlaceAnywhere toggles change.
    local function refreshHookActive()
        local active = _AR.MacroRecording
                    or _AR.MacroPlaying
                    or _AR.PlaceAnywhereEnabled
        getgenv()._ARHookActive = active and true or false
        dbg(("[hook] active=%s (rec=%s play=%s pa=%s)"):format(
            tostring(getgenv()._ARHookActive),
            tostring(_AR.MacroRecording),
            tostring(_AR.MacroPlaying),
            tostring(_AR.PlaceAnywhereEnabled)))
    end
    _AR._refreshHookActive = refreshHookActive

    -- Actual recording dispatcher (replaced on each script reload)
    local function recordDispatch(remote, ...)
        if not _AR.MacroRecording then return end
        if not _AR.MacroT0 or _AR.MacroT0 == 0 then return end
        local args = { ... }
        local t = tick() - _AR.MacroT0
        local name = remote.Name

        if name == "CreateUnits" then
            -- args[1] = UnitRealName (uuid), args[2] = CFrame
            local uuid = args[1]
            local cf = args[2]
            if typeof(cf) ~= "CFrame" then return end
            _AR.MacroPlaceCounter = _AR.MacroPlaceCounter + 1
            local idx = _AR.MacroPlaceCounter
            _AR.MacroPendingPlace = _AR.MacroPendingPlace + 1
            local unitName = uuidToUnitName(uuid) or "?"
            table.insert(_AR.CurrentMacro.Events, {
                t = math.floor(t * 1000 + 0.5) / 1000,
                Action = "Place",
                UnitName = unitName,
                CFrame = cfToArr(cf),
                PlaceIdx = idx,
            })

        elseif name == "Upgrades" then
            -- args[1] = model instance, args[2] = optional state number
            local model = args[1]
            local stateNum = tonumber(args[2])
            local idx = nil
            if typeof(model) == "Instance" then
                local stats = model:FindFirstChild("Stats")
                local urp = stats and stats:GetAttribute("UnitRealPlace")
                if urp then idx = _AR.MacroRealPlaceToIdx[urp] end
            end
            if idx then
                table.insert(_AR.CurrentMacro.Events, {
                    t = math.floor(t * 1000 + 0.5) / 1000,
                    Action = "Upgrade",
                    PlaceIdx = idx,
                    StateNum = stateNum,
                })
            end

        elseif name == "SellUnit" then
            -- args[1] = modelName, args[2] = UnitRealPlace
            local urp = args[2]
            local idx = urp and _AR.MacroRealPlaceToIdx[urp]
            if idx then
                table.insert(_AR.CurrentMacro.Events, {
                    t = math.floor(t * 1000 + 0.5) / 1000,
                    Action = "Sell",
                    PlaceIdx = idx,
                })
            end

        elseif name == "ChangeOrder" then
            local model = args[1]
            local idx = nil
            if typeof(model) == "Instance" then
                local stats = model:FindFirstChild("Stats")
                local urp = stats and stats:GetAttribute("UnitRealPlace")
                if urp then idx = _AR.MacroRealPlaceToIdx[urp] end
            end
            if idx then
                table.insert(_AR.CurrentMacro.Events, {
                    t = math.floor(t * 1000 + 0.5) / 1000,
                    Action = "Order",
                    PlaceIdx = idx,
                })
            end

        elseif name == "ActiveSkill" then
            -- From decompile (123.lua): ActiveSkill:FireServer(UnitRealPlace, UnitName)
            --   v_u_9:WaitForChild("ActiveSkill"):FireServer(v_u_417, v_u_414)
            -- where v_u_417 = UnitRealPlace attribute, v_u_414 = unit name.
            local urp = args[1]
            local unitName = args[2]
            local idx = urp and _AR.MacroRealPlaceToIdx[urp]
            if idx then
                table.insert(_AR.CurrentMacro.Events, {
                    t = math.floor(t * 1000 + 0.5) / 1000,
                    Action = "ActiveSkill",
                    PlaceIdx = idx,
                    UnitName = unitName,
                })
            end

        elseif name == "SkipWave" then
            table.insert(_AR.CurrentMacro.Events, {
                t = math.floor(t * 1000 + 0.5) / 1000,
                Action = "SkipWave",
                Vote = args[1] or "Yes",
            })

        elseif name == "UseItem" then
            table.insert(_AR.CurrentMacro.Events, {
                t = math.floor(t * 1000 + 0.5) / 1000,
                Action = "UseItem",
                Item = args[1],
                Amount = tonumber(args[2]) or 1,
            })
        end
    end
    getgenv()._ARMacroRecordFn = recordDispatch

    -- ─── CreateUnits2 listener (maps placeIdx → model during record AND playback) ─
    local createUnits2 = Remotes:FindFirstChild("CreateUnits2")
    if createUnits2 then
        local conn = createUnits2.OnClientEvent:Connect(function(arg, playerName, placedModel)
            if playerName ~= LocalPlayer.Name then return end
            if typeof(placedModel) ~= "Instance" then return end
            if _AR.MacroPendingPlace > 0 then
                _AR.MacroPendingPlace = _AR.MacroPendingPlace - 1
                -- Assign to the earliest idx that has no model yet
                for idx = 1, _AR.MacroPlaceCounter do
                    if _AR.MacroPlaceIdxToModel[idx] == nil then
                        _AR.MacroPlaceIdxToModel[idx] = placedModel
                        local stats = placedModel:FindFirstChild("Stats")
                        local urp = stats and stats:GetAttribute("UnitRealPlace")
                        if urp then _AR.MacroRealPlaceToIdx[urp] = idx end
                        break
                    end
                end
            end
        end)
        table.insert(_cleanupConns, conn)
    end

    -- ─── GameStart listener → reset & maybe auto-play macro ───────
    local function resetMacroRuntime()
        _AR.MacroT0 = tick()
        _AR.MacroPlaceCounter = 0
        _AR.MacroPendingPlace = 0
        _AR.MacroPlaceIdxToModel = {}
        _AR.MacroRealPlaceToIdx = {}
    end

    local gameStart = Remotes:FindFirstChild("GameStart")
    if gameStart then
        local conn = gameStart.OnClientEvent:Connect(function()
            resetMacroRuntime()
            if _AR.MacroRecording then
                -- Clear previous events for a fresh recording of this match
                _AR.CurrentMacro = {
                    Meta = {
                        stage      = _AR.SelectedStage,
                        mode       = _AR.SelectedMode,
                        chapter    = _AR.SelectedChapter,
                        difficulty = _AR.SelectedDifficulty,
                        placeId    = game.PlaceId,
                        recordedAt = os.date("%Y-%m-%d %H:%M:%S"),
                    },
                    Events = {},
                }
                Notify("Macro recording: match started", 3)
            end
            if _AR.MacroAutoPlayOnStart and _AR.SelectedMacroName ~= "" and not _AR.MacroPlaying then
                task.defer(function() _AR._playMacro(_AR.SelectedMacroName) end)
            end
        end)
        table.insert(_cleanupConns, conn)
    end

    -- Auto Ready — click Ready when countdown appears
    local cdStart = Remotes:FindFirstChild("CountDownStart")
    if cdStart then
        local conn = cdStart.OnClientEvent:Connect(function()
            if _AR.MacroAutoReady then
                safe(function() Remotes.Ready:FireServer() end)
            end
        end)
        table.insert(_cleanupConns, conn)
    end

    -- Auto Skip Wave (vote Yes)
    local countdownWave = Remotes:FindFirstChild("CountdownWave")
    if countdownWave then
        local conn = countdownWave.OnClientEvent:Connect(function()
            if _AR.MacroAutoSkipWave then
                task.delay(0.3, function()
                    safe(function() Remotes.SkipWave:FireServer("Yes") end)
                end)
            end
        end)
        table.insert(_cleanupConns, conn)
    end

    -- ─── Playback ─────────────────────────────────────────────────
    function _AR._playMacro(name)
        if _AR.MacroPlaying then
            Notify("Macro already playing", 2)
            return
        end
        local macro, err = loadMacro(name)
        if not macro or not macro.Events then
            Notify("Load failed: " .. tostring(err), 3)
            return
        end
        if #macro.Events == 0 then
            Notify("Macro has no events", 3)
            return
        end

        _AR.MacroPlaying = true
        if _AR._refreshHookActive then _AR._refreshHookActive() end
        -- Stage warning
        if macro.Meta and macro.Meta.stage and _AR.SelectedStage ~= "" and macro.Meta.stage ~= _AR.SelectedStage then
            Notify("⚠ Macro stage mismatch (" .. tostring(macro.Meta.stage) .. " vs " .. tostring(_AR.SelectedStage) .. ")", 5)
        end

        task.spawn(function()
            -- Fresh runtime if match didn't just restart
            resetMacroRuntime()
            local events = macro.Events
            table.sort(events, function(a, b) return (a.t or 0) < (b.t or 0) end)
            local startT = tick()
            local speed = math.max(0.1, _AR.MacroSpeed or 1)
            local playedPlaceCounter = 0
            dbg("Playing macro: " .. name .. " (" .. #events .. " events)")

            -- Position-based fallback resolver. Used when MacroPlaceIdxToModel
            -- doesn't have a live model for a placeIdx (CreateUnits2 ACK was
            -- missed or model was destroyed). Scans workspace.Unit[player]
            -- for a unit within 4 studs of the recorded CFrame position.
            local function resolveModelByPlaceIdx(placeIdx)
                -- First try direct lookup
                local direct = _AR.MacroPlaceIdxToModel[placeIdx]
                if direct and direct.Parent then return direct end
                -- Find the Place event for this placeIdx to get its CFrame
                local placeEv
                for _, e in ipairs(events) do
                    if e.Action == "Place" and e.PlaceIdx == placeIdx then
                        placeEv = e; break
                    end
                end
                if not placeEv or not placeEv.CFrame then return nil end
                local targetPos = arrToCf(placeEv.CFrame).Position
                local unitRoot = Workspace:FindFirstChild("Unit")
                local ownFolder = unitRoot and unitRoot:FindFirstChild(LocalPlayer.Name)
                if not ownFolder then return nil end
                local best, bestDist = nil, 16 -- within 4 studs
                for _, m in ipairs(ownFolder:GetChildren()) do
                    if m:IsA("Model") and m.PrimaryPart then
                        local d = (m.PrimaryPart.Position - targetPos).Magnitude
                        if d < bestDist then
                            bestDist = d
                            best = m
                        end
                    end
                end
                if best then
                    -- Cache for subsequent events
                    _AR.MacroPlaceIdxToModel[placeIdx] = best
                end
                return best
            end

            for i, ev in ipairs(events) do
                if not _AR.MacroPlaying or not getgenv()._ARRunning then break end

                local target = (ev.t or 0) / speed
                local now = tick() - startT
                if target > now then task.wait(target - now) end
                if not _AR.MacroPlaying or not getgenv()._ARRunning then break end

                local action = ev.Action
                if action == "Place" then
                    local uuid = unitNameToUuid(ev.UnitName)
                    if uuid then
                        playedPlaceCounter = playedPlaceCounter + 1
                        _AR.MacroPlaceCounter = playedPlaceCounter
                        local placeIdx = playedPlaceCounter

                        if _AR.MacroPlaybackMode == "UnitRetry" then
                            -- Retry mode: keep firing until the server ACKs
                            -- placement via CreateUnits2 (MacroPlaceIdxToModel
                            -- gets populated for this placeIdx) or the macro
                            -- is stopped. Throttle retries to avoid flooding.
                            _AR.MacroPendingPlace = _AR.MacroPendingPlace + 1
                            local attempt = 0
                            while _AR.MacroPlaying and getgenv()._ARRunning do
                                attempt = attempt + 1
                                local freshUuid = unitNameToUuid(ev.UnitName) or uuid
                                safe(function()
                                    Remotes.CreateUnits:FireServer(freshUuid, arrToCf(ev.CFrame))
                                end)
                                -- Wait up to 1s for ACK
                                local t0 = tick()
                                while (tick() - t0) < 1.0 do
                                    local m = _AR.MacroPlaceIdxToModel[placeIdx]
                                    if m and m.Parent then break end
                                    task.wait(0.05)
                                end
                                local m = _AR.MacroPlaceIdxToModel[placeIdx]
                                if m and m.Parent then
                                    dbg(("Place OK (idx=%d, unit=%s, tries=%d)"):format(
                                        placeIdx, tostring(ev.UnitName), attempt))
                                    break
                                end
                                if attempt >= 60 then
                                    dbg(("Place GAVE UP after %d tries (idx=%d, unit=%s)"):format(
                                        attempt, placeIdx, tostring(ev.UnitName)))
                                    break
                                end
                                -- Retry delay grows slightly to avoid spam
                                task.wait(0.4 + math.min(attempt * 0.05, 0.8))
                            end
                        else
                            -- Timed mode: fire once, don't wait for ACK
                            _AR.MacroPendingPlace = _AR.MacroPendingPlace + 1
                            safe(function()
                                Remotes.CreateUnits:FireServer(uuid, arrToCf(ev.CFrame))
                            end)
                        end
                    else
                        dbg("Macro: unit '" .. tostring(ev.UnitName) .. "' not in team — skipping placement")
                    end

                elseif action == "Upgrade" then
                    local model = resolveModelByPlaceIdx(ev.PlaceIdx)
                    if not model or not model.Parent then
                        -- Wait briefly for ack
                        local t0 = tick()
                        while (tick() - t0) < 1.5 do
                            model = resolveModelByPlaceIdx(ev.PlaceIdx)
                            if model and model.Parent then break end
                            task.wait(0.05)
                        end
                    end
                    if model and model.Parent then
                        safe(function()
                            if ev.StateNum then
                                Remotes.Upgrades:FireServer(model, ev.StateNum)
                            else
                                Remotes.Upgrades:FireServer(model)
                            end
                        end)
                    end

                elseif action == "Sell" then
                    local model = resolveModelByPlaceIdx(ev.PlaceIdx)
                    if model and model.Parent then
                        local stats = model:FindFirstChild("Stats")
                        local urp = stats and stats:GetAttribute("UnitRealPlace")
                        if urp then
                            safe(function() Remotes.SellUnit:FireServer(model.Name, urp) end)
                        end
                    end

                elseif action == "Order" then
                    local model = resolveModelByPlaceIdx(ev.PlaceIdx)
                    if model and model.Parent then
                        safe(function() Remotes.ChangeOrder:FireServer(model) end)
                    end

                elseif action == "ActiveSkill" then
                    local model = resolveModelByPlaceIdx(ev.PlaceIdx)
                    if model and model.Parent then
                        -- ActiveSkill uses UnitRealPlace (not model) per decompile
                        local stats = model:FindFirstChild("Stats")
                        local urp = stats and stats:GetAttribute("UnitRealPlace")
                        if urp then
                            safe(function()
                                Remotes.ActiveSkill:FireServer(urp, ev.UnitName)
                            end)
                        end
                    end

                elseif action == "SkipWave" then
                    safe(function() Remotes.SkipWave:FireServer(ev.Vote or "Yes") end)

                elseif action == "UseItem" then
                    safe(function() Remotes.UseItem:FireServer(ev.Item, ev.Amount or 1) end)
                end
            end

            _AR.MacroPlaying = false
            if _AR._refreshHookActive then _AR._refreshHookActive() end
            dbg("Macro finished")
        end)
    end

    function _AR._stopMacro()
        _AR.MacroPlaying = false
        if _AR._refreshHookActive then _AR._refreshHookActive() end
    end

