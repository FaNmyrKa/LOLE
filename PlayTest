    }
    -- Ragnarok has a sub-key; data.Shop
    table.insert(shopDefs, {
        key    = "RagnarokEvent",
        label  = "Ragnarok Shop",
        data   = (type(RagnarokData) == "table" and RagnarokData.Shop) or {},
        remote = Remotes.RagnarokEvent.Buy,
    })

    local sideToggle = "ShopsL"
    local side = sec.ShopsL

    -- Buy one shop item. If stock data is available (data.<shop>.Stock[item]),
    -- buy the full remaining stock in a single FireServer call. If stock is
    -- unknown (unlimited item / fresh data / missing field), fall back to
    -- buying 1 so unlimited items still work.
    local function buyShopItem(shop, item)
        local qty = shopStockRemaining(shop.key, item)
        if qty == nil then
            safe(function() shop.remote:FireServer(item, 1) end)
            dbg(("[shop] %s: buying %s × 1 (stock unknown)"):format(shop.label, item))
            return 1
        end
        if qty <= 0 then
            dbg(("[shop] %s: %s sold out"):format(shop.label, item))
            return 0
        end
        safe(function() shop.remote:FireServer(item, qty) end)
        dbg(("[shop] %s: buying %s × %d"):format(shop.label, item, qty))
        return qty
    end

    for i, shop in ipairs(shopDefs) do
        if i > 3 then side = sec.ShopsR end
        side:Header({ Text = shop.label })

        local opts = {}
        for name in pairs(shop.data) do table.insert(opts, name) end
        table.sort(opts)
        if #opts == 0 then opts = { "None" } end

        _AR.AutoShopItems[shop.key] = {}
        side:Dropdown({
            Name = "Items to buy",
            Multi = true,
            Options = opts,
            Default = {},
            Callback = function(selected)
                _AR.AutoShopItems[shop.key] = {}
                for n, on in pairs(selected) do
                    if on then _AR.AutoShopItems[shop.key][n] = true end
                end
            end,
        }, "Shop_" .. shop.key .. "_Items")

        side:Toggle({
            Name = "Auto Buy — " .. shop.label,
            Default = false,
            Callback = function(v)
                _AR.AutoShopEnabled[shop.key] = v
                if v then
                    local count = 0
                    for _, on in pairs(_AR.AutoShopItems[shop.key] or {}) do
                        if on then count = count + 1 end
                    end
                    if count == 0 then
                        Notify("Select items first ↑", 3)
                    else
                        Notify(shop.label .. ": auto-buy ON (" .. count .. " items)", 2)
                    end
                end
            end,
        }, "Shop_" .. shop.key .. "_Toggle")

        side:Divider()
    end

    -- Shared auto-buy loop: every 8s, for each enabled shop, fire buy
    -- per selected item (using remaining stock if available, else single).
    task.spawn(function()
        while getgenv()._ARRunning do
            task.wait(8)
            for _, shop in ipairs(shopDefs) do
                if _AR.AutoShopEnabled[shop.key] and _AR.ModulesLoaded then
                    for item, on in pairs(_AR.AutoShopItems[shop.key] or {}) do
                        if on then
                            buyShopItem(shop, item)
                            task.wait(0.25)
                        end
                    end
                end
            end
        end
    end)
end)
