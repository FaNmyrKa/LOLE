            Notify(v and "Place Anywhere ON" or "Place Anywhere OFF", 2)
        end,
    }, "PlaceAnywhere")

    -- Diagnostic: force-place RIGHT NOW at mouse position, without waiting
    -- for LMB or the game to fire. Use when normal click path doesn't work,
    -- to isolate the cause (ghost-detection vs LMB listener vs hook bypass).
    sec.MiscR:Button({
        Name = "🧪 Force Place at Mouse Now",
        Callback = function()
            local ghost = findHoldingGhost()
            if not ghost then
                Notify("No ghost in workspace — grab a unit first", 4)
                return
            end
            local uuid = ghost:GetAttribute("UnitRealName")
            if not uuid or uuid == "" then
                Notify("Ghost has no UnitRealName attribute", 4)
                return
            end
            local cf = paMouseCF()
            if not cf then Notify("No raycast hit", 3) return end
            local remote = Remotes:FindFirstChild("CreateUnits")
            if not remote then
                Notify("CreateUnits not available (lobby?)", 3)
                return
            end
            safe(function() remote:FireServer(uuid, cf) end)
            Notify(("Fired CreateUnits(%s) at mouse"):format(uuid:sub(1, 12)), 3)
        end,
    })

    -- Resolve CreateUnits remote once (may be absent on lobby)
    local createUnitsRemote = Remotes:FindFirstChild("CreateUnits")

    -- LMB listener: toggle ON + holding ghost + game didn't fire within
    -- 80ms → force-fire ourselves. In valid zones the game fires its own
    -- CreateUnits (hook already overrides CF), bumping _ARLastCreateUnitsFire
    -- so we skip force-fire and avoid double placement.
    --
    -- NB: we intentionally do NOT check `processed` — when you hold a ghost
    -- and click a team slot button, processed=true but that's not a world
    -- click. Instead we gate on findHoldingGhost() which only returns
    -- something when a ghost is in flight.
    local paInputConn = UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        if not _AR.PlaceAnywhereEnabled then return end

        local ghost = findHoldingGhost()
        if not ghost then return end
        local uuid = ghost:GetAttribute("UnitRealName")
        if not uuid or uuid == "" then
            dbg("[PA] ghost has no UnitRealName attribute")
            return
        end

        dbg(("[PA] click detected, ghost uuid=%s, waiting for game fire..."):format(uuid))

        task.delay(0.08, function()
            if not getgenv()._ARRunning then return end
            if not _AR.PlaceAnywhereEnabled then return end
            local last = getgenv()._ARLastCreateUnitsFire or 0
            local sinceFire = tick() - last
            if sinceFire > 0.1 then
                -- Game didn't fire — invalid zone. Force-fire ourselves.
                local cf = paMouseCF()
                if not cf then
                    dbg("[PA] no raycast hit, skipping")
                    return
                end
                if not createUnitsRemote then
                    dbg("[PA] CreateUnits remote not found (lobby server?)")
                    return
                end
                dbg(("[PA] force-firing CreateUnits for %s"):format(uuid))
                safe(function() createUnitsRemote:FireServer(uuid, cf) end)
            else
                dbg(("[PA] game already fired %.3fs ago, skip"):format(sinceFire))
            end
        end)
    end)
    table.insert(_cleanupConns, paInputConn)
end)
