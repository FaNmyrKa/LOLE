        local batch = {}
        local scanned, unknownRarity = 0, 0
        for uuid, info in pairs(data.Unit) do
            scanned = scanned + 1
            local hero = heroNameOf(info)
            if hero then
                local cfg = nil
                pcall(function() cfg = UnitModule:GetUnitDatabase(hero) end)
                local rarity = cfg and cfg.Rarity
                if not rarity then
                    unknownRarity = unknownRarity + 1
                else
                    local ok = _AR.AutoSellRarities[rarity] == true
                    if ok and _AR.AutoSellKeepShiny     and info.Shiny  == true then ok = false end
                    if ok and _AR.AutoSellKeepLocked    and info.Lock   == true then ok = false end
                    if ok and _AR.AutoSellKeepEquipped  and equippedLookup[uuid]  then ok = false end
                    if ok then table.insert(batch, uuid) end
                end
            end
        end
        dbg(("[sell] scanned=%d unknown_rarity=%d selected=%d"):format(
            scanned, unknownRarity, #batch))
        return batch
    end

