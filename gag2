serverHopVisited = {}   -- JobIds already tried this session (best-effort; in-memory)
-- fetch public servers via CURSOR PAGINATION (up to maxPages*100) for a much wider hop pool than one page
function fetchPublicServers(maxPages)
    local out = {}
    local cursor, pages = "", 0
    repeat
        local ok, res = pcall(function()
            local url = "https://games.roblox.com/v1/games/" .. game.PlaceId
                .. "/servers/Public?sortOrder=Asc&limit=100" .. (cursor ~= "" and ("&cursor=" .. cursor) or "")
            return HttpService:JSONDecode(game:HttpGet(url))
        end)
        if not (ok and type(res) == "table" and type(res.data) == "table") then break end
        for _, s in ipairs(res.data) do out[#out + 1] = s end
        cursor = res.nextPageCursor or ""
        pages = pages + 1
    until cursor == "" or pages >= (maxPages or 5)
    return out
end
-- hop to another public instance. lowPop=true picks the emptiest joinable server; else a RANDOM
-- joinable one. Skips the current + already-visited servers so a hunt samples widely, not in circles.
function serverHop(lowPop)
    queueHubReload()  -- persist the hub across the hop if the executor supports it
    local TPS = game:GetService("TeleportService")
    serverHopVisited[game.JobId] = true
    local servers = fetchPublicServers(5)
    local candidates, lowest = {}, nil
    for _, s in ipairs(servers) do
        if s.id ~= game.JobId and not serverHopVisited[s.id] and s.playing and s.maxPlayers and s.playing < s.maxPlayers then
            candidates[#candidates + 1] = s
            if not lowest or s.playing < lowest.playing then lowest = s end
        end
    end
    local pick
    if lowPop then pick = lowest
    elseif #candidates > 0 then pick = candidates[math.random(1, #candidates)] end
    if pick then
        serverHopVisited[pick.id] = true
        pcall(function() TPS:TeleportToPlaceInstance(game.PlaceId, pick.id, LocalPlayer) end)
        return true
    end
    -- nothing new -> clear the visited set and fall back to a fresh same-place instance
    serverHopVisited = { [game.JobId] = true }
    pcall(function() TPS:Teleport(game.PlaceId, LocalPlayer) end)
    return false
end

