-- Send configured items to recipients (chunks <=20 / batch, >=1.6s apart, overflow on rejection).
-- Items may carry a per-item recipient override (To = "user" or {"u1","u2"}); those route to their
-- own recipient(s). Items with no To go to the global list (mailSendUsernames, else mailSendUsername).
-- Item value forms in a category map:
--   number                          -> Count = number
--   {Amount = N, To = ...}           -> Count = N, optional recipient override
--   {Normal=1, Big=1, Huge=1, To=...} -> per-variant counts SUMMED into one Count (best-effort: the
--        mail tuple has no variant slot, so true per-variant routing needs verified pet-UUID resolution)
function doMailSend()
    if not MailSendBatch then return false, "no remote" end
    local globalRecips = {}
    if #mailSendUsernames > 0 then
        for _, u in ipairs(mailSendUsernames) do if tostring(u) ~= "" then globalRecips[#globalRecips + 1] = tostring(u) end end
    elseif mailSendUsername ~= "" then globalRecips[1] = mailSendUsername end

    local uuidCats = { Pets = true, HarvestedFruits = true }
    local catAlias = { Pet = "Pets", Seed = "Seeds", Fruit = "HarvestedFruits", HarvestedFruit = "HarvestedFruits", Sprinkler = "Sprinklers", WateringCan = "WateringCans" }
    local note = mailSendNote ~= "" and mailSendNote or nil

    -- groups: { {recips={names}, items={{Category,ItemKey,Count},...}}, ... }; globalItems share globalRecips
    local groups, globalItems = {}, {}
    local function toList(to)
        if type(to) == "table" then local t = {} for _, x in ipairs(to) do if tostring(x) ~= "" then t[#t + 1] = tostring(x) end end return (#t > 0) and t or nil end
        if type(to) == "string" and to ~= "" then return { to } end
        return nil
    end
    local function pushItem(category, key, count, to)
        local item = { Category = category, ItemKey = key, Count = math.max(1, math.floor(count or 1)) }
        local recips = toList(to)
        if recips then groups[#groups + 1] = { recips = recips, items = { item } }
        else globalItems[#globalItems + 1] = item end
    end
    -- value -> (count, To); handles number / {Amount,To} / per-variant sub-count maps
    local function resolveVal(raw, fallback)
        if type(raw) == "number" then return raw, nil end
        if type(raw) == "table" then
            local amt = tonumber(raw.Amount)
            if not amt then
                local s = 0; for k, v in pairs(raw) do if k ~= "To" and k ~= "Amount" then s = s + (tonumber(v) or 0) end end
                if s > 0 then amt = s end
            end
            return (amt or fallback or 1), raw.To
        end
        return fallback or 1, nil
    end
    local function addItems(category, spec)
        if type(spec) ~= "table" then return end
        category = catAlias[category] or category  -- accept competitor-style singular Pet/Seed/Gear
        local isMap = false
        for k in pairs(spec) do if type(k) == "string" then isMap = true break end end
        if isMap then
            for key, raw in pairs(spec) do
                local c, to = resolveVal(raw, mailSendCount)
                local cat = VALID_GIFT_CAT[category] and category or (itemCategoryOf(key) or category)
                pushItem(cat, key, c, to)        -- maps key by NAME (server resolves N of that name, incl. pets)
            end
        else
            for _, key in ipairs(spec) do
                local c = uuidCats[category] and 1 or (tonumber(mailItemCounts[key]) or mailSendCount)
                local cat = VALID_GIFT_CAT[category] and category or (itemCategoryOf(key) or category)
                pushItem(cat, key, c, nil)       -- arrays carry UUIDs (UI path) -> one per UUID for pets/fruit
            end
        end
    end
    if next(mailSendByCategory) ~= nil then
        for cat, spec in pairs(mailSendByCategory) do addItems(cat, spec) end
    elseif mailSendCategory and #selectedMailItems > 0 then
        addItems(mailSendCategory, selectedMailItems)
    else
        return false, "no items selected"
    end
    if #globalItems > 0 then
        if #globalRecips == 0 then return false, "no recipient" end
        groups[#groups + 1] = { recips = globalRecips, items = globalItems }
    end
    if #groups == 0 then return false, "no items selected" end

    -- send one group: items a recipient rejects overflow to the next recipient in that group's list
    local totalSent, lastMsg, reachedCount = 0, nil, 0
    local function sendGroup(g)
        local pending = g.items
        for ri, uname in ipairs(g.recips) do
            if #pending == 0 then break end
            local uid = resolveMailUser(uname)
            if not uid and ri == 1 and mailSendUsername == uname then uid = mailSendUserId end
            if uid then
                local before = totalSent
                local stillPending, i = {}, 1
                while i <= #pending do
                    local batch, total = {}, 0
                    while i <= #pending and (total + pending[i].Count) <= 20 do
                        total = total + pending[i].Count; batch[#batch + 1] = pending[i]; i = i + 1
                    end
                    if #batch == 0 then batch[#batch + 1] = pending[i]; i = i + 1 end  -- single item > 20: send as-is
                    local ok, sres, smsg = pcall(function() return MailSendBatch:Fire(uid, batch, note) end)
                    if ok and sres ~= false then totalSent = totalSent + #batch
                    else lastMsg = (smsg and tostring(smsg)) or "server rejected"; for _, it in ipairs(batch) do stillPending[#stillPending + 1] = it end end
                    task.wait(1.6)  -- server rate-limit >= 1.5s
                end
                pending = stillPending
                if totalSent > before then reachedCount = reachedCount + 1 end
            else
                lastMsg = "bad username: " .. uname
            end
        end
        return pending
    end
    local undelivered = 0
    for _, g in ipairs(groups) do undelivered = undelivered + #sendGroup(g) end
    if totalSent == 0 then return false, ("send failed: " .. (lastMsg or "unknown")) end
    local resMsg = string.format("sent %d item-stack(s), %d recipient-pass(es)", totalSent, reachedCount)
    if undelivered > 0 then resMsg = resMsg .. string.format(" (%d undelivered: %s)", undelivered, lastMsg or "?") end
    return true, resMsg
end

