-- smoothly fly the character to a world position (replaces every teleport in the hub).
-- Holds noclip on RunService.Stepped (which fires BEFORE the physics step) the whole flight, because
-- the Humanoid re-enables CanCollide every step -- a one-time noclip lets it bump walls mid-flight.
function flyTo(pos, speed)
    local hrp = hrpNow(); if not (hrp and pos) then return false end
    local hum = humanoid()
    -- default to the player's REAL in-game speed (WalkSpeed incl. pet/mushroom buffs); a non-zero
    -- flyMoveSpeed (slider/config) forces a fixed cap instead.
    local base = (flyMoveSpeed and flyMoveSpeed > 0) and flyMoveSpeed or moveSpeed()
    speed = math.max(12, tonumber(speed) or base)
    local target = pos + Vector3.new(0, 3, 0)
    if (hrp.Position - target).Magnitude < 2.5 then return true end
    local char0 = LocalPlayer.Character  -- to detect a respawn mid-flight (don't restore stale parts)
    local parts = charParts()
    local saved = {}; for _, p in ipairs(parts) do saved[p] = p.CanCollide end  -- restore exact states after
    local nclip = RunService.Stepped:Connect(function()
        for _, p in ipairs(parts) do if p and p.CanCollide then p.CanCollide = false end end
    end)
    if hum then pcall(function() hum.PlatformStand = true end) end  -- so the Humanoid doesn't fight the velocity
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1, 1, 1) * 1e6; bv.P = 2e4; bv.Velocity = Vector3.zero; bv.Parent = hrp
    local maxT = (hrp.Position - target).Magnitude / speed + 3  -- safety timeout (never spin forever)
    local t0 = os.clock()
    while not stopped and os.clock() - t0 < maxT do
        local delta = target - hrp.Position
        local d = delta.Magnitude
        if d < 3 then break end
        bv.Velocity = delta.Unit * math.min(speed, d * 4)  -- ease in near the target so we don't overshoot
        RunService.Heartbeat:Wait()
    end
    pcall(function() nclip:Disconnect() end)
    pcall(function() bv:Destroy() end)
    if hum then pcall(function() hum.PlatformStand = false end) end
    -- only restore if we did NOT respawn mid-flight; a stale snapshot could otherwise leave the new
    -- character permanently non-colliding (falling through the world). New char self-manages collision.
    if char0 == LocalPlayer.Character then
        for p, v in pairs(saved) do if p and p.Parent then pcall(function() p.CanCollide = v end) end end
    end
    return true
end
-- fly to a position, run fn there, then fly back to where we started (no teleports anywhere)
function atPosition(pos, fn)
    local hrp = hrpNow(); if not hrp then return false end
    local saved = hrp.Position
    flyTo(pos)
    task.wait(0.15)
    local ok = pcall(fn)
    task.wait(0.1)
    flyTo(saved)
    return ok
end

