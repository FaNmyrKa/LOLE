centerDist  = 30      -- only re-center if we've drifted more than this many studs from the garden center
-- the player's live in-game movement speed: WalkSpeed (raised by pets / speed mushrooms), with the
-- walk-speed floor as a fallback. flight uses this by default so we never out-run legit movement.
function moveSpeed()
