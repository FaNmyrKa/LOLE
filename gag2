-- // ---- SMART AUTO-FARM (ROI economy brain) ---- //
-- ROI = estimated fruit value / seed cost. fruitValueCalc(seedName,1,nil,LocalPlayer,0) approximates
-- value (assumes harvested fruit name == seed name); unknown -> 0 (ranked last). Guarded like stealValue.
function seedROIScore(name)
    local cost = seedPrice(name); if not cost or cost <= 0 then cost = 1 end
    local calc = fruitValueCalc(); local val = 0
    if calc then local ok, v = pcall(calc, name, 1, nil, LocalPlayer, 0); if ok and type(v) == "number" then val = v end end
    return val / cost
end
function bestInStockSeeds()
    local out = {}
    local ok, items = pcall(function() return ReplicatedStorage.StockValues.SeedShop.Items end)
    if not (ok and items) then return out end
    for _, sv in ipairs(items:GetChildren()) do
        if sv:IsA("ValueBase") and tonumber(sv.Value) and sv.Value > 0 and not inSet(plantBlacklist, sv.Name) then
            out[#out + 1] = { name = sv.Name, score = seedROIScore(sv.Name) }
        end
    end
    table.sort(out, function(a, b) return a.score > b.score end)
    return out
end
function ownedPlantableSeeds()
    local list = {}
    for name, c in pairs(invNames("Seeds")) do
        if (c or 0) > 0 and not inSet(plantBlacklist, name) then list[#list + 1] = name end
    end
    table.sort(list, function(a, b) return seedROIScore(a) > seedROIScore(b) end)
    return list
end
function smartBuyBest()
    local bought = 0
    for _, e in ipairs(bestInStockSeeds()) do
        if bought >= smartBuyPerCycle then break end
        if e.score >= (smartMinROI or 0) then
            local price = seedPrice(e.name)
            while bought < smartBuyPerCycle do
                if not smartFarmEnabled then break end
                if price > 0 and (getSheckles() - (smartBudgetReserve or 0)) < price then break end
                local stock = stockOf("SeedShop", e.name)
                if stock ~= nil and stock <= 0 then break end
                if not pcall(function() PurchaseSeed:Fire(e.name) end) then break end
                bought = bought + 1; task.wait(0.12)
            end
        end
    end
    return bought
end
