-- plant a list of seed names across free grid cells (verified placement; rejected cells skipped).
-- Shared by AutoPlant (user-selected) and Smart-Farm (owned, ROI-sorted). Returns planted count.
function plantSeedsList(seedList)
    if not seedList or #seedList == 0 then return 0 end
    local spacing = tightPackEnabled and 1 or plantSpacing  -- tight pack = densest grid (server-rejects are skipped)
    local grid = plantGrid(spacing)
    if #grid == 0 then return 0 end
    local plot = myPlot()
    local plantsFolder = plot and plot:FindFirstChild("Plants")
    local occupied = existingPlantPositions()
    local function isClear(pos)
        for _, op in ipairs(occupied) do
            if (Vector2.new(pos.X, pos.Z) - Vector2.new(op.X, op.Z)).Magnitude < 1 then return false end
        end
        return true
    end
    local free = {}
    for _, p in ipairs(grid) do if isClear(p) then free[#free + 1] = p end end
    local plantSeedCount = {}  -- LOCAL (reentrancy-safe): AutoPlant/SmartFarm/tutorial can overlap; a shared tally would corrupt caps
    local fi, planted, attempts = 1, 0, 0
    local attemptCap = (maxAutoPlant > 0 and maxAutoPlant) or 120  -- bound per-pass; rest fills next pass
    for _, name in ipairs(seedList) do
        if fi > #free or attempts >= attemptCap then break end
        if maxAutoPlant > 0 and planted >= maxAutoPlant then break end
        if not inSet(plantBlacklist, name) then
            local plantLim = tonumber(plantSeedLimits[name])
            local seedCap = (plantLim and plantLim > 0) and plantLim or nil  -- nil/0 = unlimited
            local held = equipSeedTool(name) or seedToolFor(name)  -- equipped tool, or unequipped backpack tool
            if held then
                local seedArg = held:GetAttribute("SeedTool") or name  -- client parity: fire the tool's real SeedTool value
                while fi <= #free and attempts < attemptCap do
                    if maxAutoPlant > 0 and planted >= maxAutoPlant then break end
                    if seedCap and (plantSeedCount[name] or 0) >= seedCap then break end
                    held = heldToolByAttr("SeedTool") or seedToolFor(name)
                    if not held then break end
                    seedArg = held:GetAttribute("SeedTool") or name
                    local pos = free[fi]; fi = fi + 1; attempts = attempts + 1
                    local before = plantsFolder and #plantsFolder:GetChildren() or nil
                    pcall(function() PlantSeed:Fire(pos, seedArg, held) end)
                    task.wait(0.16)
                    local landed = (before == nil) or (#plantsFolder:GetChildren() > before)  -- skip server-rejected cells
                    if landed then
                        plantSeedCount[name] = (plantSeedCount[name] or 0) + 1
                        planted = planted + 1
                    end
                end
            end
        end
    end
    return planted
end

