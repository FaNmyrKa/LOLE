-- Compatibility shim: ingest a competitor-style getgenv().UserConfig (flat, space-separated keys)
-- and translate it into our nested ApelHubConfig schema, then apply it. Lets a customer paste the
-- UserConfig from the other (Luarmor) hub and have it Just Work here. Unknown keys are ignored.
function applyUserConfig()
    local U = (getgenv and getgenv().UserConfig) or (_G and _G.UserConfig)
    if type(U) ~= "table" then return end
    local function arr(v) return (type(v) == "table") and v or {} end
    local function keysOf(t) local o = {} for k in pairs(arr(t)) do o[#o + 1] = k end return o end
    local C = { AutoFarm = {}, Pets = {}, Mail = {}, Sell = {}, Map = {}, Webhook = {}, Fps = {}, Wipe = {}, Misc = {}, Steal = {}, Harvest = {}, Open = {}, Hop = {} }
    local f = C.AutoFarm

    if U["FPS Cap"] ~= nil then C.Fps.Cap = tonumber(U["FPS Cap"]) end

    -- buy seeds: their "Limit Buy Seed" keys double as the buy list (our applier doesn't derive that)
    if U["Auto Buy Seed"] then
        local lim = arr(U["Limit Buy Seed"]); local names = keysOf(lim)
        f.BuySeeds = (#names > 0) and names or "All"
        if next(lim) then f.LimitBuySeed = lim end
    elseif U["Limit Buy Seed"] then
        f.LimitBuySeed = arr(U["Limit Buy Seed"]); f.BuySeeds = keysOf(U["Limit Buy Seed"])
    end

    -- plant
    if U["Auto Plant Seed"] ~= nil then f.Plant = U["Auto Plant Seed"] end
    if U["Auto Plant"] ~= nil then f.Plant = U["Auto Plant"] end
    if U["Limit Plant Seed"] ~= nil then
        f.LimitPlantSeed = arr(U["Limit Plant Seed"]); f.PlantSeeds = keysOf(U["Limit Plant Seed"])
    end
    if U["Limit Auto Plant"] ~= nil then f.LimitAutoPlant = tonumber(U["Limit Auto Plant"]) end
    if U["Blacklist Seed"] ~= nil then f.BlacklistSeeds = arr(U["Blacklist Seed"]) end
    if U["Tight Pack"] ~= nil then f.TightPack = U["Tight Pack"] end
    if U["Smart Auto Farm"] ~= nil then f.Smart = U["Smart Auto Farm"] end
    if U["Smart Min ROI"] ~= nil then f.SmartMinROI = tonumber(U["Smart Min ROI"]) end
    if U["Smart Reserve"] ~= nil then f.SmartReserve = tonumber(U["Smart Reserve"]) end
    if U["Smart Cleanup"] ~= nil then f.SmartCleanup = U["Smart Cleanup"] end
    if U["Smart Cleanup Seeds"] ~= nil then f.SmartCleanupSeeds = arr(U["Smart Cleanup Seeds"]) end
    if U["Max Density"] ~= nil then f.TightPack = U["Max Density"] end

    -- harvest (сбор) + sell (продажа) - accept a few common key spellings
    if U["Auto Harvest"] ~= nil then f.Harvest = U["Auto Harvest"] end
    if U["Auto Collect"] ~= nil then f.Harvest = U["Auto Collect"] end
    if U["Auto Collect Fruits"] ~= nil then f.Harvest = U["Auto Collect Fruits"] end
    if U["Auto Sell"] ~= nil then f.Sell = U["Auto Sell"] end
    if U["Auto Farm"] ~= nil then f.Harvest = U["Auto Farm"]; f.Sell = U["Auto Farm"] end  -- combined farm+sell

    -- plot expansion + gears
    if U["Expand Plot"] ~= nil then f.Expand = U["Expand Plot"] end
    if U["Plot Expansions"] ~= nil then f.PlotExpansions = tonumber(U["Plot Expansions"]) end
    if type(U["Gears"]) == "table" then
        if U["Gears"]["Buy Gear"] ~= nil then f.BuyGears = arr(U["Gears"]["Buy Gear"]) end
        if U["Gears"]["Gears To Use"] ~= nil then f.GearsToUse = arr(U["Gears"]["Gears To Use"]) end
    end

    if U["Auto Collect Seed Packs"] ~= nil then C.Map.CollectSeedPacks = U["Auto Collect Seed Packs"] end

    -- pets (per-variant caps now honored by petTameDecision)
    if U["Buy Pets"] ~= nil then C.Pets.BuyPets = U["Buy Pets"] end
    if U["Equip Pets"] ~= nil then C.Pets.EquipLoadout = U["Equip Pets"] end
    if U["Unlock Pet Slots"] ~= nil then C.Pets.UnlockPetSlots = U["Unlock Pet Slots"] end

    -- favorite-protect (keep these from being sold) + shovel blacklist
    if U["Favorite"] ~= nil then C.Sell.FavoriteFilter = true; C.Sell.FavoriteByFruit = U["Favorite"] end
    if U["Blacklist Shovel"] ~= nil then C.Wipe.Blacklist = arr(U["Blacklist Shovel"]) end

    -- mail
    local m = C.Mail
    if U["Claim Mail"] ~= nil then m.AutoClaim = U["Claim Mail"] end
    if U["Auto Claim Mail"] ~= nil then m.AutoClaim = U["Auto Claim Mail"] end
    if U["Auto Send Mail"] ~= nil then m.AutoSend = U["Auto Send Mail"] end
    if U["Mail To Username"] ~= nil then m.Usernames = arr(U["Mail To Username"]) end
    if U["Items To Mail"] ~= nil then m.ItemsByCategory = U["Items To Mail"] end

    -- webhook (listing pet names/rarities / seed mutations implies wanting those notifications)
    local w = C.Webhook
    if U["Webhook URL"] ~= nil then w.URL = U["Webhook URL"] end
    if U["Webhook Pet Name"] ~= nil then w.TamePetNames = arr(U["Webhook Pet Name"]); w.TameNotify = true end
    if U["Webhook Pet Rarity"] ~= nil then w.TameRarities = arr(U["Webhook Pet Rarity"]); w.TameNotify = true end
    if U["Webhook Seed Name"] ~= nil then w.SeedNames = arr(U["Webhook Seed Name"]); w.MutationNotify = true end
    if U["Webhook Note"] ~= nil then w.Note = U["Webhook Note"] end
    if U["Discord ID"] ~= nil then w.DiscordId = U["Discord ID"] end

    -- black status panel (dark info screen) + roll UI
    if U["Status Overlay"] ~= nil then C.Misc.StatusOverlay = U["Status Overlay"] end
    if U["Auto Tutorial"] ~= nil then C.Misc.AutoTutorial = U["Auto Tutorial"] end
    if U["Black Panel"] ~= nil then C.Misc.StatusOverlay = U["Black Panel"] end
    if U["Dark Screen"] ~= nil then C.Misc.StatusOverlay = U["Dark Screen"] end
    if U["Remove Roll UI"] ~= nil then C.Misc.RemoveRollUi = U["Remove Roll UI"] end

    -- fps boost
    if U["FPS Boost"] ~= nil then C.Fps.Boost = U["FPS Boost"] end
    if U["Boost FPS"] ~= nil then C.Fps.Boost = U["Boost FPS"] end
    if U["FPS Max"] ~= nil then C.Fps.Max = U["FPS Max"] end
    if U["Max FPS Boost"] ~= nil then C.Fps.Max = U["Max FPS Boost"] end
    if U["Disable 3D Render"] ~= nil then C.Fps.No3d = U["Disable 3D Render"] end
    if U["Mute Audio"] ~= nil then C.Fps.Mute = U["Mute Audio"] end
    if U["FPS Burst"] ~= nil then C.Fps.Burst = U["FPS Burst"] end
    if U["Burst FPS Cap"] ~= nil then C.Fps.BurstCap = tonumber(U["Burst FPS Cap"]) end
    if U["Idle FPS Cap"] ~= nil then C.Fps.IdleCap = tonumber(U["Idle FPS Cap"]) end

    -- newly-exposed feature groups (flat keys -> nested C, ride through applyGConfig)
    if U["Auto Skill"] ~= nil then f.Skill = U["Auto Skill"] end
    if U["Skills"] ~= nil then f.Skills = arr(U["Skills"]) end
    if U["Auto Buy Crates"] ~= nil then f.BuyCrates = U["Auto Buy Crates"] end
    if U["Buy Crates"] ~= nil then f.Crates = arr(U["Buy Crates"]) end
    if U["Plant Spacing"] ~= nil then f.PlantSpacing = tonumber(U["Plant Spacing"]) end
    if U["Sell Interval"] ~= nil then f.SellInterval = tonumber(U["Sell Interval"]) end
    if U["Harvest Interval"] ~= nil then f.HarvestInterval = tonumber(U["Harvest Interval"]) end
    if U["Auto Daily"] ~= nil then f.Daily = U["Auto Daily"] end
    if U["Auto Sprinkler"] ~= nil then f.Sprinkler = U["Auto Sprinkler"] end
    if U["Auto Water"] ~= nil then f.Water = U["Auto Water"] end
    if U["Auto Sell Pets"] ~= nil then C.Pets.AutoSell = U["Auto Sell Pets"] end
    if U["Sell Pets"] ~= nil then C.Pets.SellNames = arr(U["Sell Pets"]) end
    if U["Auto Buy Pets"] ~= nil then C.Pets.AutoBuy = U["Auto Buy Pets"] end
    if U["Equip Pets Toggle"] ~= nil then C.Pets.Equip = U["Equip Pets Toggle"] end
    if U["Auto Collect Seeds"] ~= nil then C.Map.CollectSeeds = U["Auto Collect Seeds"] end
    if U["Auto Collect Acorns"] ~= nil then C.Map.CollectAcorns = U["Auto Collect Acorns"] end
    if U["Seed Pack Types"] ~= nil then C.Map.SeedPackTypes = arr(U["Seed Pack Types"]) end
    if U["Auto Steal"] ~= nil then C.Steal.Auto = U["Auto Steal"] end
    if U["Steal Most Expensive"] ~= nil then C.Steal.MostExpensive = U["Steal Most Expensive"] end
    if U["Steal Return Home"] ~= nil then C.Steal.ReturnHome = U["Steal Return Home"] end
    if U["Field Guard"] ~= nil then C.Guard = U["Field Guard"] end
    if U["Auto Open Eggs"] ~= nil then C.Open.Eggs = U["Auto Open Eggs"] end
    if U["Auto Open Crates"] ~= nil then C.Open.Crates = U["Auto Open Crates"] end
    if U["Auto Open Packs"] ~= nil then C.Open.Packs = U["Auto Open Packs"] end
    if U["Auto Hop"] ~= nil then C.Hop.Auto = U["Auto Hop"] end
    if U["Hop Seeds"] ~= nil then C.Hop.Seeds = arr(U["Hop Seeds"]) end
    if U["Hop Min Price"] ~= nil then C.Hop.MinPrice = tonumber(U["Hop Min Price"]) end
    if U["Walk Speed"] ~= nil then C.Misc.WalkSpeed = tonumber(U["Walk Speed"]) end
    if U["Fly Speed"] ~= nil then C.Misc.FlySpeed = tonumber(U["Fly Speed"]) end
    if U["Stay Centered"] ~= nil then C.Misc.StayCentered = U["Stay Centered"] end
    if U["Harvest Ignore Mutations"] ~= nil then C.Harvest.IgnoreMutations = arr(U["Harvest Ignore Mutations"]) end
    if U["Harvest Ignore Types"] ~= nil then C.Harvest.IgnoreTypes = arr(U["Harvest Ignore Types"]) end
    if U["Harvest Min Weight"] ~= nil then C.Harvest.MinWeight = tonumber(U["Harvest Min Weight"]) end

    applyGConfig(C, true)
    pcall(function() Window:Notify({ Title = "Apel Hub", Description = "UserConfig (compat) applied.", Lifetime = 4 }) end)
end

