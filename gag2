-- FPS-burst: raise the setfpscap only while an action loop is firing (frame-bound CollectFruit/steal
-- land ~1 per frame, so a higher cap = faster), then drop back to the idle cap. Ref-counted so two
-- loops bursting at once don't fight; a manual FPS Cap (if set) is respected as the floor.
local function fpsSetCap(v)
    local f = (getgenv and getgenv().setfpscap) or setfpscap
    if type(f) == "function" then pcall(f, (v and v > 0) and v or 999) end
end
function fpsBurstBegin()
    if not fpsBurstEnabled then return end
    fpsBurstDepth = fpsBurstDepth + 1
    if fpsBurstDepth == 1 then fpsSetCap(math.max(tonumber(fpsBurstCap) or 120, (fpsCap and fpsCap > 0) and fpsCap or 0)) end
end
function fpsBurstEnd()
    if fpsBurstDepth <= 0 then return end
    fpsBurstDepth = fpsBurstDepth - 1
    if fpsBurstDepth == 0 then fpsSetCap((fpsCap and fpsCap > 0) and fpsCap or (tonumber(fpsIdleCap) or 0)) end
end

