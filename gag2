-- A wild pet's "variant" lives in TWO attributes on the WildPetRef Part (VERIFIED in the decompile —
-- setupVisual reads p:GetAttribute("PetSize")/("PetType"), GetScale uses Big/HugeScale, and the game
-- tags "PetRainbow" when PetType=="Rainbow"):
--   PetSize = "Normal" | "Big" | "Huge"     (size tier)
--   PetType = "Normal" | "Rainbow" | ...     (type/mutation)
-- A requested token is matched against the RIGHT attribute (Big/Huge->size, Rainbow/Golden->type,
-- Normal->both must be Normal). This is what makes the per-variant "Buy Pets" filter actually work;
-- the old code probed the wrong attribute names so it never matched -> it tamed everything incl. Normal.
local PET_SIZE_TOKENS = { big = true, huge = true }
local PET_TYPE_TOKENS = { rainbow = true, golden = true, gold = true, shiny = true }
function petVariantMatches(token, size, ptype)
    token = tostring(token):lower()
    size  = tostring(size  or "Normal"):lower()
    ptype = tostring(ptype or "Normal"):lower()
    if token == "normal" then return size == "normal" and ptype == "normal" end
    if PET_SIZE_TOKENS[token] then return size == token end
    if PET_TYPE_TOKENS[token] then return ptype == token end
    return size == token or ptype == token  -- unknown token: best-effort match against either attribute
end
function wildPets()
    local out = {}
