end
-- per-name OR per-variant tame decision. petBuyCaps[name] can be:
--   number -> cap N of this pet (ANY variant)                       -> (true, "Name", N)
--   table   -> per-variant caps e.g. {Big=99, Huge=99, Rainbow=99}   -> tame ONLY matching variants;
--              a pet whose size/type isn't requested is SKIPPED       -> (true,"Name|Token",N) / (false)
--   nil    -> defer to the name/rarity allow-list (petMatch)
function petTameDecision(w)
    local pname = w.name or ""
    local entry = petBuyCaps[pname]
    if type(entry) == "table" then
        for token, cap in pairs(entry) do
            if petVariantMatches(token, w.size, w.ptype) then
                return true, pname .. "|" .. tostring(token), tonumber(cap) or 0
            end
        end
        return false, pname, 0  -- this pet's size/type wasn't requested -> skip (fixes "Big set but Normal tamed")
    elseif type(entry) == "number" then
        return true, pname, entry
    end
    return petMatch(pname, selectedTamePetNames, selectedTamePetRarities), pname, nil
end
