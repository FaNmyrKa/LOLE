-- tools in Backpack + Character carrying attribute `attr` (optionally matching a name)
function toolsByAttr(attr, wantName)
    local out = {}
    local function scan(c)
        if not c then return end
        for _, t in ipairs(c:GetChildren()) do
            if t:IsA("Tool") and t:GetAttribute(attr) ~= nil then
                if (not wantName) or t:GetAttribute(attr) == wantName or t.Name == wantName then out[#out + 1] = t end
            end
        end
    end
    scan(LocalPlayer:FindFirstChildOfClass("Backpack")); scan(LocalPlayer.Character)
    return out
end
function heldToolByAttr(attr)
    local c = LocalPlayer.Character
    local t = c and c:FindFirstChildWhichIsA("Tool")
    if t and t:GetAttribute(attr) ~= nil then return t end
    return nil
end
-- equip a tool by attribute (and optional name); waits for the equip to land, with a parent fallback
function equipByAttr(attr, wantName)
    local t = heldToolByAttr(attr)
    if t and ((not wantName) or t:GetAttribute(attr) == wantName) then return t end
    t = toolsByAttr(attr, wantName)[1]
    if not t then return nil end
    local hum = humanoid(); if not hum then return nil end
    pcall(function() hum:EquipTool(t) end)
    task.wait(0.22)
    if heldToolByAttr(attr) then return heldToolByAttr(attr) end
    local char = LocalPlayer.Character
    if char then pcall(function() t.Parent = char end); task.wait(0.15) end
    return heldToolByAttr(attr)
end
-- find the seed tool for `name` in Character/Backpack (by SeedTool attr exact/case-insensitive, or Name)
-- WITHOUT equipping. Used as a fallback: the server accepts the tool instance even when unequipped.
function seedToolFor(name)
    local exact, ci
    for _, c in ipairs({ LocalPlayer.Character, LocalPlayer:FindFirstChildOfClass("Backpack") }) do
        if c then for _, t in ipairs(c:GetChildren()) do
            if t:IsA("Tool") and t:GetAttribute("SeedTool") ~= nil then
                local st = t:GetAttribute("SeedTool")
                if st == name or t.Name == name then exact = exact or t
                elseif tostring(st):lower() == tostring(name):lower() then ci = ci or t end
            end
        end end
    end
    return exact or ci
end
-- robustly equip the seed tool for `name` and return the HELD tool (or nil). Matches the tool by its
-- SeedTool attribute (exact, then case-insensitive) or its Name, retries the equip, and confirms by
-- instance identity — so seeds whose display name differs slightly from the SeedTool attr still equip.
function equipSeedTool(name)
    local function matches(t)
        if not (t and t:IsA("Tool")) then return false end
        local st = t:GetAttribute("SeedTool"); if st == nil then return false end
        return st == name or t.Name == name or tostring(st):lower() == tostring(name):lower()
    end
    -- already holding the right seed?
    local held = heldToolByAttr("SeedTool")
    if held and matches(held) then return held end
    local tool = seedToolFor(name); if not tool then return nil end
    local hum = humanoid(); if not hum then return nil end
    for _ = 1, 3 do
        pcall(function() hum:EquipTool(tool) end); task.wait(0.2)
        held = heldToolByAttr("SeedTool")
        if held == tool then return held end
        pcall(function() tool.Parent = LocalPlayer.Character end); task.wait(0.12)  -- parent-into-char fallback
        held = heldToolByAttr("SeedTool")
        if held == tool then return held end
    end
    held = heldToolByAttr("SeedTool")
    return (held and matches(held)) and held or nil  -- only return if it's really our seed
end

