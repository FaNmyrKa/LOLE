-- ServerHop - hop until a target seed is in stock. Terminal (teleports the whole client away);
-- queue_on_teleport reloads the hub and MacLib autoload re-arms the toggle so the chain continues.
-- Only hops when nothing else is mid-action (so it never teleports away mid-steal/sell and loses loot).
task.spawn(function()
    while not stopped do
        if autoHopRareEnabled and not hopBusy and not ActivityPriority.currentActivity and seedStockReady() then
            local inStock, which = rareSeedInStock()
            if inStock then
                if not hopFoundNotified then
                    hopFoundNotified = true
                    pcall(function() Window:Notify({ Title = "Server Hop", Description = "'" .. tostring(which) .. "' is in stock - holding here.", Lifetime = 8 }) end)
                end
            else
                hopFoundNotified = false
                hopBusy = true
                pcall(function() Window:Notify({ Title = "Server Hop", Description = "Target not in stock - hopping...", Lifetime = 3 }) end)
                serverHop(false)
                task.wait(4); hopBusy = false  -- release if the teleport didn't actually fire
            end
        end
        waitInterval(function() return autoHopRareEnabled end, hopInterval)
    end
end)

