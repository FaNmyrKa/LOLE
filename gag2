-- stay centered in our own garden when nothing else is running: a quiet, legit-looking resting spot.
-- Gated on an idle ActivityPriority so it never fights a real action, and only fires when we've
-- actually drifted off-center. Flies (never teleports) so the anti-cheat sees normal motion.
task.spawn(function()
    while not stopped do
        task.wait(3)
        if stayCentered and not ActivityPriority.currentActivity then
            local c, hrp = myPlotCenter(), hrpNow()
            if c and hrp and (hrp.Position - c).Magnitude > (centerDist or 30) then
                if ActivityPriority:SetActivity("Recenter") then
                    pcall(function() flyTo(c) end)
                    ActivityPriority:ClearActivity("Recenter")
                end
            end
        end
    end
end)

-- // ---- session guard / recovery ---- //
-- Every loop is `while not stopped` and helpers (hrpNow/myPlot/pdata) re-fetch each call, so they
-- self-heal on respawn. The two things that DON'T: the cached replica (_replica) goes stale after a
-- teleport to a new server, and the game re-adds its idle-kick on the new server. Re-warm both.
local function suppressIdleKick()
    pcall(function()
        local GC = getconnections or get_signal_cons
        if GC then for _, v in pairs(GC(LocalPlayer.Idled)) do
            if v.Disable then v:Disable() elseif v.Disconnect then v:Disconnect() end
        end end
    end)
end
do
    local function recover(reason)
        task.spawn(function()
            task.wait(2)  -- let the new character/replica stream in
            rewarmReplica(); suppressIdleKick()
            pcall(function() Window:Notify({ Title = "Apel Hub", Description = "session recovered (" .. reason .. ")", Lifetime = 4 }) end)
        end)
    end
    pcall(function()
        local TPS = game:GetService("TeleportService")
        table.insert(hubConnections, TPS.LocalPlayerArrivedFromTeleport:Connect(function() recover("teleport") end))
    end)
    -- replica-desync watchdog: re-warm if the replica goes empty while we're in-world (any cause, no respawn spam)
    task.spawn(function()
        while not stopped do
            task.wait(20)
            if hrpNow() and not next(pdata()) then rewarmReplica() end
        end
    end)
end

