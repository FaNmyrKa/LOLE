local _cachedRequest = (syn and syn.request) or (http and http.request) or http_request or request or (fluxus and fluxus.request) or nil

-- [3] Session tracking
local function resetSessionPulls() _TR.SessionPulls = {} _TR.SessionPullOrder = {} end
local function resetSessionTraits() _TR.SessionTraits = {} _TR.SessionTraitOrder = {} end

local function recordSessionPull(name)
	if not name then return end
	if not _TR.SessionPulls[name] then
		_TR.SessionPullOrder[#_TR.SessionPullOrder + 1] = name
		_TR.SessionPulls[name] = 1
	else
		_TR.SessionPulls[name] = _TR.SessionPulls[name] + 1
	end
end

local function recordSessionTrait(label)
	if not label then return end
	if not _TR.SessionTraits[label] then
		_TR.SessionTraitOrder[#_TR.SessionTraitOrder + 1] = label
		_TR.SessionTraits[label] = 1
	else
		_TR.SessionTraits[label] = _TR.SessionTraits[label] + 1
	end
end

local function buildReport(order, counts)
	if #order == 0 then return "—" end
	local lines = {}
	for _, name in ipairs(order) do
		local n = counts[name] or 1
		lines[#lines + 1] = n > 1 and ("• " .. name .. " x" .. n) or ("• " .. name)
	end
	return table.concat(lines, "\n")
end

local function buildTargetNameList()
	if not next(_TR.TargetHeroIds) then return "—" end
	local parts = {}
	for id, sel in pairs(_TR.TargetHeroIds) do if sel then parts[#parts + 1] = heroName(id) end end
	table.sort(parts)
	return table.concat(parts, ", ")
end

local function buildTargetTraitList()
	if not next(_TR.TargetTraits) then return "—" end
	local parts = {}
	for id, sel in pairs(_TR.TargetTraits) do if sel then parts[#parts + 1] = traitIdToName[id] or id end end
	table.sort(parts)
	return table.concat(parts, ", ")
end

local function sendRejoinWebhook(mode, kind)
	if not _TR.WebhookEnabled then return end
	local url = _TR.WebhookURL
	if not url or url == "" then return end

	local title, color
	if kind == "clean" then
		title = "✅ Цель поймана — чистый реджоин"
		color = 4437377
	elseif kind == "manual" then
		title = "⏹ Ручное выключение — возврат гемов"
		color = 10197915
	else
		title = "🔁 Сессия завершена — реджоин с возвратом"
		color = 15277667
	end

	local desc
	if mode == "trait" then
		desc = ("**Режим:** Trait Reroll\n**Герой:** %s\n**Целевые трейты:** %s\n**Всего реролов:** %d\n\n**Что выпало:**\n%s"):format(
			_TR.SelectedHeroId and heroName(_TR.SelectedHeroId) or "—",
			buildTargetTraitList(),
			_TR.TotalRerolls or 0,
			buildReport(_TR.SessionTraitOrder, _TR.SessionTraits)
		)
	else
		desc = ("**Режим:** Banner Summon\n**Кого крутили:** %s\n**Баннер:** %s x%d\n**Всего круток:** %d\n\n**Что выпало:**\n%s"):format(
			buildTargetNameList(),
			tostring(_TR.SummonBanner or "?"),
			_TR.SummonAmount or 1,
			_TR.TotalSummons or 0,
			buildReport(_TR.SessionPullOrder, _TR.SessionPulls)
		)
	end

	task.spawn(function()
		local payload = HttpService:JSONEncode({
			username = "Apel Hub • Trait Reroller",
			embeds = {{
				title = title,
				description = desc,
				color = color,
				footer = { text = "Apel Hub • " .. os.date("%Y-%m-%d %H:%M:%S") },
			}},
		})

		local sent = false
		if _cachedRequest then
			local ok = pcall(function()
				_cachedRequest({ Url = url, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = payload })
			end)
			if ok then sent = true end
		end
		if not sent then
			pcall(function()
				HttpService:PostAsync(url, payload, Enum.HttpContentType.ApplicationJson, false)
			end)
		end
	end)
end

