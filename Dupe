-- Banner Summon loop
---------------------------------------------------------------------------
task.spawn(function()
	task.wait(0.5)
	while getgenv()._TRRunning do
		if not _TR.BannerSummonEnabled or not summonNet then task.wait(0.2) continue end

		if not next(_TR.TargetHeroIds) then
			warn("[TR] No target heroes selected!")
			stopBannerSummon()
			continue
		end

		-- Fresh session
		resetSessionPulls()
		_TR.GemsSpentThisSession = 0

		-- ARM bug refund BEFORE any summons
		armBugRefund()

		local banner = _TR.SummonBanner or "NORMAL"
		local amount = _TR.SummonAmount or 10
		local cost = (banner == "CRIMSON" and 60 or 50) * amount

		while _TR.BannerSummonEnabled and getgenv()._TRRunning and not _TR.TargetFound do
			-- Gem session limit
			if _TR.GemsSpentThisSession >= GEMS_PER_SESSION then
				sendRejoinWebhook("summon", "bug")
				rejoin()
				return
			end

			local cur = GetSummonCurrency(banner)
			if cur < cost then
				sendRejoinWebhook("summon", "bug")
				rejoin()
				return
			end

			local ok, err = pcall(function() summonNet.summonHero.call(amount, banner) end)
			if ok then
				_TR.TotalSummons = _TR.TotalSummons + amount
				_TR.GemsSpentThisSession = _TR.GemsSpentThisSession + cost
				pcall(function() SummonStatsLabel:UpdateName("Total summons: " .. _TR.TotalSummons .. " | " .. _TR.GemsSpentThisSession .. "/" .. GEMS_PER_SESSION) end)
			else
				warn("[TR] Summon error:", tostring(err))
				task.wait(0.3)
			end

			if _TR.TargetFound then break end
			task.wait(SUMMON_DELAY)
		end

		if not getgenv()._TRRunning then return end

		-- Target found → clean rejoin (save hero)
		if _TR.TargetFound then
			sendRejoinWebhook("summon", "clean")
			cleanRejoin()
			return
		end

		-- Toggle disabled mid-session → disarm
		if not _TR.BannerSummonEnabled then
			if _bugArmed then disarmBugRefund() end
			continue
		end
	end
end)

---------------------------------------------------------------------------
-- Main reroll loop
---------------------------------------------------------------------------
task.spawn(function()
	task.wait(2)

	while getgenv()._TRRunning do
		if not _TR.Enabled then task.wait(0.3) continue end

		if not _TR.SelectedHeroUUID then
			warn("[TR] No hero selected!") stopReroll() continue
		end
		if not next(_TR.TargetTraits) then
			warn("[TR] No target traits!") stopReroll() continue
		end

		local uuid = _TR.SelectedHeroUUID

		-- Pre-roll check
		pcall(function()
			local bag = getHeroBag()
			local hero = bag[uuid]
			if hero and hero.trait then
				local current = normalizeTraitId(hero.trait)
				if _TR.TargetTraits[current] then
					local currentName = traitIdToName[current] or hero.trait
					stopReroll()
					SaveAll()
					pcall(function()
						Window:Notify({
							Title = "Already has target!",
							Description = currentName .. " | Total: " .. _TR.TotalRerolls,
							Lifetime = 30,
						})
					end)
				end
			end
		end)
		if not _TR.Enabled then continue end

		-- Fresh session
		resetSessionTraits()

		-- ARM bug before rerolls
		armBugRefund()

		for i = 1, _TR.RerollsPerSession do
			if not _TR.Enabled or not getgenv()._TRRunning then break end


			local ok, result = pcall(function() return heroesNet.rerollHeroTraits.call(uuid) end)
			_TR.TotalRerolls = _TR.TotalRerolls + 1
			pcall(function() StatsLabel:UpdateName("Total rerolls: " .. _TR.TotalRerolls) end)

			if ok and type(result) == "table" then
				if result.result == "success" then
					local raw = result.trait
					local got = normalizeTraitId(raw)
					local gotName = traitIdToName[got] or raw
					recordSessionTrait(gotName)

					if _TR.TargetTraits[got] then
						pcall(function()
							Window:Notify({
								Title = "Trait Found!",
								Description = gotName .. " | Total: " .. _TR.TotalRerolls,
								Lifetime = 30,
							})
						end)
						sendRejoinWebhook("trait", "clean")
						cleanRejoin()
						return
					end
				elseif result.result == "fail" then
					warn("[TR] Fail:", result.reason or "?")
					if result.reason and result.reason:lower():find("ticket") then
						stopReroll()
						SaveAll()
						break
					end
				end
			else
				warn("[TR] Error:", tostring(result))
			end

			if i < _TR.RerollsPerSession then task.wait(REROLL_DELAY) end
		end

		-- Session done, no target → bug rejoin (tickets refund)
		if _TR.Enabled and getgenv()._TRRunning then
			sendRejoinWebhook("trait", "bug")
			rejoin()
			return
		end
	end
end)

Window.onUnloaded(function()
	getgenv()._TRRunning = false
	stopReroll()
	stopBannerSummon()
	SaveAll()
end)

