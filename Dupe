local function armBugRefund()
	if _bugArmed then return end
	print("[TR] [BUG] Arming NaN refund (uiVolume = 0/0)")
	local ok = pcall(function()
		local playerNet = require(game:GetService("ReplicatedStorage").lobbyClient.net.player)
		playerNet.updateSettings.fire("uiVolume", 0/0)
	end)
	if ok then
		_bugArmed = true
	else
		warn("[TR] [BUG] Arm failed")
	end
end

local function disarmBugRefund()
	print("[TR] [BUG] Disarming refund (uiVolume = 0.5)")
	pcall(function()
		local playerNet = require(game:GetService("ReplicatedStorage").lobbyClient.net.player)
		playerNet.updateSettings.fire("uiVolume", 0.5)
	end)
	_bugArmed = false
end

