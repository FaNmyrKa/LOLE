---------------------------------------------------------------------------
-- Rejoin
---------------------------------------------------------------------------
local function rejoin()
	if _rejoining then return end
	_rejoining = true
	print("[TR] >>> REJOIN (NaN bug, double-shot) <<<")
	SaveAll()
	-- Second NaN shot for guaranteed delivery (first one was at session start)
	_bugArmed = false -- force armBugRefund to fire again
	armBugRefund()
	-- Let the NaN packet actually leave the client before teleporting
	task.wait(0.5)
	TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LP)
end

-- Clean rejoin: sends a VALID uiVolume (0.5) before teleporting, so the server saves
-- the new hero/trait. Overrides any previously armed NaN bug.
local function cleanRejoin()
	if _rejoining then return end
	_rejoining = true
	print("[TR] >>> CLEAN REJOIN (target found, saving) <<<")
	_TR.StopAfterReload = true
	_TR.BannerSummonEnabled = false
	_TR.Enabled = false
	SaveAll()
	-- Disarm: send valid 0.5 to override the prior NaN
	disarmBugRefund()
	-- Let the valid packet flush + give server time to persist
	task.wait(0.5)
	TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LP)
end

---------------------------------------------------------------------------
-- Banner Summon: hook summonHero.call to detect target
---------------------------------------------------------------------------
local function GetSummonCurrency(banner)
	if not clientStore then return 0 end
	local ok, state = pcall(function() return clientStore:getState() end)
	if not ok or not state or not state.data or not state.data.core then return 0 end
	local core = state.data.core[userId]
	if not core then return 0 end
	return banner == "CRIMSON" and (core.bloodiedChains or 0) or (core.crystalShard or 0)
end

if summonNet and summonNet.summonHero and summonNet.summonHero.call then
	local _origSummonCall = summonNet.summonHero.call
	summonNet.summonHero.call = function(amount, bannerKey)
		local ok, res = _origSummonCall(amount, bannerKey)
		if ok and type(res) == "table" then
			-- Print every hero from the pull
			local names = {}
			for _, h in ipairs(res) do
				if type(h) == "table" and h.id then
					local nm = heroName(h.id)
					if h.shiny then nm = nm .. "★" end
					names[#names + 1] = nm
				end
			end
			if #names > 0 then
				print("[TR] Pulled [" .. tostring(bannerKey) .. " x" .. tostring(amount) .. "]: " .. table.concat(names, ", "))
			end

			-- Target detection
			if next(_TR.TargetHeroIds) then
				for _, h in ipairs(res) do
					if type(h) == "table" and h.id and _TR.TargetHeroIds[h.id] then
						_TR.TargetFound = true
						_TR.BannerSummonEnabled = false
						print("[TR] ★★★ TARGET HERO PULLED: " .. heroName(h.id) .. " ★★★ after " .. _TR.TotalSummons .. " summons")
						pcall(function()
							Window:Notify({
								Title = "Target Hero!",
								Description = heroName(h.id) .. " | Total summons: " .. _TR.TotalSummons,
								Lifetime = 30,
							})
						end)
						SaveAll()
						break
					end
				end
			end
		end
		return ok, res
	end
end

---------------------------------------------------------------------------
-- Banner Summon loop
---------------------------------------------------------------------------
local SUMMON_DELAY = 0.05 -- delay between summons

task.spawn(function()
	task.wait(0.5)
	while getgenv()._TRRunning do
		if not _TR.BannerSummonEnabled or not summonNet then task.wait(0.2) continue end

		if not next(_TR.TargetHeroIds) then
			warn("[TR] No target heroes selected!") _TR.BannerSummonEnabled = false continue
		end

		-- ARM bug refund BEFORE any summons. If something kills the script mid-session,
		-- the NaN packet is already on the server and the next rejoin will refund.
		armBugRefund()

		local banner = _TR.SummonBanner or "NORMAL"
		local amount = _TR.SummonAmount or 10
		local cost = (banner == "CRIMSON" and 60 or 50) * amount
		local limit = _TR.SummonsPerSession or 5

		-- Run a fixed number of summon CALLS (x1 and x10 both count as 1 call)
		local sessionCalls = 0
		for i = 1, limit do
			if not _TR.BannerSummonEnabled or not getgenv()._TRRunning then break end
			if _TR.TargetFound then break end

			local cur = GetSummonCurrency(banner)
			if cur < cost then
				print(string.format("[TR] Out of gems early at call %d/%d (%d/%d)", i, limit, cur, cost))
				break
			end

			print(string.format("[TR] Call %d/%d | x%d [%s] | gems: %d → %d", i, limit, amount, banner, cur, cur - cost))
			local ok, err = pcall(function() summonNet.summonHero.call(amount, banner) end)
			if ok then
				_TR.TotalSummons = _TR.TotalSummons + amount
				sessionCalls = sessionCalls + 1
				pcall(function() SummonStatsLabel:UpdateName("Total summons: " .. _TR.TotalSummons) end)
			else
				warn("[TR] Summon error:", tostring(err))
				task.wait(0.3)
			end

			if _TR.TargetFound then break end
			task.wait(SUMMON_DELAY)
		end

		if not getgenv()._TRRunning then return end

		-- Target pulled → CLEAN rejoin so the unit is saved
		if _TR.TargetFound then
			cleanRejoin()
			return
		end

		-- Toggle disabled mid-session → disarm and stop
		if not _TR.BannerSummonEnabled then
			if _bugArmed then disarmBugRefund() end
			continue
		end

		-- Limit reached, no target → BUG rejoin (NaN) to refund gems
		print(string.format("[TR] Session done (%d calls) — bug rejoin", sessionCalls))
		rejoin()
		return
	end
end)

---------------------------------------------------------------------------
-- Main loop
---------------------------------------------------------------------------
task.spawn(function()
	task.wait(2)

	while getgenv()._TRRunning do
		if not _TR.Enabled then task.wait(0.3) continue end

		if not _TR.SelectedHeroUUID then
			warn("[TR] No hero selected!") _TR.Enabled = false continue
		end
		if not next(_TR.TargetTraits) then
			warn("[TR] No target traits!") _TR.Enabled = false continue
		end

		local uuid = _TR.SelectedHeroUUID

		for i = 1, _TR.RerollsPerSession do
			if not _TR.Enabled or not getgenv()._TRRunning then break end

			print(string.format("[TR] Roll %d/%d (total %d)", i, _TR.RerollsPerSession, _TR.TotalRerolls + 1))

			local ok, result = pcall(function() return heroesNet.rerollHeroTraits.call(uuid) end)
			_TR.TotalRerolls = _TR.TotalRerolls + 1
			pcall(function() StatsLabel:UpdateName("Total rerolls: " .. _TR.TotalRerolls) end)

			if ok and type(result) == "table" then
				if result.result == "success" then
					local got = result.trait
					local gotName = traitIdToName[got] or got
					print("[TR] Got:", gotName)

					if _TR.TargetTraits[got] then
						print("[TR] ★★★ TARGET TRAIT FOUND:", gotName, "★★★ after", _TR.TotalRerolls, "rerolls")
						pcall(function()
							Window:Notify({
								Title = "Trait Found!",
								Description = gotName .. " | Total: " .. _TR.TotalRerolls,
								Lifetime = 30,
							})
						end)
						cleanRejoin()
						return
					end
				elseif result.result == "fail" then
					warn("[TR] Fail:", result.reason or "?")
					if result.reason and result.reason:lower():find("ticket") then
						print("[TR] Out of tickets!")
						_TR.Enabled = false
						SaveAll()
						break
					end
				end
			else
				warn("[TR] Error:", tostring(result))
			end

			if i < _TR.RerollsPerSession then task.wait(REROLL_DELAY) end
		end

		if _TR.Enabled and getgenv()._TRRunning then
			rejoin()
			return
		end
	end
end)

Window.onUnloaded(function()
	getgenv()._TRRunning = false
	_TR.Enabled = false
	SaveAll()
end)
