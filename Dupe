local traitNameToId, traitIdToName, traitNames = {}, {}, {}
for _, t in ipairs(TRAITS) do
	local label = t.name .. " (" .. t.rarity .. ")"
	traitNameToId[label] = t.id
	traitIdToName[t.id] = label
	traitNames[#traitNames + 1] = label
end

local itemsCfg = nil
pcall(function() itemsCfg = require(RS:WaitForChild("shared"):WaitForChild("config"):WaitForChild("items")) end)

local function heroName(heroId)
	if itemsCfg then
		local ok, cfg = pcall(function() return itemsCfg.hero.get(heroId) end)
		if ok and cfg and cfg.name then return cfg.name end
	end
	return tostring(heroId)
end

-- Build list of all Secret heroes from heroRarities config
local function buildSecretHeroList()
	local list = {}
	pcall(function()
		local hr = require(RS:WaitForChild("shared"):WaitForChild("config"):WaitForChild("summon"):WaitForChild("heroRarities"))
		if hr and hr.Secret then
			for id, _ in pairs(hr.Secret) do
				list[#list + 1] = { id = id, name = heroName(id) }
			end
		end
	end)
	-- Fallback: scan itemsCfg for any Secret-rarity hero
	if #list == 0 and itemsCfg then
		pcall(function()
			local all = itemsCfg.hero.getAll and itemsCfg.hero.getAll() or nil
			if type(all) == "table" then
				for id, cfg in pairs(all) do
					if type(cfg) == "table" and cfg.rarity == "Secret" then
						list[#list + 1] = { id = id, name = cfg.name or tostring(id) }
					end
				end
			end
		end)
	end
	table.sort(list, function(a, b) return a.name < b.name end)
	return list
end

local function getHeroBag()
	local ok, state = pcall(function() return clientStore:getState() end)
	if not ok or not state or not state.data or not state.data.heroes then return {} end
	return state.data.heroes[userId] or {}
end

local function buildHeroList()
	local bag = getHeroBag()
	local list = {}
	for uuid, hero in pairs(bag) do
		if type(hero) == "table" and hero.id then
			local name = heroName(hero.id)
			local trait = hero.trait and (traitIdToName[hero.trait] or hero.trait) or "None"
			local shiny = hero.shiny and " ★" or ""
			list[#list + 1] = {
				uuid = uuid, heroId = hero.id,
				label = name .. shiny .. " [" .. trait .. "]",
				sortName = name,
			}
		end
	end
	table.sort(list, function(a, b) return a.sortName < b.sortName end)
	return list
end

