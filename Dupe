---------------------------------------------------------------------------
-- Rejoin: dirty (NaN rollback) vs clean (save)
---------------------------------------------------------------------------

-- Dirty rejoin — NaN armed, сервер откатит
function rejoin()
	if _rejoining then return end
	_rejoining = true
	SaveAll()
	-- Second NaN shot for guaranteed delivery
	_bugArmed = false
	armBugRefund()
	task.wait(0.3)
	TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LP)
end

-- Clean rejoin — disarm NaN, сервер СОХРАНИТ
local function cleanRejoin()
	if _rejoining then return end
	_rejoining = true
	_TR.StopAfterReload = true
	stopReroll()
	stopBannerSummon()
	SaveAll()
	disarmBugRefund()
	task.wait(0.5)
	TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LP)
end

