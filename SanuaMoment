                    byType[t].total = byType[t].total + 1
                    if ok then byType[t].ready = byType[t].ready + 1 end
                end
            end

            -- Index claimable count
            local idxClaim = 0
            do
                local cpd = session.collection and session.collection.collection_profile_data
                if cpd then
                    local indexed = cpd.indexed_units or {}
                    local claimed = cpd.claimed_units or {}
                    for id, unit in pairs(Units or {}) do
                        if unit.id and not unit.spawn_cap and indexed[id] and not claimed[id] then
                            local r = unit.rarity
                            if r ~= "Mythic" and r ~= "Exclusive" and r ~= "Secret" and r ~= "Crusader" then
                                idxClaim = idxClaim + 1
                            elseif unit.evolved then
                                idxClaim = idxClaim + 1
                            end
                        end
                    end
                end
            end

            -- BP info
