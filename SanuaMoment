-- Release rewards (Christmas event). Iterates unlocked indices and claims any
-- not yet in claimed list. Server tracks claimed_daily_release_rewards_christmas.
function API.claimReleaseRewards()
    local stats = (session and session._stats) or {}
    local unlocked = stats.unlocked_daily_release_rewards_christmas
    local claimed  = stats.claimed_daily_release_rewards_christmas or {}
    if type(unlocked) ~= "table" then return 0 end
    local claimedSet = {}
    for _, v in ipairs(claimed) do claimedSet[v] = true end
    local n = 0
    for _, idx in ipairs(unlocked) do
        if not claimedSet[idx] then
            local ok = API.invoke("claim_release_rewards", idx)
            if ok then n = n + 1 end
            task.wait(0.15)
        end
    end
    return n
end

-- Guidebook rewards. Decompile shows two call shapes: numeric FixedIndex and
-- the literal string "Unit". Server returns false if nothing to claim.
function API.claimGuidebook()
    local n = 0
    for _, arg in ipairs({ "Unit" }) do
        local ok, res = API.invoke("claim_guidebook", arg)
        if ok and res then n = n + 1 end
        task.wait(0.15)
    end
    return n
end

-- Index reward — per-unit individual claim. claim_all_index covers most cases;
-- this is a fallback that walks owned units and tries each unit_id whose entry
-- is marked claimable. Server is idempotent on already-claimed.
function API.claimIndexRewardsPerUnit()
    if not session or not session.collection
       or not session.collection.collection_profile_data then return 0 end
    local owned = session.collection.collection_profile_data.owned_units
    if type(owned) ~= "table" then return 0 end
    local seen, n = {}, 0
    for _, u in pairs(owned) do
        local id = u and u.unit_id
        if id and not seen[id] then
            seen[id] = true
            local ok = API.invoke("claim_index_reward", id)
            if ok then n = n + 1 end
            task.wait(0.1)
        end
    end
    return n
end

