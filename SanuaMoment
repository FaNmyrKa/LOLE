-- Full auto-join flow:
--   1. Find free R-lobby (or reuse current if it matches)
--   2. request_join_lobby(lobby) — become Owner
--   3. request_lock_level(lobby, level, friends_only, difficulty, true)
--      → server fills Active=true, Level/World/Difficulty in model
--   4. request_start_game(lobby)
local function autoJoinRaid()
    local levelId = _AC.RaidLevel
    if not levelId or levelId == "" then
        return false, "no RaidLevel set in hub UI"
    end

    -- Reuse current lobby if it's already locked on the right level
    local cur = readLiveRaidParams()
    if cur and cur.lobby_model then
        local s = readRaidLobbyState(cur.lobby_model)
        if s and s.Active and s.Level == levelId and s.Owner == LocalPlayer then
            local ok = API.invoke("request_start_game", cur.lobby)
            if not ok then API.invoke("vote_start") end
            return true, ("reused %s"):format(cur.lobby)
        end
    end

    -- Pick a free lobby
    local lobbyModel = findFreeRaidLobby()
    if not lobbyModel then return false, "no free raid lobby (R1-R9)" end
    local lobbyName = lobbyModel.Name

    -- Sync LSC client-side (mirrors what game UI would do)
    if LobbyServiceClient then
        pcall(function()
            LobbyServiceClient.selected_level      = levelId
            LobbyServiceClient.difficulty          = _AC.RaidDifficulty or "Hard"
            LobbyServiceClient.friends_only        = _AC.RaidFriendsOnly or false
            LobbyServiceClient.current_lobby       = lobbyName
            LobbyServiceClient.current_lobby_model = lobbyModel
        end)
    end

    local ok = API.invoke("request_join_lobby", lobbyName)
    if not ok then return false, "request_join_lobby failed" end
    task.wait(_AC.JoinWait)

    -- request_lock_level(lobby, level, friends_only, difficulty, true, map_item_id)
    API.invoke("request_lock_level", lobbyName, levelId,
           _AC.RaidFriendsOnly or false, _AC.RaidDifficulty or "Hard",
           true, nil)
    task.wait(0.4)

    local ok2 = API.invoke("request_start_game", lobbyName)
    if not ok2 then API.invoke("vote_start") end
    return true, lobbyName
end

