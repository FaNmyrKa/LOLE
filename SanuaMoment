-- ----- Helpers -----
local function sanitizeMacroName(name)
    if type(name) ~= "string" then return "" end
    name = name:match("^%s*(.-)%s*$") or ""
    name = name:gsub('[<>:"/\\|?*]', "")
    return name
end

local function listMacroFiles()
    if not (listfiles and isfolder and isfolder(MacroFolder)) then return {} end
    local names = {}
    local ok, files = pcall(listfiles, MacroFolder)
    if not ok then return {} end
    for _, file in ipairs(files) do
        local name = file:match("([^/\\]+)%.json$")
        if name then table.insert(names, name) end
    end
    table.sort(names)
    return names
end

local function macroPath(name) return MacroFolder .. "/" .. name .. ".json" end

-- ----- Save / Load -----
-- Format:
--   { version = 2, saved_at = "...", name = "...", count = N, steps = [...] }
-- All step identifiers are portable: UnitName (display, hotbar label) and
-- Pos (world Vector3). No collection UUIDs, no runtime SpawnedIDs.
--
-- saveMacro accepts either:
--   • plain step array (will be wrapped in envelope)
--   • already-wrapped envelope (passes through)

local function saveMacro(name, data)
    name = sanitizeMacroName(name)
    if name == "" then return false end
    if not writefile then return false end

    local payload
    if type(data) == "table" and data.version and data.steps then
        payload = data
    else
        local steps = (type(data) == "table" and not data.steps) and data or {}
        payload = {
            version  = 2,
            saved_at = os.date("%Y-%m-%d %H:%M:%S"),
            name     = name,
            count    = #steps,
            steps    = steps,
        }
    end

    -- Pretty: header compact, each step on own line for human review / git diff
    local stepsJson = {}
    for _, step in ipairs(payload.steps) do
        local ok, encoded = pcall(HttpService.JSONEncode, HttpService, step)
        stepsJson[#stepsJson + 1] = ok and encoded or "{}"
    end
    local header = {
        version  = payload.version,
        saved_at = payload.saved_at,
        name     = payload.name,
        count    = payload.count,
    }
    local hOk, hEnc = pcall(HttpService.JSONEncode, HttpService, header)
    if not hOk then return false end
    local body = hEnc:sub(1, -2)  -- drop closing }
    body = body .. (hEnc == "{}" and '"steps":[' or ',"steps":[')
    if #stepsJson > 0 then
        body = body .. "\n  " .. table.concat(stepsJson, ",\n  ") .. "\n"
    end
    body = body .. "]}"

    local ok = pcall(writefile, macroPath(name), body)
    return ok
end

local function loadMacro(name)
    name = sanitizeMacroName(name or "")
    if name == "" then return {} end
    if not (readfile and isfile and isfile(macroPath(name))) then return {} end
    local ok, raw = pcall(readfile, macroPath(name))
    if not ok then return {} end
    local ok2, data = pcall(HttpService.JSONDecode, HttpService, raw)
    if not ok2 or type(data) ~= "table" then return {} end
    if type(data.steps) ~= "table" then return {} end
    return data.steps
end

local function deleteMacro(name)
    name = sanitizeMacroName(name or "")
    if name == "" or not (delfile and isfile and isfile(macroPath(name))) then return false end
    local ok = pcall(delfile, macroPath(name))
    return ok
end

local function ensureMacroFile(name)
    name = sanitizeMacroName(name)
    if name == "" then return false end
    if not (isfile and isfile(macroPath(name))) then
        return saveMacro(name, {})
    end
    return true
end

-- ----- Import / Export -----
local function macroBaseFromUrl(url)
    if type(url) ~= "string" then return "" end
    if url:find("paste%.rs/") then
        local id = url:match("paste%.rs/(%w+)")
        return sanitizeMacroName("paste_" .. (id or "import"))
    end
    local noQuery = url:match("^([^%?#]+)") or url
    local file = noQuery:match("([^/\\]+)$") or ""
    file = file:gsub("%.json$", ""):gsub("%.JSON$", "")
    return sanitizeMacroName(file)
end

local function fetchMacroUrl(url)
    if type(url) ~= "string" or url == "" then return nil, "empty url" end
    url = url:match("^%s*(%S+)%s*$") or url
    local req = (syn and syn.request) or (http and http.request) or http_request or request
    if req then
        local ok, res = pcall(function()
            return req({ Url = url, Method = "GET",
                Headers = { ["User-Agent"] = "Mozilla/5.0 ACHub-MacroImport" } })
        end)
        if ok and type(res) == "table" then
            local code = res.StatusCode or res.statusCode or res.Status
            local body = res.Body or res.body
            if type(body) == "string" and body ~= "" and (code == nil or code == 200 or code == 0) then
                return body
            end
        end
    end
    local ok2, body2 = pcall(function() return game:HttpGet(url, true) end)
    if ok2 and type(body2) == "string" and body2 ~= "" then return body2 end
    return nil, "download failed"
end

