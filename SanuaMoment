local CONTRACT_TIERS = { -- order matters (lowest → highest)
    "Rookie Contract", "Standard Contract", "Elite Contract",
    "Legendary Contract", "Mythic Contract", "Godlike Contract",
}
local TIER_INDEX = {}; for i, n in ipairs(CONTRACT_TIERS) do TIER_INDEX[n] = i end

local function getGatesFolder()    local g = workspace:FindFirstChild("_GATES"); return g and g:FindFirstChild("gates") end
local function getLobbiesFolder()  local g = workspace:FindFirstChild("_GATES"); return g and g:FindFirstChild("Lobbies") end
local function readSV(p, n) if not p then return nil end; local sv = p:FindFirstChild(n); local ok, v = pcall(function() return sv and sv.Value end); return ok and v ~= "" and v or nil end
local function readNV(p, n) if not p then return 0 end; local sv = p:FindFirstChild(n); local ok, v = pcall(function() return sv and sv.Value end); return ok and tonumber(v) or 0 end
local function readBV(p, n) if not p then return false end; local sv = p:FindFirstChild(n); local ok, v = pcall(function() return sv and sv.Value end); return ok and v == true end

-- Gate index 1-11 = basic, 12-22 = Advanced (1-11)
-- Returns lobby model name like "_GATE1" or "_GATE5Advanced"
local function gateIndexToName(i)
    if i <= 11 then return "_GATE" .. i end
    return "_GATE" .. (i - 11) .. "Advanced"
end

local function getGateLobbyModel(i)
    local lf = getLobbiesFolder()
    return lf and lf:FindFirstChild(gateIndexToName(i))
end

-- Read challenge from gates/N folder (basic gates). Advanced gates read from lobby model directly.
local function getGateChallenge(i)
    if i <= 11 then
        local gf = getGatesFolder()
        local ch = gf and readSV(gf:FindFirstChild(tostring(i)), "current_challenge")
        if ch then return tostring(ch):lower() end
    end
    local m = getGateLobbyModel(i)
    local c2 = m and readSV(m, "Challenge")
    return c2 and tostring(c2):lower() or nil
end

local function getGateReward(i)
    if i <= 11 then
        local gf = getGatesFolder()
        local r = gf and readNV(gf:FindFirstChild(tostring(i)), "_portal_reward_scale")
        if r > 0 then return r end
    end
    local m = getGateLobbyModel(i)
    return m and readNV(m, "_portal_reward_scale") or 0
end

local function getGateContract(i)
    -- Lobby model uses "Gate" StringValue, info folder uses "GateType"
    local m = getGateLobbyModel(i)
    if m then
        local v = readSV(m, "Gate") or readSV(m, "GateType")
        if v then return v end
    end
    if i <= 11 then
        local gf = getGatesFolder()
        local info = gf and gf:FindFirstChild(tostring(i))
        if info then return readSV(info, "GateType") end
    end
    return nil
end

local function isGateLocked(i)
    local m = getGateLobbyModel(i)
    return m and readBV(m, "Locked")
end

-- Score logic:
--   skip gate if locked, or contract below MinContractTier, or challenge priority = 0
--   score = challengePrio * 10000 + reward
--   priority dominates (higher prio wins regardless of reward)
local function pickBestGate(verbose)
    local best, bestScore = nil, -1
    local maxIdx = _AC.IncludeAdvanced and 22 or 11
    local minTier = TIER_INDEX[_AC.MinContractTier] or 1
    local skipLog = {}

    for i = 1, maxIdx do
        local m = getGateLobbyModel(i)
        if m then  -- skip if lobby model doesn't exist
            local locked   = isGateLocked(i)
            local ch       = getGateChallenge(i)        -- e.g. "tank_enemies"
            local reward   = getGateReward(i)
            local contract = getGateContract(i)
            -- tier check: if contract is unknown, don't filter (let through)
            local tierOK = true
            if contract then
                local tierIdx = TIER_INDEX[contract] or 1
                tierOK = tierIdx >= minTier
            end
            -- challenge priority: 0 = skip, default 5 if unknown challenge
            local chPrio = ch and (_AC.ChallengePriority[ch] or 5) or 5

            if not locked and tierOK and chPrio > 0 then
                local score = chPrio * 10000 + reward
                if score > bestScore then
                    bestScore = score; best = i
                end
            elseif verbose then
                local why = locked and "locked"
                         or (not tierOK and ("tier<"..minTier.."("..tostring(contract)..")"))
                         or (chPrio == 0 and "prio=0("..tostring(ch)..")")
                         or "unknown"
                table.insert(skipLog, ("g%d: %s"):format(i, why))
            end
        elseif verbose then
            table.insert(skipLog, ("g%d: no model"):format(i))
        end
    end

    if verbose then
        print("[ACHub:pickBestGate] best=" .. tostring(best)
            .. " score=" .. tostring(bestScore)
            .. " maxIdx=" .. maxIdx
            .. " minTier=" .. minTier
            .. " skipped=" .. #skipLog)
        for _, l in ipairs(skipLog) do print("  " .. l) end
    end
    return best, bestScore
end

