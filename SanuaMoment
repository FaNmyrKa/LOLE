-- 5. LOCK CRITICAL OBJECTS (getgc)
-- ============================================================
-- Required to boot: session + EndpointsClient.
-- Optional (best-effort, non-blocking): LobbyServiceClient (exists only when
-- in the lobby — never present in stage matches; locking it would stall boot
-- by 20s every time the hub is loaded mid-match).
local session, EndpointsClient, LobbyServiceClient

function API.lockRequired(timeoutSec)
    local t0 = tick()
    while tick() - t0 < (timeoutSec or 5) do
        for _, t in ipairs(getgc(true)) do
            if type(t) == "table" then
                if not session
                    and rawget(t, "collection") and rawget(t, "_stats")
                    and rawget(t, "inventory") and rawget(t, "player") == LocalPlayer then
                    session = t
                end
                if not EndpointsClient
                    and type(rawget(t, "invoke_server")) == "function"
                    and rawget(t, "ENDPOINT_FOLDER") then
                    EndpointsClient = t
                end
                if session and EndpointsClient then return end
            end
        end
        task.wait(0.1)
    end
end
API.lockRequired(5)
if not (session and EndpointsClient) then
    warn("[ACHub] FAIL: session/EndpointsClient не найден. Зайди в лобби, подожди 5+ сек.")
    return
end
