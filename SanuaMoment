    if not story then return nil end
    -- Prefer one already owned by us
    for _, m in ipairs(story:GetChildren()) do
        local owner = m:FindFirstChild("Owner")
        if owner and owner:IsA("ObjectValue") and owner.Value == LocalPlayer then
            return m
