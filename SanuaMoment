    local defaultWorldRaw = findWorldForLevel(_AC.RaidLevel)
    if not defaultWorldRaw or not raidCatalog[defaultWorldRaw] then
        defaultWorldRaw = next(raidCatalog)
    end
    local defaultWorldPretty = defaultWorldRaw and raidWorldPretty(defaultWorldRaw)
                               or worldOptions[1]
    -- Make sure pretty matches one we built (handle dedup-suffix case)
    if defaultWorldRaw then
        for p, r in pairs(worldP2R) do
            if r == defaultWorldRaw then defaultWorldPretty = p; break end
        end
    end

