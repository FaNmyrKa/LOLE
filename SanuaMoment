local function getOwnedUnits()
    if not session.collection then return {} end
    local cpd = session.collection.collection_profile_data
    return (cpd and cpd.owned_units) or {}
end
local function getUnitConfig(id) return id and Units and Units[id] or nil end
local function getRarity(u) local c = getUnitConfig(u and u.unit_id); return c and c.rarity end

local function snapshotOwned()
    local s = {}; for uuid in pairs(getOwnedUnits()) do s[uuid] = true end; return s
end
local function diffNewUnits(snap)
    local n = {}; for uuid, u in pairs(getOwnedUnits()) do if not snap[uuid] then table.insert(n, u) end end; return n
end
local function shouldAutoSell(u)
    if not u or u._locked then return false end
    if u.equipped_slot and tonumber(u.equipped_slot) and tonumber(u.equipped_slot) > 0 then return false end
    if type(u.traits) == "table" and #u.traits > 0 then return false end
    local r = getRarity(u)
    if r == "Rare"      then return u.shiny and _AC.AutoSellRareShiny      or (not u.shiny) and _AC.AutoSellRare end
    if r == "Epic"      then return u.shiny and _AC.AutoSellEpicShiny      or (not u.shiny) and _AC.AutoSellEpic end
    if r == "Legendary" then return u.shiny and _AC.AutoSellLegendaryShiny or (not u.shiny) and _AC.AutoSellLegendary end
    return false
end
