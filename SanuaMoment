function API.getStatsFolder()
    if not (session and session.player) then return nil end
    local ok, f = pcall(function() return session.player:FindFirstChild("_stats") end)
    return ok and f or nil
end

function API.readStatNumber(name)
    local f = API.getStatsFolder()
    if not f then return nil end
    local stat = f:FindFirstChild(name)
    if not stat then return nil end
    local ok, v = pcall(function() return stat.Value end)
    return (ok and type(v) == "number") and v or nil
end

