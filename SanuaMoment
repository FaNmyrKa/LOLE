-- 14b. DUNGEON (Roguelike / Expedition)
-- ============================================================
-- Endpoints used:
--   request_start_dungeon(gamemode, branch, node)  — direct start from lobby.
--                                                   Server reserves instance +
--                                                   teleports — no lobby join.
--   set_game_finished_vote("Replay", nil, {selectedNodeBranch, selectedNode})
--                                                 — pick next node mid-run.
--   FetchDungeonShop / dungeon_buy_shop(idx)      — relic shop.
--   request_reset_dungeon(gamemode)                — wipe progress (1h cd).
--
-- Modes (from Levels_Jojo, both have DungeonLevel field):
--   Roguelike  → "_JojosMode1"   (full roguelike, has RelicShop)
--   Expedition → "_NoShopMode1"  (no shop, expedition flow)
--
-- "Cards" mode (JojoEvent_Cards) is a normal raid via _MATCHMAKING — handled
-- by the existing Raid tab, NOT here.

local DUNGEON_GAMEMODE_MAP = {
    Roguelike  = "_JojosMode1",   -- with shop, full roguelike
    Expedition = "_NoShopMode1",  -- no shop
}

-- Cached service refs (lazy-loaded via getgc)
local _DungeonServiceCore

local function getDungeonServiceCore()
    if _DungeonServiceCore then return _DungeonServiceCore end
    for _, t in ipairs(getgc(true)) do
        if type(t) == "table"
           and rawget(t, "ITEMS")
           and type(rawget(t, "FetchDungeonData")) == "function"
           and type(rawget(t, "GetShopMulti")) == "function" then
            _DungeonServiceCore = t
            return t
        end
    end
    return nil
end

-- Predict node type using server's seed formula (see DungeonServiceCore.FetchDungeonData).
-- Options array order matters: the Random:NextInteger(1,#Options) pick must match.
local DUNGEON_NODE_OPTIONS = { "Normal", "Unknown", "Elite", "merchant", "campfire", "treasure" }

local function predictDungeonNodeType(gamemode, branch, node)
    if not (LevelNodes and LevelNodes[gamemode]) then return nil end
    local lvlNode = LevelNodes[gamemode].Nodes
                    and LevelNodes[gamemode].Nodes[branch]
                    and LevelNodes[gamemode].Nodes[branch][node]
    if not lvlNode then return nil end
    if lvlNode.FinalNode   then return "Boss"   end
    if lvlNode.LinkingNode then return "Linker" end
    if lvlNode.Type and lvlNode.Type ~= "Normal" then return lvlNode.Type end
    local data = session._stats and session._stats._GamemodeData
                 and session._stats._GamemodeData[gamemode]
    if not (data and data.CurrentSeed) then return "Normal" end
    local depth = node or data.CurrentDepth or 1
    local rng = Random.new((data.CurrentSeed * depth + branch) / 1.45)
    return DUNGEON_NODE_OPTIONS[rng:NextInteger(1, #DUNGEON_NODE_OPTIONS)]
end

-- Get all nodes that pass HasRoomUnlocked client-side check.
-- HasRoomUnlocked returns: (selectable, unlockable, already_cleared)
-- We filter to: selectable AND not already_cleared (matches in-game UI behavior).
local function getSelectableDungeonNodes(gamemode)
    local out = {}
    if not (LevelNodes and LevelNodes[gamemode] and LevelNodes[gamemode].Nodes) then return out end
    local svc = getDungeonServiceCore()
    if not svc then return out end

    for branch, column in pairs(LevelNodes[gamemode].Nodes) do
        for nodeIdx, _ in pairs(column) do
            local ok, sel, _unlockable, cleared = pcall(svc.HasRoomUnlocked, session, gamemode, branch, nodeIdx)
            if ok and sel and not cleared then
                table.insert(out, {
                    branch = branch,
                    node   = nodeIdx,
                    type   = predictDungeonNodeType(gamemode, branch, nodeIdx) or "Normal",
                })
            end
        end
    end
    return out
end

-- Pick best node by user priority weights.
local function pickBestDungeonNode(gamemode)
    local nodes = getSelectableDungeonNodes(gamemode)
    if #nodes == 0 then return nil end

    local prio = _AC.DungeonNodePriority or {}
    table.sort(nodes, function(a, b)
        return (prio[a.type] or 0) > (prio[b.type] or 0)
    end)
    return nodes[1]
end

-- Direct dungeon start: server creates reserved instance and teleports.
-- For fresh runs (no _GamemodeData yet) defaults to (branch=1, node=1).
-- For existing progress, uses pickBestDungeonNode to resume at preferred node.
local function joinDungeon()
    local gamemode = DUNGEON_GAMEMODE_MAP[_AC.DungeonMode]
    if not gamemode then return false, "unknown mode: " .. tostring(_AC.DungeonMode) end
    if not Loader.IsLobby then return false, "must be in lobby" end

    -- Decide branch + node
    local branch, node = 1, 1
    local data = session._stats and session._stats._GamemodeData
                 and session._stats._GamemodeData[gamemode]
    if data and data.UnlockedPaths and next(data.UnlockedPaths) then
        local pick = pickBestDungeonNode(gamemode)
        if pick then
            branch, node = pick.branch, pick.node
        end
    end

    local ok, res = API.invoke("request_start_dungeon", gamemode, branch, node)
    if not ok then return false, "request_start_dungeon errored" end
    return true, { gamemode = gamemode, branch = branch, node = node, result = res }
end

-- Auto pick & continue from map mid-run (after wave clear).
local function autoPickDungeonNode()
    local lvld = Loader.LevelData
    if not (lvld and lvld.DungeonLevel and lvld.DungeonLevel._Gamemode) then return false end
    local gamemode = lvld.DungeonLevel._Gamemode

    local pick = pickBestDungeonNode(gamemode)
    if not pick then return false, "no selectable nodes" end

    API.invoke("set_game_finished_vote", "Replay", nil, {
        selectedNodeBranch = pick.branch,
        selectedNode       = pick.node,
    })
    return true, pick
end

-- Auto buy dungeon shop using per-item weights (0-100).
-- Algorithm:
--   1. FetchDungeonShop returns array of {id=...} entries.
--   2. Filter to entries with weight > 0.
--   3. Sort by weight DESC.
--   4. Walk sorted list; for each: if affordable (balance - cost >= MinCurrency)
--      → buy. Otherwise skip and continue (so cheaper higher-weight runs first,
--      but if too expensive we still try next-highest weight, which may be
--      cheaper). This gives "couldn't buy X (weight 90), bought Y (weight 70)"
--      behavior the user asked for.
local function autoBuyDungeonShop()
    local lvld = Loader.LevelData
    if not (lvld and lvld.RelicShop) then return false, "no RelicShop on this level" end
    local svc = getDungeonServiceCore()
    if not svc then return false, "DungeonServiceCore not found in getgc" end

    local currencyId = lvld.RelicShop.Currency
    local gamemode   = lvld.DungeonLevel and lvld.DungeonLevel._Gamemode
    local mult       = 1
    pcall(function()
        if gamemode then mult = svc.GetShopMulti(session, gamemode) or 1 end
    end)

    local ok, shop = API.invokeT("FetchDungeonShop", 4)
    if not ok or type(shop) ~= "table" then return false, "FetchDungeonShop failed" end

    local weights = _AC.DungeonShopWeights or {}
    local minKeep = _AC.DungeonShopMinCurrency or 0

    -- Build candidate list: { idx, id, cost, name, weight }
    local candidates = {}
    for idx, entry in pairs(shop) do
        if type(entry) == "table" and entry.id then
            local w = weights[entry.id] or 0
            if w > 0 then
                local def = svc.ITEMS[entry.id]
                if def and def.cost then
                    table.insert(candidates, {
                        idx    = idx,
                        id     = entry.id,
                        cost   = math.ceil(math.ceil(def.cost) * mult),
                        name   = def.name or entry.id,
                        weight = w,
                    })
                end
            end
        end
    end

    -- Sort by weight DESC, then by cost ASC (cheapest of same weight first)
    table.sort(candidates, function(a, b)
        if a.weight ~= b.weight then return a.weight > b.weight end
        return a.cost < b.cost
    end)

    local function balance()
        local b = 0
        pcall(function() b = session.inventory:get_number_of_owned_item(currencyId) or 0 end)
        return b
    end

    local bought = {}
    for _, c in ipairs(candidates) do
        local bal = balance()
        if bal - c.cost >= minKeep then
            local okBuy, res = API.invoke("dungeon_buy_shop", c.idx)
            if okBuy and res ~= false then
                table.insert(bought, ("%s (w%d)"):format(c.name, c.weight))
                task.wait(0.3)
            end
            -- if server rejects, just continue — don't retry same idx (it might be stale)
        end
        -- if can't afford: skip, try next (might be cheaper)
    end
    return true, bought
end

