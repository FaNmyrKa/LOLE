    local function watchResultsUI()
        if resultsConn then return end
        local pg = LocalPlayer:FindFirstChild("PlayerGui")
        if not pg then return end
        local rui = pg:FindFirstChild("ResultsUI")
        if not rui then return end
        resultsConn = rui:GetPropertyChangedSignal("Enabled"):Connect(function()
            if rui.Enabled then
                macroStopAllSync("rewards screen")
            end
        end)
    end

    local function dropResultsConn()
        if resultsConn then
            pcall(function() resultsConn:Disconnect() end)
            resultsConn = nil
        end
    end

    while getgenv()._ACHubRunning do
        -- Wrap iteration in pcall so a transient error (e.g. workspace reload
        -- during teleport) doesn't kill the monitor and break replay handling.
        pcall(function()
            local inStage = isInStage()
            local started = isGameStarted()
            local wave    = getWaveNum()

            -- Stage enter/leave transitions
            if inStage ~= lastInStage then
                voteStartFiredForMatch = false
                lastWave = 0
                if inStage then watchResultsUI() else dropResultsConn() end
                lastInStage = inStage
            end

            -- Single-fire vote_start: only when AutoStart toggle on AND game's
            -- own autostart setting is OFF (otherwise the game vote-starts).
            if inStage and not started and _AC.AutoStart and not voteStartFiredForMatch then
                if not getGameAutostartSetting() and not isVoteFinished() then
                    API.invoke("vote_start")
                    voteStartFiredForMatch = true
                end
            end

            -- PRIMARY trigger: GameStarted false → true
            if started ~= lastStarted then
                if started then
                    if _AC.MacroLoop and Macro and not Macro.playing
                       and #_AC.MacroData > 0 then
                        API.notify("Game started — playing macro: "
                              .. (_AC.MacroName ~= "" and _AC.MacroName or "(unnamed)"))
                        macroPlay()
                    end
                    if Macro and Macro.recording and not Macro.rec_start_t then
                        Macro.rec_start_t = tick()
                        Macro.diag.session_started_at = tick()
                        API.notify("Recording timer started")
                    end
                else
                    -- Match ended (GameStarted true → false). Stop playback +
                    -- recording. Play Macro toggle stays ON (armed for replay).
                    -- Re-arm vote_start so it fires again on the next match
                    -- (replay flow stays in-stage, no stage-leave to reset on).
                    voteStartFiredForMatch = false
                    if Macro and Macro.playing then macroStop() end
                    if Macro and Macro.recording then
                        macroStopRecord()
                        pcall(function() MacLib.Options["MacroRecordToggle"]:UpdateState(false) end)
                    end
                end
                lastStarted = started
            end

            -- BACKUP trigger: wave_num reset (>1 → 1) — handles replays where
            -- GameStarted somehow stays true (rare, but observed). Re-arms
            -- macro playback if armed and not currently playing.
            if started and wave == 1 and lastWave > 1 then
                voteStartFiredForMatch = false  -- new match → re-arm vote_start
                if _AC.MacroLoop and Macro and not Macro.playing
                   and #_AC.MacroData > 0 then
                    API.notify("Replay detected (wave reset) — playing macro")
                    macroPlay()
                end
            end
            if wave ~= lastWave then lastWave = wave end
        end)
        task.wait(0.4)
    end
end)

-- ============================================================
-- AUTO SAVE / AUTO LOAD CONFIG
-- ============================================================
function API.doConfigSetup()
    pcall(function() MacLib:SetFolder("ApelHub") end)

    local _configLoading = true
    local _origAS = rawget(MacLib, "AutoSave")
    if type(_origAS) == "function" then
        MacLib.AutoSave = function(self, ...)
            if _configLoading then return end
            return _origAS(self, ...)
        end
    end

    pcall(function()
        if type(MacLib.LoadAutoLoadConfig) == "function" then
            MacLib:LoadAutoLoadConfig()
        end
    end)

    _configLoading = false
    if type(_origAS) == "function" then MacLib.AutoSave = _origAS end
end

task.spawn(function()
    task.wait(0.5)
    pcall(API.doConfigSetup)
end)

