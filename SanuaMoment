            local function typeStr(v)
                local t = type(v)
                if t == "table" then
                    local n = 0; for _ in pairs(v) do n = n + 1 end
                    return ("table[%d]"):format(n)
                elseif t == "userdata" then
                    local ok, c = pcall(function() return v.ClassName end)
                    return ok and ("Instance:" .. tostring(c)) or "userdata"
                end
                return t
            end

            local function instanceShallow(inst, maxKids)
                if not inst then return nil end
                local out = { __class = inst.ClassName, __name = inst.Name, children = {} }
                local ok, val = pcall(function() return inst.Value end)
                if ok and val ~= nil then
                    out.Value = type(val) == "userdata" and tostring(val) or val
                end
                local okch, ch = pcall(function() return inst:GetChildren() end)
                if okch and ch then
                    for i, c in ipairs(ch) do
                        if i > (maxKids or 100) then
                            table.insert(out.children, { __truncated = #ch - (maxKids or 100) })
                            break
                        end
                        local cv = nil
                        local okv, vv = pcall(function() return c.Value end)
                        if okv and vv ~= nil then
                            cv = type(vv) == "userdata" and tostring(vv) or vv
                        end
                        table.insert(out.children, {
                            name = c.Name, class = c.ClassName, value = cv,
                        })
                    end
                end
                return out
            end

            local function tableShallow(t, depth, maxN)
                if type(t) ~= "table" then return tostring(t) end
                depth = depth or 0
                maxN = maxN or 60
                local out, n = {}, 0
                for k, v in pairs(t) do
                    n = n + 1
                    if n > maxN then out["..."] = "truncated"; break end
                    local key = tostring(k)
                    if type(v) == "table" then
                        if depth < 1 then out[key] = tableShallow(v, depth + 1, maxN)
                        else out[key] = typeStr(v) end
                    else
