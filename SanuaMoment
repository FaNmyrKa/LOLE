local function isInStage()
    return Loader and not Loader.IsLobby
end

local function getWaveNum()
    local n = workspace:FindFirstChild("_wave_num")
    return n and n.Value or 0
end

local function getWaveTime()
    local n = workspace:FindFirstChild("_wave_time")
    return n and n.Value or 0
end

local function isGameStarted()
    local d = workspace:FindFirstChild("_DATA")
    local g = d and d:FindFirstChild("GameStarted")
    return g and g.Value or false
end

-- Find UnitManager via getgc (cached)
local _unitMgrCache
local function getUnitManager()
    if _unitMgrCache and _unitMgrCache.ClientHandler then return _unitMgrCache end
    for _, v in ipairs(getgc(true)) do
        if type(v) == "table" then
            local ch = rawget(v, "ClientHandler")
            if type(ch) == "table" and type(rawget(ch, "Active")) == "table"
                                    and type(rawget(ch, "LastMovements")) == "table" then
                _unitMgrCache = v
                return v
            end
        end
    end
    return nil
end

-- Returns array of spawned-unit IDs (keys of UnitManager.ClientHandler.Active)
-- These IDs are <unit_uuid><index_suffix> like "f6597...c1773"
local function getActiveUnitIds()
    local out = {}
    local um = getUnitManager()
    if um and um.ClientHandler and um.ClientHandler.Active then
        for name, _ in pairs(um.ClientHandler.Active) do
            table.insert(out, name)
        end
    end
    return out
end

-- Get equipped slot uuids: { slot_index = unit_uuid, ... }
local function getEquippedSlots()
    if not (session and session.collection) then return {} end
    local ok, slots = pcall(function()
        return session.collection:get_used_equipped_slots()
    end)
    if not ok or type(slots) ~= "table" then return {} end
    -- Normalize: ensure structure is {[slot]=uuid}
    local out = {}
    for k, v in pairs(slots) do
        local uuid = nil
        if type(v) == "string" then uuid = v
        elseif type(v) == "table" then uuid = v.uuid or v.unit_uuid
        end
        if uuid then out[k] = uuid end
    end
    return out
end

