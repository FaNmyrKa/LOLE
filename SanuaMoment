-- 6. SAFE INVOKE
-- ============================================================
function API.invoke(name, ...)
    local args = {...}
    local ok, res = pcall(function()
        return EndpointsClient.invoke_server(name, table.unpack(args))
    end)
    if not ok then warn(("[ACHub] %s FAIL: %s"):format(name, tostring(res):sub(1, 120))) end
    return ok, res
end

-- timeout-protected variant (для зависающих endpoint'ов)
function API.invokeT(name, timeoutSec, ...)
    local args = {...}
    local done, ok, res = false, nil, nil
    task.spawn(function()
        ok, res = pcall(function()
            return EndpointsClient.invoke_server(name, table.unpack(args))
        end)
        done = true
    end)
    local t0 = tick()
    while not done and (tick() - t0) < (timeoutSec or 4) do task.wait(0.05) end
    if not done then return false, "TIMEOUT" end
    return ok, res
end

