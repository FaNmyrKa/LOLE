-- Check: any indexed-but-not-claimed unit?
local function hasClaimableIndex()
    local cpd = session.collection and session.collection.collection_profile_data
    if not cpd then return false end
    local indexed = cpd.indexed_units or {}
    local claimed = cpd.claimed_units or {}
    for id, unit in pairs(Units or {}) do
        if unit.id and not unit.spawn_cap and indexed[id] and not claimed[id] then
            -- skip Mythic/Exclusive/Secret/Crusader unless evolved (per decompile L4465)
            if unit.rarity == "Mythic" or unit.rarity == "Exclusive"
               or unit.rarity == "Secret" or unit.rarity == "Crusader" then
                if unit.evolved then return true end
            else
                return true
            end
        end
    end
    return false
end

-- Check: any BP tier ready to claim?
local function hasClaimableBP()
    if not BattlePass then return false end
    local s = session._stats or {}
    local bp_data = s.battlepass_data1
    local current_id = GameplaySettings and GameplaySettings.CURRENT_BATTLEPASS
    if not (bp_data and current_id and bp_data[current_id] and BattlePass[current_id]) then return false end
    local cur = bp_data[current_id]
    local def = BattlePass[current_id]
    local xp = cur.xp or 0
    local now = os.time()
    local claimed_normal  = cur.claimed_tiers and cur.claimed_tiers.normal  or {}
    local claimed_premium = cur.claimed_tiers and cur.claimed_tiers.premium or {}
    for i = 1, def.total_tiers or 0 do
        local tier = def.tiers and def.tiers[tostring(i)]
        if tier and now >= (tier._unlock_time or 0) and xp >= (tier.xp_required or 0) then
            if not claimed_normal[tostring(i)] then return true end
            if cur.has_premium and not claimed_premium[tostring(i)] then return true end
        end
    end
    return false
end

local function isQuestReady(q)
    if not q or not q.quest_info or not q.quest_info.quest_class then return false end
    local cls = q.quest_info.quest_class
    if cls.class == "test_free" then return true end
    if cls.class == "daily_complete" then
        local qh = session.quest_handler
        if not (qh and type(qh.get_quests_by_type) == "function") then return false end
        local ok, dailies = pcall(qh.get_quests_by_type, qh, "daily")
        if ok and type(dailies) == "table" then return #dailies <= 1 end
        return false
    end
    if cls.amount and q.quest_progress then
        return (q.quest_progress.amount or 0) >= (cls.amount or 1)
    end
    return false
end

local function countReadyQuests()
    local qh = session.quest_handler and session.quest_handler.quest_profile_data
    local list = qh and qh.quests
    if type(list) ~= "table" then return 0 end
    local n = 0
    for _, q in pairs(list) do
        if isQuestReady(q) then n = n + 1 end
    end
    return n
end

