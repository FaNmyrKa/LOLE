-- Auto-detect raid levels grouped by world.
-- Returns: { worldName = { {id="Sakamato_Raid_1", name="Raid 1"}, ... }, ... }
-- World is parsed from levelId pattern "<World>_Raid_<N>".
local function getRaidsByWorld()
    local out = {}
    local seen = {}
    local function add(id)
        if type(id) ~= "string" or seen[id] then return end
        local world = id:match("^(.-)_Raid_") or id:match("^(.-)_RAID_")
        if not world or world == "" then return end
        seen[id] = true

        local num = id:match("_Raid_(%d+)") or id:match("_RAID_(%d+)") or "?"
        local name = "Raid " .. num
        -- Prefer explicit display name from Levels module if present
        if Levels and Levels[id] and type(Levels[id]) == "table" then
            local def = Levels[id]
            name = def.name or def.display_name or def.DisplayName or name
        end

        out[world] = out[world] or {}
        table.insert(out[world], { id = id, name = name, num = tonumber(num) or 0 })
    end

    if Levels then
        for id, def in pairs(Levels) do
            if type(id) == "string"
               and (id:find("_Raid_") or id:find("_RAID_")
                    or (type(def) == "table" and def._gamemode == "raid")) then
                add(id)
            end
        end
    end
    if Worlds then
        for _, world in pairs(Worlds) do
            if type(world) == "table" and type(world.levels) == "table" then
                for _, lvl in pairs(world.levels) do
                    if type(lvl) == "table" and lvl.id then add(lvl.id) end
                end
            end
        end
    end

    -- Sort each world's levels by raid number
    for _, list in pairs(out) do
        table.sort(list, function(a, b) return a.num < b.num end)
    end
    return out
end

