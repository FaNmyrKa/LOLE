            -- Pick currently selected if it belongs to this world, else first
            local pickPretty
            for pname, id in pairs(p2r) do
                if id == _AC.RaidLevel then pickPretty = pname; break end
            end
            if not pickPretty then
                pickPretty = opts[1]
                _AC.RaidLevel = p2r[pickPretty] or ""
            end
            pcall(function() raidLevelDropdown:UpdateSelection(pickPretty) end)
        end
