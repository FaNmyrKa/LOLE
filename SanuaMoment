-- game_finished listener — для auto-next gate (только в стейдже)
local _gfConn
local function setupGateAutoNext()
    if _gfConn then pcall(function() _gfConn:Disconnect() end); _gfConn = nil end
    local s2c = RS.endpoints:FindFirstChild("server_to_client")
    local r   = s2c and s2c:FindFirstChild("game_finished")
    if not r then return end
    _gfConn = r.OnClientEvent:Connect(function()
        if not _AC.AutoGate or not _AC.GateLoop then return end
        task.wait(_AC.GateDelay)
        if not _AC.AutoGate then return end
        local g = (_AC.ForceGate > 0) and _AC.ForceGate or pickBestGate()
