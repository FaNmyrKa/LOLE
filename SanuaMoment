    local function buildLevelOptions(worldRaw)
        local entries = raidCatalog[worldRaw] or {}
        local list, p2r = {}, {}
        for _, e in ipairs(entries) do
            local label = e.name
            if p2r[label] then label = label .. " · " .. e.id end
            p2r[label] = e.id
            table.insert(list, label)
        end
        if #list == 0 then list = { "(no levels)" } end
        return list, p2r
    end

