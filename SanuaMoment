    local CODES_URL = "https://raw.githubusercontent.com/HOSTI1315/Opensurs/refs/heads/main/CodeAC.lua"
    local REDEEMED_FILE = RootFolder .. "/AC_redeemed_codes.json"

    local function loadRedeemedSet()
        local set = {}
        if isfile and isfile(REDEEMED_FILE) then
            local ok, raw = pcall(readfile, REDEEMED_FILE)
            if ok then
                local ok2, data = pcall(HttpService.JSONDecode, HttpService, raw)
                if ok2 and type(data) == "table" then
                    for _, c in ipairs(data) do set[c] = true end
                end
            end
        end
        return set
    end

    local function saveRedeemedSet(set)
        if not writefile then return end
        local list = {}
        for c in pairs(set) do table.insert(list, c) end
        table.sort(list)
        pcall(writefile, REDEEMED_FILE, HttpService:JSONEncode(list))
    end

    -- Fetch code list from URL — extracts strings from `local codes = { ... }` block
    local function fetchCodeList()
        local body
        local req = (syn and syn.request) or (http and http.request) or http_request or request
        if req then
            local ok, res = pcall(function()
                return req({ Url = CODES_URL, Method = "GET" })
            end)
            if ok and type(res) == "table" then
                body = res.Body or res.body
            end
        end
        if not body or body == "" then
            local ok2, b2 = pcall(function() return game:HttpGet(CODES_URL, true) end)
            if ok2 then body = b2 end
        end
        if not body or body == "" then return nil, "fetch failed" end

        -- Extract every "..." string literal from the file
        local out = {}
        for code in body:gmatch('"([^"\r\n]+)"') do
            -- skip empty + dedup
            if code ~= "" then table.insert(out, code) end
        end
        if #out == 0 then return nil, "no codes parsed" end
        return out
    end

    -- State: cached code list + status
    local codeState = {
        list           = {},  -- fetched codes
        running        = false,
        last_status    = "Idle",
        last_success   = 0,
        last_invalid   = 0,
        last_skipped   = 0,
        total_redeemed = 0,
    }
    -- Load initial counter from file
    do
        local s = loadRedeemedSet()
        local n = 0
        for _ in pairs(s) do n = n + 1 end
