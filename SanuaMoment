-- ============================================================
-- MATCH STATE MONITOR (must be at end — references Macro/macroPlay/macroStop/etc)
-- ============================================================
-- Centralized lifecycle handler. Watches workspace state + PlayerGui to:
--   • Fire vote_start ONCE per match when game-side autostart is off
--     (replaces previous spam-loop that fired every 1.5s)
--   • Auto-play loaded macro the moment GameStarted flips true
--   • Auto-stop playback/recording at match end (ResultsUI shown OR
--     GameStarted true→false), keeping toggle UI in sync.
--
-- Game state references (verified in decompile):
--   workspace._DATA.GameStarted                — BoolValue, line 16308
--   workspace._DATA.VoteStart.VotingFinished   — BoolValue, line 63118
--   player._settings.autostart                 — BoolValue, line 63121
--   PlayerGui.ResultsUI (.Enabled)             — ScreenGui, line 16246/16253

local function getGameAutostartSetting()
    local ok, v = pcall(function()
        local s = LocalPlayer:FindFirstChild("_settings")
        local a = s and s:FindFirstChild("autostart")
        return a and a.Value
    end)
    return ok and v or false
end

local function isVoteFinished()
    local d = workspace:FindFirstChild("_DATA")
    local vs = d and d:FindFirstChild("VoteStart")
    local vf = vs and vs:FindFirstChild("VotingFinished")
    return vf and vf.Value or false
end

local function macroStopAllSync(reason)
    -- Stops playback + recording at match end. Play Macro toggle stays ON
    -- (armed for next match). Record toggle DOES flip off — recording is
    -- a one-shot per session.
    if Macro and Macro.playing then
        macroStop()
        if reason then API.notify("Playback stopped: " .. reason) end
    end
    if Macro and Macro.recording then
        macroStopRecord()
        pcall(function() MacLib.Options["MacroRecordToggle"]:UpdateState(false) end)
        if reason then API.notify("Recording stopped: " .. reason) end
    end
end

