-- ----- Balance snapshot (for delta calculation in results) -----
local function readNumberValue(obj)
    if not obj then return 0 end
    local ok, v = pcall(function() return obj.Value end)
    return (ok and type(v) == "number") and v or 0
end

local function getCurrentBalance()
    local f = API.getStatsFolder()
    return {
        gold     = readNumberValue(f and f:FindFirstChild("gold_amount")),
        gems     = readNumberValue(f and f:FindFirstChild("gem_amount")),
        trophies = readNumberValue(f and f:FindFirstChild("trophies")),
    }
end

-- Get owned amount for a item id (uses session.inventory)
local function getItemAmount(itemId)
    if not (session and session.inventory and session.inventory.get_number_of_owned_item) then
        return 0
    end
    local ok, n = pcall(function()
        return session.inventory:get_number_of_owned_item(itemId)
    end)
    return (ok and type(n) == "number") and n or 0
end

-- Snapshot ALL inventory items (so we can compute deltas for any item that drops)
local function snapshotInventory()
    local out = {}
    if not (session and session.inventory and session.inventory.inventory_profile_data) then
        return out
    end
    -- Try to read full inventory map
    local ipd = session.inventory.inventory_profile_data
    if type(ipd) == "table" and type(ipd.items) == "table" then
        for itemId, _ in pairs(ipd.items) do
            out[itemId] = getItemAmount(itemId)
        end
    end
    return out
end

-- Snapshot of entire wallet+inventory taken at match start
-- Triggered on _DATA.GameStarted = true (transition to in-stage)
local _matchStartSnapshot = nil

local function captureMatchStartSnapshot()
    _matchStartSnapshot = {
        balance   = getCurrentBalance(),
        inventory = snapshotInventory(),
        time      = tick(),
    }
end

-- Watcher for GameStarted = true → snapshot balance + reset webhook guard.
-- Also fires GameStarted=false fallback webhook (final safety net) if neither
-- ResultsUI nor game_finished triggered a webhook for this match.
task.spawn(function()
    local lastStarted = false
    while getgenv()._ACHubRunning do
        if isInStage() then
            local started = isGameStarted()
            if started and not lastStarted then
                -- New match started — reset webhook guard
                _webhookSentForMatch = false
                -- Wait a tick for inventory to be in steady state
                task.wait(0.5)
                captureMatchStartSnapshot()
            elseif (not started) and lastStarted then
                -- Match ended (true→false). Give ResultsUI / game_finished
                -- a generous window to fire first, then send minimal fallback.
                -- Skip if player left stage in the meantime (= leave, not match end).
                task.delay(8, function()
                    if not isInStage() then return end
                    if not _webhookSentForMatch then
                        sendFallbackEndWebhook("GameStarted=false")
                    end
                end)
            end
            lastStarted = started
        else
            -- Left stage entirely (back to lobby etc). Reset state.
            lastStarted = false
        end
        task.wait(1)
    end
end)

-- Fallback 1: server-side game_finished event. Fires on every match end
-- regardless of how (force end, victory, defeat, time-out). If ResultsUI
-- doesn't appear within 5s of this event, send a minimal webhook.
task.spawn(function()
    -- Wait for endpoints folder to be ready
    local s2c
    while getgenv()._ACHubRunning do
        s2c = RS:FindFirstChild("endpoints")
        s2c = s2c and s2c:FindFirstChild("server_to_client")
        if s2c and s2c:FindFirstChild("game_finished") then break end
        task.wait(1)
    end
    if not getgenv()._ACHubRunning then return end
    local gfRemote = s2c:FindFirstChild("game_finished")
    if not gfRemote then return end
    gfRemote.OnClientEvent:Connect(function()
        -- Only relevant if we're actually in a stage match
        if not isInStage() then return end
        task.delay(5, function()
            -- Skip if player left stage during the wait window (= leave)
            if not isInStage() then return end
            if not _webhookSentForMatch then
                sendFallbackEndWebhook("game_finished (no ResultsUI)")
            end
        end)
    end)
end)

-- Helper: snapshot equipped units BEFORE the match (for "Equip units" section)
-- Stored once per match (when GameStarted appears)
local _matchEquippedUnits = {}

local function captureEquippedUnits()
    local out = {}
    local equipped = getEquippedSlots()  -- {[slot] = unit_uuid}
    if not (session and session.collection) then return out end

    -- Sort by slot index so output is [1][2][3]...
    local slots = {}
    for k in pairs(equipped) do table.insert(slots, k) end
    table.sort(slots, function(a, b)
        local na, nb = tonumber(a) or 0, tonumber(b) or 0
        return na < nb
    end)

    for i, slot in ipairs(slots) do
        local uuid = equipped[slot]
        local unit = nil
        pcall(function()
            unit = session.collection:get_unit_by_uuid(uuid)
        end)
        local unitId = unit and unit.unit_id or "?"
        local xp     = unit and unit.xp or 0
        -- look up display name from Units data
        local displayName = unitId
        if Units and Units[unitId] then
            displayName = Units[unitId].name or Units[unitId].OverrideName or unitId
        end
        -- compute level
        local level = 1
        pcall(function()
            -- LevelService formula: level = floor(log(xp/1000+1)/0.0769610411361284) + 1
            if xp and xp > 0 then
                level = math.floor(math.log(xp/1000 + 1) / 0.0769610411361284) + 1
            end
        end)
        table.insert(out, {
            slot      = tonumber(slot) or i,
            unit_id   = unitId,
            name      = displayName,
            level     = level,
            xp        = xp,
        })
    end
    return out
end

-- Hook into start watcher
local _origCaptureMatchStartSnapshot = captureMatchStartSnapshot
captureMatchStartSnapshot = function()
    _origCaptureMatchStartSnapshot()
    _matchEquippedUnits = captureEquippedUnits()
end

-- Helper: safe text read from a TextLabel-like instance under a path
local function readText(obj, ...)
    if not obj then return nil end
    local cur = obj
    for _, name in ipairs({...}) do
        if not cur then return nil end
        cur = cur:FindFirstChild(name)
    end
    if cur and (cur:IsA("TextLabel") or cur:IsA("TextBox") or cur:IsA("TextButton")) then
        return cur.Text
    end
    return nil
end

-- Parse the ResultsUI structure into a snapshot table
local function parseResultsUI()
    local pgui = LocalPlayer:FindFirstChild("PlayerGui")
    local ui   = pgui and pgui:FindFirstChild("ResultsUI")
    local holder = ui and ui:FindFirstChild("Holder")
    if not holder then return nil end

    local snap = {
        timestamp = os.time(),
        title     = readText(holder, "Banner", "Title")              or "?",
        playtime  = readText(holder, "Middle", "PlayTime", "ValueText") or "?",
        rewards   = {},
        units     = {},

        -- Wave info — from workspace at moment of capture
        wave_current = getWaveNum(),

        -- Stage info (level + difficulty when available)
        stage     = nil,
        stage_act = nil,
        difficulty = nil,
    }

    -- Rewards: Holder.Rewards.Reward[*Item].name + .OwnedAmount
    local rewardsFolder = holder:FindFirstChild("Rewards")
    local rewardRoot    = rewardsFolder and rewardsFolder:FindFirstChild("Reward")
    if rewardRoot then
        for _, item in ipairs(rewardRoot:GetChildren()) do
            local nm  = readText(item, "name")
            local amt = readText(item, "OwnedAmount")
            if nm or amt then
                -- Try to parse amount as number for arithmetic (it's a string label)
                local amtNum = tonumber((amt or ""):gsub("[%s,+]", "")) or 0
                table.insert(snap.rewards, {
                    item   = item.Name,
                    name   = nm  or "?",
                    amount = amt or "?",
                    n      = amtNum,
                })
            end
        end
    end

    -- Unit XP results: Holder.XPResults.Main.Wrapper.Main:GetChildren()
    local xpRes = holder:FindFirstChild("XPResults")
    local main  = xpRes and xpRes:FindFirstChild("Main")
    local wrap  = main  and main:FindFirstChild("Wrapper")
    local main2 = wrap  and wrap:FindFirstChild("Main")
    if main2 then
        for _, ch in ipairs(main2:GetChildren()) do
            local unitName = readText(ch, "NewFrame", "UnitName")
            local lvl      = readText(ch, "Exp", "LevelFrame", "Level")
            if unitName or lvl then
                table.insert(snap.units, {
                    container = ch.Name,
                    unit      = unitName or "?",
                    level     = lvl      or "?",
                })
            end
        end
    end

    -- Capture current balance & compute delta vs match-start
    local current = getCurrentBalance()
    snap.balance = current
    if _matchStartSnapshot then
        local before = _matchStartSnapshot.balance
        snap.delta = {
            gold     = current.gold     - before.gold,
            gems     = current.gems     - before.gems,
            trophies = current.trophies - before.trophies,
        }
    end

    -- Equipped units snapshot taken at match start
    snap.equipped = _matchEquippedUnits or {}

    return snap
end

-- Format a number with comma separators: 1234567 → "1,234,567"
local function fmtNum(n)
    if type(n) ~= "number" then return tostring(n) end
    local s = tostring(math.floor(n + 0.5))
    -- insert commas every 3 digits from the right
    local result = s:reverse():gsub("(%d%d%d)", "%1,"):reverse()
    result = result:gsub("^,", "")
    return result
end

local function fmtDelta(n)
    if type(n) ~= "number" or n == 0 then return "0" end
    return (n > 0 and "+" or "") .. fmtNum(n)
end

-- Optional webhook for results — premium-style embed
local function buildResultsEmbed(snap)
    local titleLower = (snap.title or ""):lower()
    local isWin     = titleLower:find("vict") or titleLower:find("win")
    local resultIco = isWin and "🏆" or "💀"

    local headerFields = {
        { name = "Player", value = LocalPlayer.DisplayName ~= LocalPlayer.Name
                                     and ("%s (@%s)"):format(LocalPlayer.DisplayName, LocalPlayer.Name)
                                     or  ("@%s"):format(LocalPlayer.Name),
          inline = true },
        { name = "Result",   value = resultIco .. " " .. (snap.title or "?"), inline = true },
        { name = "Duration", value = "⏱️ " .. (snap.playtime or "?"),         inline = true },
    }

    local stageLines = {}
    if snap.wave_current and snap.wave_current > 0 then
        table.insert(stageLines, ("**Waves:** %d"):format(snap.wave_current))
    end

    local equipLines = {}
    if snap.equipped and #snap.equipped > 0 then
        for _, u in ipairs(snap.equipped) do
            table.insert(equipLines, ("[%d] %s lvl %d [%s/%s]"):format(
                u.slot, u.name, u.level, fmtNum(u.xp), "5000"))
        end
    end

    local rewardLines = {}
    for _, r in ipairs(snap.rewards or {}) do
        local nameLower = (r.name or ""):lower()
        local total = nil
        if snap.balance then
            if nameLower:find("gold") then total = snap.balance.gold
            elseif nameLower:find("crystal") or nameLower:find("gem") then total = snap.balance.gems
            elseif nameLower:find("trophy") then total = snap.balance.trophies
            end
        end
        if not total then
            local cur = getItemAmount(r.item)
            if cur and cur > 0 then total = cur end
        end
        local prefix = (r.n and r.n > 0) and ("+" .. fmtNum(r.n)) or (r.amount or "?")
        if total then
            table.insert(rewardLines, ("%s %s (%s)"):format(prefix, r.name, fmtNum(total)))
        else
            table.insert(rewardLines, ("%s %s"):format(prefix, r.name))
        end
    end

    local curLines = {}
    if snap.balance then
        table.insert(curLines, ("**Gold:** %s"):format(fmtNum(snap.balance.gold)))
        table.insert(curLines, ("**Crystals:** %s"):format(fmtNum(snap.balance.gems)))
        if snap.balance.trophies and snap.balance.trophies > 0 then
            table.insert(curLines, ("**Trophies:** %s"):format(fmtNum(snap.balance.trophies)))
        end
    end

    local fields = {}
    for _, f in ipairs(headerFields) do table.insert(fields, f) end
    if #stageLines > 0 then
        table.insert(fields, { name = "Stage", value = table.concat(stageLines, "\n"):sub(1, 1024), inline = false })
    end
    if #equipLines > 0 then
        local body = table.concat(equipLines, "\n")
        if #body > 1024 then body = body:sub(1, 1020) .. "..." end
        table.insert(fields, { name = "Equip units", value = body, inline = false })
    end
    if #rewardLines > 0 then
        local body = table.concat(rewardLines, "\n")
        if #body > 1024 then body = body:sub(1, 1020) .. "..." end
        table.insert(fields, { name = "Rewards", value = body, inline = false })
    end
    if #curLines > 0 then
        table.insert(fields, { name = "Currencies", value = table.concat(curLines, "\n"), inline = false })
    end

    return {
        title     = "Anime Crusaders — Match Result",
        color     = isWin and 5763719 or 15548997,
        fields    = fields,
        footer    = { text = "AC Hub" },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ", snap.timestamp),
    }
end

local function sendResultsWebhook(snap)
    local embed = buildResultsEmbed(snap)
    dispatchWebhook("MatchEnd", embed)
end

-- Watch for ResultsUI appearance — single-shot per appearance
local _resultsHandled = false
local _resultsConn
-- Single source of truth for "match-end webhook already sent for this match".
-- Flipped TRUE after any of: ResultsUI parse, game_finished fallback, or
-- GameStarted=false fallback. Reset on new match (GameStarted=true) by
-- Match State Monitor.
local _webhookSentForMatch = false

-- Minimal end-of-match webhook for cases where ResultsUI never appeared
-- (force-end vote, weird server flows, etc).
local function buildFallbackEndEmbed(reason)
    local fields = {
        { name = "Player", value = ("@%s"):format(LocalPlayer.Name), inline = true },
        { name = "Result", value = "⚠ Match ended (no results screen)", inline = true },
        { name = "Trigger", value = reason or "?", inline = true },
    }
    local cur = getCurrentBalance()
    if cur then
        local curLines = {
            ("**Gold:** %s"):format(fmtNum(cur.gold)),
            ("**Crystals:** %s"):format(fmtNum(cur.gems)),
        }
        if cur.trophies and cur.trophies > 0 then
            table.insert(curLines, ("**Trophies:** %s"):format(fmtNum(cur.trophies)))
        end
        table.insert(fields, { name = "Currencies", value = table.concat(curLines, "\n"), inline = false })
    end
    if _matchStartSnapshot then
        local before = _matchStartSnapshot.balance
        local delta = {
            gold     = cur.gold     - before.gold,
            gems     = cur.gems     - before.gems,
            trophies = cur.trophies - before.trophies,
        }
        local dl = {}
        if delta.gold     ~= 0 then table.insert(dl, ("Gold: %s"):format(fmtDelta(delta.gold))) end
        if delta.gems     ~= 0 then table.insert(dl, ("Crystals: %s"):format(fmtDelta(delta.gems))) end
        if delta.trophies ~= 0 then table.insert(dl, ("Trophies: %s"):format(fmtDelta(delta.trophies))) end
        if #dl > 0 then
            table.insert(fields, { name = "Delta this match", value = table.concat(dl, " · "), inline = false })
        end
    end
    return {
        title     = "Anime Crusaders — Match Ended",
        color     = 10070709,  -- gray
        fields    = fields,
        footer    = { text = "AC Hub" },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
    }
end

local function sendFallbackEndWebhook(reason)
    if _webhookSentForMatch then return end
    _webhookSentForMatch = true
    print("[ACHub:Results] Fallback webhook fired ("..tostring(reason)..")")
    dispatchWebhook("MatchEnd", buildFallbackEndEmbed(reason))
end

local function onResultsAppeared()
    if _resultsHandled then return end
    _resultsHandled = true

    print("[ACHub:Results] ResultsUI appeared")
    print(("[ACHub:Results] AutoReplay=%s  AutoNext=%s"):format(
        tostring(_AC.AutoRestartOnResults), tostring(_AC.AutoNext)))

    -- 1) Auto-stop recording IMMEDIATELY (before any waits) — snapshot current state
    --    Only save if at least 1 step recorded.
    if Macro.recording then
        local recorded = #_AC.MacroData
        Macro.recording = false
        _AC.MacroRecording = false
        if recorded > 0 and _AC.MacroName ~= "" then
            if saveMacro(_AC.MacroName, _AC.MacroData) then
                API.notify(("Auto-saved '%s' (%d steps)"):format(_AC.MacroName, recorded))
            end
        elseif recorded > 0 then
            API.notify(("Recording stopped (%d steps, no name to save)"):format(recorded))
        else
            API.notify("Recording stopped (no steps)")
        end
    end

    -- 2) Wait a beat for UI to fill in (rewards animate in)
    task.wait(1.5)

    -- 3) Parse + webhook (only fires once per match thanks to guard)
    local snap = parseResultsUI()
    if snap then
        _AC.ResultsLastSnapshot = snap
        API.notify(("Match: %s · %s"):format(snap.title, snap.playtime))
        print(("[ACHub:Results] %s · time=%s · rewards=%d · units=%d"):format(
            snap.title, snap.playtime, #snap.rewards, #snap.units))
        if not _webhookSentForMatch then
            _webhookSentForMatch = true
            sendResultsWebhook(snap)
        end
    end

    -- 4) Auto Replay (replay current level — mode-aware)
    --    Auto Next   (move to next level if mode supports it)
    --    Mutually exclusive: Auto Replay takes priority.
    if not isInStage() then return end

    -- Read LevelData to decide which vote command applies
    local L = nil
    pcall(function() L = Loader and Loader.LevelData end)

    if _AC.AutoRestartOnResults then
        task.wait(1.0)
        local cmd, extra = "replay", nil
        local actionLabel = "replay"
        local ok = pcall(function()
            if not L then return end
            if L.SpiritInvasion or L.HalloweenEvent or L.WanoEvent then
                cmd = "replay"
            elseif L._gamemode == "infinite_tower" then
                cmd = "next_infinite_tower"
                actionLabel = "next_infinite_tower"
            elseif L.Gate then
                -- Gate replay: server expects replay_gate-equivalent flow but the
                -- normal "replay" works to retry the same gate level.
                -- (The native UI path opens quickgates UI to choose a different gate;
                --  we just replay the current one.)
                cmd = "replay"
            elseif L._owner_player_portal_userid then
                -- Portal: requires a portal item uuid as 3rd arg.
                -- Server matches against current portal owner — try LobbyServiceClient
                -- or session inventory for any "Portals" group item.
                local portalUuid = nil
                pcall(function()
                    if session and session.inventory and session.inventory.inventory_profile_data then
                        local items = session.inventory.inventory_profile_data.items
                        if type(items) == "table" then
                            for uuid, it in pairs(items) do
                                local id = (type(it) == "table") and it.item_id or nil
                                if id and Items and Items[id]
                                       and Items[id].item_group == "Portals" then
                                    portalUuid = uuid
                                    break
                                end
                            end
                        end
                    end
                end)
                if portalUuid then
                    cmd = "replay_portal"
                    extra = portalUuid
                    actionLabel = "replay_portal"
                else
                    -- Can't replay a portal without a portal item — fall through
                    cmd = "replay"
                    actionLabel = "replay (no portal item)"
                end
            else
                cmd = "replay"
            end
        end)
        if not ok then API.notify("Replay decision failed — falling back to replay") end

        if extra ~= nil then
            API.invoke("set_game_finished_vote", cmd, extra)
        else
            API.invoke("set_game_finished_vote", cmd)
        end
        API.notify("Auto Replay: " .. actionLabel)

    elseif _AC.AutoNext then
        task.wait(1.0)
        local mode = nil
        pcall(function()
            if not L then return end
            if L._is_actual_storymode then mode = "next_story"
            elseif L._gamemode == "raid" then mode = "next_raid"
            elseif Worlds and Worlds[L.world] and Worlds[L.world].legend_stage then
                mode = "next_legend"
            elseif L._gamemode == "infinite_tower" then mode = "next_infinite_tower"
            end
        end)
        if mode then
            API.invoke("set_game_finished_vote", mode)
            API.notify("Auto Next: " .. mode)
        else
            API.invoke("set_game_finished_vote", "replay")
            API.notify("Auto Next not available → replay")
        end
    end
end

local function setupResultsWatcher()
    if _resultsConn then return end
    local pgui = LocalPlayer:FindFirstChild("PlayerGui")
    if not pgui then return end

    -- Hook Enabled changes for any ResultsUI that ever appears
    local function hookExisting(child)
        if not (child and child.Name == "ResultsUI" and child:IsA("ScreenGui")) then return end
        -- When new ResultsUI shows up, allow handler to fire again
        _resultsHandled = false
        -- Connect Enabled change
        pcall(function()
            child:GetPropertyChangedSignal("Enabled"):Connect(function()
                if child.Enabled then
                    _resultsHandled = false
                    onResultsAppeared()
                end
            end)
        end)
        -- Also fire if it's already enabled when we discover it
        if child.Enabled then
            task.spawn(function()
                -- small delay so Holder is loaded
                local deadline = tick() + 5
                while tick() < deadline do
                    if child:FindFirstChild("Holder") then break end
                    task.wait(0.1)
                end
                onResultsAppeared()
            end)
        end
    end

    _resultsConn = pgui.ChildAdded:Connect(function(child)
        hookExisting(child)
    end)

    -- Hook anything already there
    for _, ch in ipairs(pgui:GetChildren()) do hookExisting(ch) end

    -- Polling fallback: every 0.5s check if ResultsUI is visible and we haven't handled it
    task.spawn(function()
        while _resultsConn and getgenv()._ACHubRunning do
            local ui = pgui:FindFirstChild("ResultsUI")
            if ui and ui:IsA("ScreenGui") and ui.Enabled and not _resultsHandled then
                onResultsAppeared()
            end
            task.wait(0.5)
        end
    end)
end

-- Start watcher in stage
task.spawn(function()
    while getgenv()._ACHubRunning do
        if isInStage() then
            if not _resultsConn then setupResultsWatcher() end
        else
            if _resultsConn then
                pcall(_resultsConn.Disconnect, _resultsConn)
                _resultsConn = nil
                _resultsHandled = false
            end
        end
        task.wait(2)
    end
end)

