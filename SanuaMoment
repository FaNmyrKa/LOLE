    end

    local function redeemAllCodes()
        if codeState.running then API.notify("Already redeeming"); return end
        if isInStage() then API.notify("Use codes in lobby"); return end
        codeState.running = true
        codeState.last_status = "Fetching list..."

        task.spawn(function()
