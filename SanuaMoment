-- VIP gives 20% discount on EventClover/Selection banners
local function getHatchPrice(bannerId, baseCost)
    local discount = 0
    pcall(function()
        if session._stats.owned_gamepasses
           and session._stats.owned_gamepasses.vip
           and (bannerId == "EventClover" or bannerId == "Selection") then
            discount = 0.2
        end
    end)
    return math.floor(baseCost * (1 - discount) + 0.5)
end

-- Returns: (canAfford, currentBalance, needed, currencyLabel)
-- NEVER blocks summons on parsing errors — if cost can't be determined returns true
local function canAffordSummon(bannerId, amount)
    local ok, result = pcall(function()
        if not Banners or not bannerId or bannerId == "" then return nil end
        local b = Banners[bannerId]
        if not b then return nil end

        local pricePerOne, balance, label

        -- Helper to read NumberValue safely
        local function readVal(inst)
            if not inst then return 0 end
            local ok2, v = pcall(function() return inst.Value end)
            return (ok2 and type(v) == "number") and v or 0
        end

        if b.resource_cost then
            local id = b.resource_cost.id
            pricePerOne = b.resource_cost.amount or 0
            local statsF = API.getStatsFolder()
            local stat = statsF and statsF:FindFirstChild("_resource" .. tostring(id))
            balance = readVal(stat)
            label = tostring(id)
        elseif b.item_cost then
            local id = b.item_cost.item_id
            pricePerOne = b.item_cost.amount or 0
            balance = 0
            pcall(function()
                if session.inventory and session.inventory.get_number_of_owned_item then
                    balance = session.inventory:get_number_of_owned_item(id) or 0
                end
            end)
            label = tostring(id)
        else
            pricePerOne = b.gem_cost or 0
            pricePerOne = getHatchPrice(bannerId, pricePerOne)
            local statsF = API.getStatsFolder()
            local stat = statsF and statsF:FindFirstChild("gem_amount")
            balance = readVal(stat)
            label = "gems"
        end

        local total = pricePerOne * amount
        if amount == 10 and b.gem_cost10 then
            total = getHatchPrice(bannerId, b.gem_cost10)
        elseif amount == 50 and b.gem_cost50 then
            total = getHatchPrice(bannerId, b.gem_cost50)
        end

        -- If we couldn't find a price (cost = 0), don't block — let server decide
        if total <= 0 then return nil end

        return { afford = balance >= total, balance = balance, needed = total, label = label }
    end)

    if not ok or not result then
        -- Unknown banner / data not loaded / banner has no cost field we recognize
        -- → don't block summons; status line just shows "?"
        return true, 0, 0, "?"
    end
    return result.afford, result.balance, result.needed, result.label
end

