            local redeemed = loadRedeemedSet()
            local toTry, skipped = {}, 0
            for _, c in ipairs(list) do
                if redeemed[c] then skipped = skipped + 1
                else table.insert(toTry, c) end
            end

            codeState.last_skipped = skipped
            codeState.last_success = 0
            codeState.last_invalid = 0
            codeState.last_status  = ("Redeeming %d codes..."):format(#toTry)
            API.notify(("Codes: %d new, %d already used"):format(#toTry, skipped))

            -- Adaptive backoff: start at 1.0s + jitter, grow on failure, reset on success.
            -- Cap at 4s — fail progression: 1.0 → 1.4 → 1.96 → 2.74 → 3.84 → 4.0 (cap).
            local DELAY_MIN, DELAY_MAX, GROW = 1.0, 4.0, 1.4
            local curDelay = DELAY_MIN

            for i, code in ipairs(toTry) do
                if not codeState.running then break end
                codeState.last_status = ("[%d/%d] trying: %s  (wait %.1fs)"):format(
                    i, #toTry, code, curDelay)

                -- Server returns: true = success, false = invalid OR rate-limited.
                -- We can't distinguish these from the return alone, so we use an
                -- adaptive pacing strategy: tight on success, back off on failure.
                local ok, res = API.invoke("redeem_code", code)
                if ok and res then
                    codeState.last_success = codeState.last_success + 1
                    codeState.consec_fail = 0
                    redeemed[code] = true
                    curDelay = DELAY_MIN  -- success → reset
                else
                    codeState.last_invalid = codeState.last_invalid + 1
                    codeState.consec_fail = (codeState.consec_fail or 0) + 1
                    -- Mark as tried so we skip it next session
                    redeemed[code] = true
                    curDelay = math.min(curDelay * GROW, DELAY_MAX)  -- fail → grow
                end

                -- Save progress every 5 codes
                if (i % 5) == 0 then saveRedeemedSet(redeemed) end

                -- Wait with small jitter (0-0.2s) so two clients don't sync
                task.wait(curDelay + math.random() * 0.2)
            end

            saveRedeemedSet(redeemed)

            -- Update total counter
            local total = 0
            for _ in pairs(redeemed) do total = total + 1 end
            codeState.total_redeemed = total

            codeState.last_status = ("Done: %d ok, %d invalid, %d skipped"):format(
                codeState.last_success, codeState.last_invalid, codeState.last_skipped)
            codeState.running = false
            API.notify(("Codes done: %d new redeemed"):format(codeState.last_success))
        end)
    end

    L:Button({
