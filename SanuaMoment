-- Auto Start — see Match State Monitor at end of file (centralized).

-- Auto Restart at wave X (Force End only, per spec)
local _restartConn
local _restartFiredForMatch = false   -- one-shot per match (resets on GameStarted=false)

local function setupRestartListener()
    if _restartConn then pcall(_restartConn.Disconnect, _restartConn); _restartConn = nil end
    local n = workspace:FindFirstChild("_wave_num")
    if not n then return end
    _restartConn = n.Changed:Connect(function(v)
        if not (_AC.AutoRestartWave and isInStage()) then return end
        if _restartFiredForMatch then return end
        if _AC.RestartAtWave and _AC.RestartAtWave > 0 and v >= _AC.RestartAtWave then
            _restartFiredForMatch = true
            API.notify(("Wave %d → force end"):format(v))
            task.wait(0.3)
            API.invoke("vote_force_end")
        end
    end)
end

-- Reset one-shot flag when match restarts (GameStarted goes false → true)
task.spawn(function()
    local lastStarted = false
    while getgenv()._ACHubRunning do
        if isInStage() then
            if not _restartConn then setupRestartListener() end
            local started = isGameStarted()
            if started ~= lastStarted then
                if not started then _restartFiredForMatch = false end
                lastStarted = started
            end
        else
            if _restartConn then pcall(_restartConn.Disconnect, _restartConn); _restartConn = nil end
            _restartFiredForMatch = false
        end
        task.wait(1)
    end
end)

