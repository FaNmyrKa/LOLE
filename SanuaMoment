    local out = {
        in_dungeon  = false,
        gamemode    = nil,
        depth       = nil,
        items_count = 0,
        items_list  = {},
        currency_id = nil,
        currency_balance = 0,
        shop_multi  = 1,
    }
    if not (lvld and lvld.DungeonLevel and lvld.DungeonLevel._Gamemode) then return out end
    out.in_dungeon = true
    out.gamemode   = lvld.DungeonLevel._Gamemode

