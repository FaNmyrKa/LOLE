-- WEBHOOK CORE (event-based dispatcher)
-- All webhook sends go through dispatchWebhook(eventKey, payloadFn)
-- ============================================================

local WEBHOOK_EVENTS = {
    "MatchEnd", "SecretDrop", "MythicDrop", "ExclusiveDrop",
    "LegendaryDrop", "ShinyDrop", "CrusaderTrait",
}

local WEBHOOK_EVENT_TO_TOGGLE = {
    MatchEnd       = "WebhookOnMatchEnd",
    SecretDrop     = "WebhookOnSecretDrop",
    MythicDrop     = "WebhookOnMythicDrop",
    ExclusiveDrop  = "WebhookOnExclusiveDrop",
    LegendaryDrop  = "WebhookOnLegendaryDrop",
    ShinyDrop      = "WebhookOnShinyDrop",
    CrusaderTrait  = "WebhookOnCrusaderTrait",
}

local function buildPingContent()
    if not _AC.WebhookPingEnabled then return nil end
    if not _AC.WebhookUserId or _AC.WebhookUserId == "" then return nil end
    return ("<@%s>"):format(_AC.WebhookUserId)
end

-- Send a pre-built embed table, gated by event toggle + master switch
local function dispatchWebhook(eventKey, embed)
    if not _AC.WebhookEnabled then return end
    if not _AC.WebhookURL  or _AC.WebhookURL == "" then return end
    if not _request then return end

    local toggleField = WEBHOOK_EVENT_TO_TOGGLE[eventKey]
    if toggleField and _AC[toggleField] == false then return end

    local body = { username = "AC Hub", embeds = { embed } }
    if _AC.WebhookPingEnabled and _AC.WebhookPingOn and _AC.WebhookPingOn[eventKey] then
        local content = buildPingContent()
        if content then body.content = content end
    end

    local payload = HttpService:JSONEncode(body)
    pcall(_request, {
        Url = _AC.WebhookURL, Method = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body = payload,
    })
end

-- Helper: check if unit has the Crusader trait
local function hasCrusaderTrait(u)
    if not u or type(u.traits) ~= "table" then return false end
    for _, t in ipairs(u.traits) do
        -- traits can be either strings or {trait="...",tier=N} tables
        if t == "Crusader" then return true end
        if type(t) == "table" and (t.trait == "Crusader" or t.id == "Crusader") then
            return true
        end
    end
    return false
end

-- Drop webhook: dispatches to ALL applicable events (rarity, shiny, crusader trait)
local function sendDropWebhook(u)
    local cfg = getUnitConfig(u.unit_id) or {}
    local rarity = cfg.rarity or "?"

    -- Build base embed
    local color
    if rarity == "Secret"        then color = 16711935       -- magenta
    elseif rarity == "Mythic"    then color = 15277667       -- gold/red
    elseif rarity == "Exclusive" then color = 16766720       -- gold
    elseif rarity == "Legendary" then color = 9442302        -- purple
    elseif u.shiny               then color = 65535          -- cyan
    else color = 8421504 end

    local tagParts = {}
    if u.shiny then table.insert(tagParts, "Shiny") end
    local crusader = hasCrusaderTrait(u)
    if crusader then table.insert(tagParts, "Crusader trait") end
    local tagStr = #tagParts > 0 and (" [" .. table.concat(tagParts, ", ") .. "]") or ""

    local fields = {
        { name = "Rarity", value = rarity, inline = true },
        { name = "Banner", value = _AC.SelectedBanner, inline = true },
    }
    if type(u.traits) == "table" and #u.traits > 0 then
        local list = {}
        for _, t in ipairs(u.traits) do
            if type(t) == "string" then table.insert(list, t)
            elseif type(t) == "table" then
                table.insert(list, tostring(t.trait or t.id or "?")
                    .. (t.tier and (" T" .. t.tier) or ""))
            end
        end
        if #list > 0 then
            table.insert(fields, { name = "Traits", value = table.concat(list, ", "), inline = false })
        end
    end

    local embed = {
        title       = ("%s drop: %s%s"):format(rarity, cfg.name or u.unit_id, tagStr),
        description = ("Player: @%s"):format(LocalPlayer.Name),
        color       = color,
        fields      = fields,
        timestamp   = os.date("!%Y-%m-%dT%H:%M:%SZ"),
        footer      = { text = "AC Hub" },
    }

    -- Determine which event keys to fire. Same drop can trigger multiple webhooks
    -- (e.g. Mythic + Shiny + CrusaderTrait → 3 dispatches if all 3 enabled).
    -- dispatchWebhook itself silently drops if event toggle is off.
    local fired = {}
    local function fire(key)
        if not fired[key] then dispatchWebhook(key, embed); fired[key] = true end
    end

    if rarity == "Secret"        then fire("SecretDrop")
    elseif rarity == "Mythic"    then fire("MythicDrop")
    elseif rarity == "Exclusive" then fire("ExclusiveDrop")
    elseif rarity == "Legendary" then fire("LegendaryDrop")
    end

    if u.shiny    then fire("ShinyDrop") end
    if crusader   then fire("CrusaderTrait") end
end
