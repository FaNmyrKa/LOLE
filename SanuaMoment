-- PORTABLE MACRO HELPERS
-- ============================================================
-- Macros store ONLY display names ("Bulmo", "Prodigy Mage (Apprentice)") —
-- the text shown in the hotbar — plus world positions. No internal unit_ids,
-- no collection UUIDs, no runtime SpawnedIDs in the saved file.
--
-- On playback, display name is reverse-resolved through the Units data table
-- to a unit_id, then the player's collection is searched for an owned UUID
-- with that unit_id. Positions resolve to current-match SpawnedIDs via the
-- ClientHandler.Active table.

-- collection UUID → display name from Units table (the hotbar label).
local function getDisplayNameFromUuid(uuid)
    if not (uuid and session and session.collection) then return nil end
    local ok, unit = pcall(function() return session.collection:get_unit_by_uuid(uuid) end)
    if not ok or not unit or not unit.unit_id then return nil end
    if Units and Units[unit.unit_id] and Units[unit.unit_id].name then
        return Units[unit.unit_id].name, unit.unit_id
    end
    return unit.unit_id, unit.unit_id  -- fallback: raw id if no display
end

-- display name → unit_id (Units key). If multiple unit_ids share a name
-- (rare — usually evolution variants get distinct names like
-- "Goku" vs "Goku (Super Saiyan)"), prefer one the player actually owns.
local function unitNameToId(displayName)
    if type(displayName) ~= "string" or not Units then return nil end
    local candidates = {}
    for id, def in pairs(Units) do
        if type(def) == "table" and def.name == displayName then
            table.insert(candidates, id)
        end
    end
    if #candidates == 0 then return nil end
    if #candidates == 1 then return candidates[1] end

    -- Disambiguate by ownership
    local owned = session and session.collection
                  and session.collection.collection_profile_data
                  and session.collection.collection_profile_data.owned_units
    if type(owned) == "table" then
        for _, id in ipairs(candidates) do
            for _, u in pairs(owned) do
                if type(u) == "table" and u.unit_id == id then return id end
            end
        end
    end
    return candidates[1]
end

-- For playback: find an owned collection UUID whose unit's display name
-- matches `displayName`. Picks highest-upgrade variant if multiple owned.
-- Path confirmed in decompile (line 653): owned_units is an ARRAY of
-- { uuid, unit_id, _upgrade, shiny, ... }.
local function findOwnedUuidByDisplayName(displayName)
    local unitId = unitNameToId(displayName)
    if not unitId then return nil end
    if not (session and session.collection
            and session.collection.collection_profile_data) then return nil end
    local owned = session.collection.collection_profile_data.owned_units
    if type(owned) ~= "table" then return nil end

    -- 1. Prefer EQUIPPED instance — server validates uuid against hotbar,
    --    so a non-equipped copy of the same unit_id fails with
    --    "This unit slot is locked!".
    for _, unit in pairs(owned) do
        if type(unit) == "table" and unit.unit_id == unitId then
            local eq = tonumber(unit.equipped_slot)
            if eq and eq > 0 then return unit.uuid end
        end
    end

    -- 2. Fallback: highest upgrade among owned (when user has the unit
    --    but it's not currently in the hotbar)
    local bestUuid, bestUpg = nil, -1
    for _, unit in pairs(owned) do
        if type(unit) == "table" and unit.unit_id == unitId then
            local upg = unit._upgrade or unit.upgrade or 0
            if upg > bestUpg then
                bestUuid, bestUpg = unit.uuid, upg
            end
        end
    end
    return bestUuid
end

-- spawnedId (runtime) → world Vector3 + display name
local function getActiveUnitInfoBySpawnedId(spawnedId)
    if spawnedId == nil then return nil end
    local key = tostring(spawnedId)
    local um = getUnitManager()
    if not (um and um.ClientHandler and um.ClientHandler.Active) then return nil end
    local entry = um.ClientHandler.Active[key] or um.ClientHandler.Active[spawnedId]
    if not entry then return nil end
    local pos
    if entry.spawn_position and entry.spawn_position.Position then
        pos = entry.spawn_position.Position
    elseif entry.UnitModel then
        local ok, cf = pcall(function() return entry.UnitModel:GetPivot() end)
        if ok and cf then pos = cf.Position end
    end
    local unitId = entry.CollectionData and entry.CollectionData.unit_id
    local name
    if unitId and Units and Units[unitId] and Units[unitId].name then
        name = Units[unitId].name
    end
    return { pos = pos, name = name, unit_id = unitId }
end

-- pos → spawnedId of MY closest unit within tolerance studs.
-- preferredName (display) used as tie-breaker if multiple within tolerance.
-- IMPORTANT: ownership check is `entry.Player == LocalPlayer` — confirmed in
-- decompile (lines 17962, 88128). `CollectionData.Player` does NOT exist;
-- CollectionData only has uuid/unit_id/etc.
local function findOwnedSpawnedIdAtPos(pos, tolerance, preferredName)
    if not pos then return nil end
    tolerance = tolerance or 5.0
    local um = getUnitManager()
    if not (um and um.ClientHandler and um.ClientHandler.Active) then return nil end
    local preferredId = preferredName and unitNameToId(preferredName) or nil

    local bestId, bestDist
    local bestIdMatching, bestDistMatching
    for name, entry in pairs(um.ClientHandler.Active) do
        if entry and not entry._DEAD
           and entry.Player == LocalPlayer
           and entry.CollectionData then
            local p
            if entry.spawn_position and entry.spawn_position.Position then
                p = entry.spawn_position.Position
            elseif entry.UnitModel then
                local ok, cf = pcall(function() return entry.UnitModel:GetPivot() end)
                if ok and cf then p = cf.Position end
            end
            if p then
                local d = (p - pos).Magnitude
                if d < tolerance then
                    if not bestId or d < bestDist then
                        bestId, bestDist = name, d
                    end
                    if preferredId and entry.CollectionData.unit_id == preferredId then
                        if not bestIdMatching or d < bestDistMatching then
                            bestIdMatching, bestDistMatching = name, d
                        end
                    end
                end
            end
        end
    end
    return bestIdMatching or bestId
end

local function vec3ToArray(v)
    if typeof(v) == "Vector3" then return { v.X, v.Y, v.Z } end
    return nil
end

local function arrayToVec3(t)
    if type(t) == "table" and #t >= 3 then
        return Vector3.new(t[1], t[2], t[3])
    end
    return nil
end

-- Endpoints recorded as generic "SpecialAbility" steps. These are unit-specific
-- ability remotes (DioWrites, FrierenMagics, etc.) that take arbitrary args.
-- The first arg is typically _stats.spawn_id (runtime ID) — we map it to the
-- unit's world position so it's portable across matches/accounts.
-- Source: ReplicatedStorage.endpoints.client_to_server in game_analysis_v5.txt.
local SPECIAL_ABILITY_ENDPOINTS = {
    DioWrites           = true,
    NagumoSelectUnit    = true,
    NagumoCancel        = true,
    LelouchAssignUnit   = true,
    LelouchChoosePiece  = true,
    HestiaAssignBlade   = true,
    FrierenMagics       = true,
    UraharaAssignHat    = true,
    UseAbilityVegeta    = true,
    UseAbilityGoku      = true,
    CellAbsorb          = true,
    ChrolloSelect       = true,
    ChrolloCancel       = true,
    WeatherSelection    = true,
    SongsMelody         = true,
    CrazySlots          = true,
    Gojo_Sukuna         = true,
    Gojo_Sukuna_Heian   = true,
    Hakari_evolved      = true,
    Maki_evolved        = true,
    Subaru              = true,
    Pucci_Evolve_Unit   = true,
    PowerArsenal        = true,
    MobChooseEmotion    = true,
    CardAction          = true,
}

-- Serialize a single arg value to JSON-safe form (primitives passthrough,
-- Vector3 → tagged array, others dropped).
local function safeArg(v)
    local t = type(v)
    if t == "string" or t == "number" or t == "boolean" then return v end
    if t == "userdata" and typeof(v) == "Vector3" then
        return { __t = "Vector3", v.X, v.Y, v.Z }
    end
    return nil
end

local function deserArg(v)
    if type(v) == "table" and v.__t == "Vector3" then
        return Vector3.new(v[1], v[2], v[3])
    end
    return v
end

-- Read current upgrade level for a runtime spawnedId (NumberValue from
-- ClientHandler.Active[id]._stats.upgrade). Used for verifying Upgrade steps:
-- server replicates level change reliably, so a level diff before vs after
-- the invoke is a robust success signal regardless of the endpoint's return.
local function getUpgradeLevel(spawnedId)
    if spawnedId == nil then return 0 end
    local um = getUnitManager()
    if not (um and um.ClientHandler and um.ClientHandler.Active) then return 0 end
    local e = um.ClientHandler.Active[spawnedId]
            or um.ClientHandler.Active[tostring(spawnedId)]
    if not (e and e._stats and e._stats.upgrade) then return 0 end
    return e._stats.upgrade.Value or 0
end

-- Diagnostics: counts every namecall hit even when not recording
Macro.diag = {
    total_invokes      = 0,    -- total InvokeServer/FireServer seen
    total_my_calls     = 0,    -- of which from our script (checkcaller=true)
    total_recorded     = 0,    -- ended up in MacroData (lifetime)
    session_recorded   = 0,    -- recorded within current Record session
    session_started_at = 0,
    last_endpoint_seen = "",   -- last endpoint name (any)
    seen_endpoints     = {},   -- set of endpoint names ever seen
}

local function snapshotActiveNames()
    local set = {}
    local um = getUnitManager()
    if um and um.ClientHandler and um.ClientHandler.Active then
        for name, _ in pairs(um.ClientHandler.Active) do set[name] = true end
    end
    return set
end

local function installNamecallHook()
    if _hookInstalled then return end
    if not (hookmetamethod and getrawmetatable and checkcaller) then
        warn("[Macro] hookmetamethod/checkcaller unavailable — recording disabled")
        return
    end
    _origNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if method == "InvokeServer" or method == "FireServer" then
            -- Diagnostics — fires regardless of recording state
            local _ok, _name = pcall(function() return self.Name end)
            if _ok and type(_name) == "string" then
                Macro.diag.total_invokes = Macro.diag.total_invokes + 1
                Macro.diag.last_endpoint_seen = _name
                Macro.diag.seen_endpoints[_name] = (Macro.diag.seen_endpoints[_name] or 0) + 1
                if checkcaller() then
                    Macro.diag.total_my_calls = Macro.diag.total_my_calls + 1
                end
            end
        end
        if Macro.recording and not Macro.suppress
                            and (method == "InvokeServer" or method == "FireServer")
                            and not checkcaller() then
            local ok, name = pcall(function() return self.Name end)
            local isSpecial = ok and SPECIAL_ABILITY_ENDPOINTS[name]
            if ok and (name == "spawn_unit" or name == "upgrade_unit_ingame"
                       or name == "sell_unit_ingame" or name == "use_active_attack"
                       or name == "cycle_priority" or isSpecial) then
                local args = { ... }
                local t = tick() - (Macro.rec_start_t or tick())

                -- Run original FIRST and capture verdict.
                local serverResult = _origNamecall(self, ...)

                local function pushStep(step)
                    -- Skip recording entirely if recording timer hasn't armed yet
                    -- (waiting for GameStart).
                    if not Macro.rec_start_t then return end
                    Macro.seq = Macro.seq + 1
                    step.Time = t
                    step.Seq  = Macro.seq
                    Macro.diag.total_recorded = Macro.diag.total_recorded + 1
                    Macro.diag.session_recorded = Macro.diag.session_recorded + 1
                    table.insert(_AC.MacroData, step)
                end

                if name == "spawn_unit" then
                    if serverResult == false or serverResult == nil then
                        return serverResult  -- server rejected — don't record
                    end
                    local uuid = args[1]; local ray = args[2]; local slot = args[3]
                    if type(uuid) == "string" and type(ray) == "table"
                                              and ray.Origin and ray.Direction then
                        local origin    = vec3ToArray(ray.Origin)
                        local direction = vec3ToArray(ray.Direction)
                        local slotVal   = slot or 0
                        local displayName = getDisplayNameFromUuid(uuid)

                        -- Dedup safety net (rapid double-clicks)
                        local isDup = false
                        for i = #_AC.MacroData, math.max(1, #_AC.MacroData - 5), -1 do
                            local p = _AC.MacroData[i]
                            if p.Action == "Place"
                               and p.UnitName == displayName
                               and p.Slot == slotVal
                               and (t - (p.Time or 0)) < 0.3
                               and p.Origin
                               and math.abs(p.Origin[1] - origin[1]) < 1
                               and math.abs(p.Origin[2] - origin[2]) < 1
                               and math.abs(p.Origin[3] - origin[3]) < 1 then
                                isDup = true; break
                            end
                        end
                        if not isDup then
                            local step = {
                                Action    = "Place",
                                UnitName  = displayName,
                                Origin    = origin,
                                Direction = direction,
                                Slot      = slotVal,
                            }
                            pushStep(step)
                        end
                    end
                elseif name == "upgrade_unit_ingame"
                       or name == "sell_unit_ingame"
                       or name == "use_active_attack"
                       or name == "cycle_priority" then
                    local spawnedId = args[1]
                    if spawnedId == nil then return serverResult end

                    -- Server rejects with false/nil; truthy = success.
                    -- (Confirmed in decompile line 88456 where the result is
                    --  used as a boolean.) Don't pollute macro with rejected ops.
                    if name == "upgrade_unit_ingame"
                       and (serverResult == false or serverResult == nil) then
                        return serverResult
                    end

                    local info = getActiveUnitInfoBySpawnedId(spawnedId)
                    local actionName =
                        (name == "upgrade_unit_ingame" and "Upgrade")
                        or (name == "sell_unit_ingame" and "Sell")
                        or (name == "use_active_attack" and "Ability")
                        or (name == "cycle_priority" and "Priority")
                    local step = {
                        Action   = actionName,
                        UnitName = info and info.name or nil,
                        Pos      = info and info.pos and vec3ToArray(info.pos) or nil,
                    }
                    if name == "use_active_attack" then
                        local ca = args[2]
                        if type(ca) == "boolean" or type(ca) == "number" or type(ca) == "string" then
                            step.Arg = ca
                        end
                    elseif name == "cycle_priority" then
                        local pn = args[2]
                        if type(pn) == "string" then step.Priority = pn end
                    end
                    pushStep(step)
                elseif isSpecial then
                    -- SPECIAL endpoints come in 3 flavours:
                    --   A) UNIT-BOUND  args[1] = spawn_id/UUID (matches Active)
                    --      e.g. CellAbsorb, ChrolloSelect, use_active_attack-like
                    --   B) SLOT-BOUND  args[1] = hotbar slot ("1".."6")
                    --      e.g. DioWrites — server resolves unit by slot
                    --   C) ARG-ONLY   no unit reference (rare)
                    -- Probe in that order; record whatever we got.
                    local first = args[1]
                    local info = getActiveUnitInfoBySpawnedId(first)

                    local step = {
                        Action   = "SpecialAbility",
                        Endpoint = name,
                        Method   = method,
                    }

                    if info and info.pos then
                        -- (A) unit-bound — record Pos + UnitName
                        step.Mode     = "unit"
                        step.UnitName = info.name
                        step.Pos      = vec3ToArray(info.pos)
                        local rest = {}
                        for i = 2, #args do rest[i - 1] = safeArg(args[i]) end
                        step.Rest = rest
                    else
                        -- Try (B) slot-bound: first arg is small int / numeric string
                        local slotKey
                        if type(first) == "number" and first >= 1 and first <= 12 then
                            slotKey = first
                        elseif type(first) == "string" and tonumber(first)
                               and tonumber(first) >= 1 and tonumber(first) <= 12 then
                            slotKey = first  -- keep original type for replay parity
                        end

                        if slotKey then
                            -- Find which unit is in that slot RIGHT NOW
                            local equipped = getEquippedSlots()
                            local lookup = tonumber(slotKey)
                            local uuid = equipped[lookup] or equipped[tostring(lookup)]
                            if uuid then
                                local displayName = getDisplayNameFromUuid(uuid)
                                step.Mode     = "slot"
                                step.SlotKey  = slotKey
                                step.UnitName = displayName
                            else
                                -- Slot empty? Record raw — replay will send as-is
                                step.Mode    = "raw"
                                step.SlotKey = slotKey
                            end
                        else
                            -- (C) no recognisable unit/slot reference
                            step.Mode = "raw"
                        end

                        -- Always store full args for slot/raw modes
                        local rawArgs = {}
                        for i = 1, #args do rawArgs[i] = safeArg(args[i]) end
                        step.RawArgs = rawArgs
                    end

                    pushStep(step)
                end

                return serverResult
            end
        end
        return _origNamecall(self, ...)
    end)
    _hookInstalled = true
end

local function macroStartRecord()
    installNamecallHook()
    if not _hookInstalled then API.notify("Hook unavailable"); return end
    _AC.MacroData = {}
    Macro.seq = 0
    Macro.recording = true
    _AC.MacroRecording = true
    -- Reset session counters
    Macro.diag.session_recorded = 0

    -- Arm timer only when the match is actually running. Otherwise leave
    -- rec_start_t = nil so the status panel shows "waiting" with 0s and
    -- pushStep skips any pre-Game-Start invokes. Match State Monitor sets
    -- rec_start_t when GameStarted flips true.
    if isGameStarted() then
        Macro.rec_start_t = tick()
        Macro.diag.session_started_at = tick()
        API.notify("Recording: " .. _AC.MacroName)
    else
        Macro.rec_start_t = nil
        Macro.diag.session_started_at = nil
        API.notify("Recording armed: " .. _AC.MacroName .. " (waiting for Game Start)")
    end
end

local function macroStopRecord()
    Macro.recording = false
    _AC.MacroRecording = false
    Macro.rec_start_t = nil
    if #_AC.MacroData == 0 then
        API.notify("Recording stopped (no steps captured)")
        return
    end
    if _AC.MacroName and _AC.MacroName ~= "" then
        if saveMacro(_AC.MacroName, _AC.MacroData) then
            API.notify(("Saved '%s' (%d steps)"):format(_AC.MacroName, #_AC.MacroData))
        end
    else
        API.notify(("Recorded %d steps (set name to save)"):format(#_AC.MacroData))
    end
end

-- ----- Playback (3 modes) -----
-- execStep returns (success, info)
-- success = true ONLY when InvokeServer returned a truthy value (server accepted)
local function execStep(step)
    local function check(ok, res)
        if not ok then return false, "invoke_error" end
        if res == false or res == nil then return false, "server_rejected" end
        return true
    end

    -- Resolve placement uuid: pick owned uuid by display name.
    local function resolvePlaceUuid()
        if not step.UnitName then return nil end
        return findOwnedUuidByDisplayName(step.UnitName)
    end

    -- Resolve runtime spawnedId: find nearest owned unit at Pos
    -- (preferring matching display name).
    local function resolveRuntimeId()
        if not step.Pos then return nil end
        return findOwnedSpawnedIdAtPos(arrayToVec3(step.Pos), 5.0, step.UnitName)
    end

    if step.Action == "Place" then
        -- Resolve unit_id from display name
        local unitId = step.UnitName and unitNameToId(step.UnitName) or nil
        if not unitId then return false, "no_unit_id_for_name" end

        -- Find the EQUIPPED instance of this unit_id (the one sitting in
        -- the hotbar). If we send an inventory-only uuid, server replies
        -- "This unit slot is locked!" — even if same unit_id is also
        -- equipped elsewhere. Source of truth: owned_units[i].equipped_slot
        -- (also used in shouldAutoSell logic).
        local uuid, currentSlot
        local owned
        pcall(function()
            owned = session.collection
                    and session.collection.collection_profile_data
                    and session.collection.collection_profile_data.owned_units
        end)
        if type(owned) == "table" then
            for _, unit in pairs(owned) do
                if type(unit) == "table" and unit.unit_id == unitId then
                    local eq = tonumber(unit.equipped_slot)
                    if eq and eq > 0 then
                        uuid = unit.uuid
                        currentSlot = eq
                        break
                    end
                end
            end
        end

        -- Fallback: highest-upgrade owned (legacy behaviour). May fail with
        -- "slot is locked" if the unit isn't actually equipped, but at
        -- least we try rather than skipping the step.
        if not uuid then
            uuid = findOwnedUuidByDisplayName(step.UnitName)
            if not uuid then return false, "no_owned_unit" end
            currentSlot = step.Slot or 0
        end

        local origin    = arrayToVec3(step.Origin)
        local direction = arrayToVec3(step.Direction)
        if not (origin and direction) then return false, "bad_ray" end

        -- Snapshot Active BEFORE spawn_unit so we can detect the *new* entry
        -- afterward (a same-unit_id earlier placement would otherwise satisfy
        -- the lookup immediately and the next step would stall).
        local before = snapshotActiveNames()

        local ok, err = check(API.invoke("spawn_unit", uuid,
            { Origin = origin, Direction = direction },
            currentSlot))
        if not ok then return ok, err end

        -- Wait for replication: server-spawned unit takes 50–300ms to appear
        -- in ClientHandler.Active. Without this, the next Upgrade/Sell step
        -- can't resolve the unit by position and stalls in retry loop.
        local expectedUnitId = step.UnitName and unitNameToId(step.UnitName) or nil
        local deadline = tick() + 1.0
        while tick() < deadline do
            local um = getUnitManager()
            if um and um.ClientHandler and um.ClientHandler.Active then
                for entryName, e in pairs(um.ClientHandler.Active) do
                    if not before[entryName] and e and e.CollectionData
                       and e.Player == LocalPlayer
                       and (not expectedUnitId or e.CollectionData.unit_id == expectedUnitId)
                       and not e._DEAD then
                        return true  -- new unit confirmed in Active
                    end
                end
            end
            task.wait(0.05)
        end
        return true  -- timed out; let next step retry by position
    elseif step.Action == "Upgrade" then
        local id = resolveRuntimeId()
        if not id then return false, "no_unit_at_pos" end
        -- Robust verification: server's return value for upgrade_unit_ingame
        -- is ambiguous (nil on rejection AND sometimes on success). Source of
        -- truth is the unit's _stats.upgrade NumberValue — server replicates
        -- the level bump on success.
        local before = getUpgradeLevel(id)
        API.invoke("upgrade_unit_ingame", id)
        -- Wait briefly for replication; 0.15s covers typical RTT (50–250ms).
        local deadline = tick() + 0.4
        while tick() < deadline do
            if getUpgradeLevel(id) > before then return true end
            task.wait(0.05)
        end
        return false, "no_level_change"
    elseif step.Action == "Sell" then
        local id = resolveRuntimeId()
        if not id then return false, "no_unit_at_pos" end
        return check(API.invoke("sell_unit_ingame", id))
    elseif step.Action == "Ability" then
        local id = resolveRuntimeId()
        if not id then return false, "no_unit_at_pos" end
        local ok = step.Arg ~= nil
                   and select(1, API.invoke("use_active_attack", id, step.Arg))
                   or  select(1, API.invoke("use_active_attack", id))
        return ok
    elseif step.Action == "Priority" then
        local id = resolveRuntimeId()
        if not id then return false, "no_unit_at_pos" end
        local ok = step.Priority
                   and select(1, API.invoke("cycle_priority", id, step.Priority))
                   or  select(1, API.invoke("cycle_priority", id))
        return ok
    elseif step.Action == "SpecialAbility" then
        local cts = RS.endpoints and RS.endpoints:FindFirstChild("client_to_server")
        local re  = cts and cts:FindFirstChild(step.Endpoint or "")
        if not re then return false, "endpoint_missing" end

        -- Back-compat: old steps had no Mode but had Pos → treat as "unit"
        local mode = step.Mode or (step.Pos and "unit") or "raw"
        local callArgs

        if mode == "unit" then
            local id = resolveRuntimeId()
            if not id then return false, "no_unit_at_pos" end
            callArgs = { tonumber(id) or id }
            for i = 1, #(step.Rest or {}) do
                callArgs[#callArgs + 1] = deserArg(step.Rest[i])
            end

        elseif mode == "slot" then
            -- Find current slot of recorded UnitName; fall back to original SlotKey
            local newSlot
            if step.UnitName then
                local targetUuid = findOwnedUuidByDisplayName(step.UnitName)
                if targetUuid then
                    local equipped = getEquippedSlots()
                    for slot, uuid in pairs(equipped) do
                        if uuid == targetUuid then newSlot = slot; break end
                    end
                end
            end
            -- Reassemble args: replace [1] with newSlot if found, else use recorded
            local raw = step.RawArgs or {}
            callArgs = {}
            if newSlot ~= nil then
                -- Match original arg type (server may be picky)
                if type(step.SlotKey) == "string" then
                    callArgs[1] = tostring(newSlot)
                else
                    callArgs[1] = tonumber(newSlot) or newSlot
                end
            else
                callArgs[1] = deserArg(raw[1])
            end
            for i = 2, #raw do
                callArgs[i] = deserArg(raw[i])
            end

        else  -- "raw"
            callArgs = {}
            for i = 1, #(step.RawArgs or {}) do
                callArgs[i] = deserArg(step.RawArgs[i])
            end
        end

        if step.Method == "InvokeServer" then
            local ok, res = pcall(function() return re:InvokeServer(table.unpack(callArgs)) end)
            if not ok then return false, "invoke_error" end
            if res == false then return false, "server_rejected" end
            return true
        else
            local ok = pcall(function() re:FireServer(table.unpack(callArgs)) end)
            return ok
        end
    end
    return false, "unknown_action"
end

local function shouldStopPlayback()
    return not Macro.playing or not getgenv()._ACHubRunning
end

local function playStepFast(step)
    -- Spam-retry until success or playback stops. This is the whole point of
    -- Fast mode: try the step every ~100ms until the server accepts (gold
    -- accumulates, replication catches up, etc.). User toggles Play OFF to
    -- bail out of an impossible step.
    while not shouldStopPlayback() do
        Macro.suppress = true
        local ok, ret = pcall(execStep, step)
        Macro.suppress = false
        if ok and ret then return true end
        task.wait(0.1 + math.random() * 0.1)
    end
    return false
end

local function playStepTimed(step, retries)
    retries = retries or 3
    for _ = 1, retries do
        if shouldStopPlayback() then return false end
        Macro.suppress = true
        local ok, ret = pcall(execStep, step)
        Macro.suppress = false
        if ok and ret then return true end
        task.wait(0.5)
    end
    return false
end

-- Build a pretty label for a step ("Place Dio", "Upgrade Goku", etc).
local function formatStepLabel(step)
    if not step then return "?" end
    local who = step.UnitName or "?"
    local act = step.Action or "?"
    if act == "Place"    then return "Place "    .. who
    elseif act == "Upgrade"  then return "Upgrade "  .. who
    elseif act == "Sell"     then return "Sell "     .. who
    elseif act == "Ability"  then return "Ability "  .. who
    elseif act == "Priority" then return "Priority " .. who
    elseif act == "SpecialAbility" then
        local arg2 = (step.Rest and step.Rest[1])
                   or (step.RawArgs and step.RawArgs[2])
        local label = (step.Endpoint or "ability")
        if arg2 ~= nil then label = label .. " · " .. tostring(arg2) end
        if step.UnitName then label = label .. " on " .. step.UnitName end
        return label
    end
    return act .. " " .. who
end

local function macroPlay()
    if Macro.playing then API.notify("Already playing"); return end
    if #_AC.MacroData == 0 then API.notify("No macro data"); return end
    if not isInStage() then API.notify("Not in stage"); return end

    Macro.playing       = true
    _AC.MacroPlaying    = true
    Macro.completed     = false
    Macro.play_idx      = 0
    Macro.play_total    = #_AC.MacroData
    Macro.play_step     = nil
    Macro.play_label    = ""
    Macro.play_started_t = tick()

    task.spawn(function()
        table.sort(_AC.MacroData, function(a, b)
            local ta = a.Time or 0
            local tb = b.Time or 0
            if ta ~= tb then return ta < tb end
            return (a.Seq or 0) < (b.Seq or 0)
        end)

        Macro.play_total = #_AC.MacroData

        local startT = tick()
        for i, step in ipairs(_AC.MacroData) do
            if shouldStopPlayback() then break end

            -- Wait for timed slot before publishing progress (avoids
            -- "stuck on step N for 30s" UI confusion when next step is far)
            if _AC.MacroPlayMode == "timed" or _AC.MacroPlayMode == "hybrid" then
                local target = step.Time or 0
                while not shouldStopPlayback() and (tick() - startT) < target do
                    task.wait(0.05)
                end
            end

            if shouldStopPlayback() then break end

            -- Publish progress for status UI
            Macro.play_idx   = i
            Macro.play_step  = step
            Macro.play_label = formatStepLabel(step)

            local mode = _AC.MacroPlayMode or "timed"
            if mode == "fast" then
                playStepFast(step)
            elseif mode == "timed" then
                playStepTimed(step, 3)
            else -- hybrid
                if not playStepTimed(step, 3) and not shouldStopPlayback() then
                    playStepFast(step)
                end
            end
        end

        -- Single pass done. Don't loop here — Match State Monitor will call
        -- macroPlay() again on the next GameStarted=true (or wave reset).
        -- This prevents spammy retries while the current match is still
        -- running with all units already placed.
        Macro.completed = (Macro.play_idx >= Macro.play_total) and not shouldStopPlayback()
        Macro.playing       = false
        _AC.MacroPlaying    = false

        if Macro.completed then
            API.notify(("Macro completed (%d/%d) — waiting for next match"):format(
                Macro.play_total, Macro.play_total))
        end
    end)
    API.notify(("Playing '%s' (%d steps, %s)"):format(
        _AC.MacroName, #_AC.MacroData, _AC.MacroPlayMode or "timed"))
end

local function macroStop()
    Macro.playing       = false
    _AC.MacroPlaying    = false
    Macro.completed     = false
    Macro.play_idx      = 0
    Macro.play_step     = nil
    Macro.play_label    = ""
    API.notify("Macro stopped")
end

