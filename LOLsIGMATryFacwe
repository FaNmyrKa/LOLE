local function executeBypassSequence()
    local screenGui, statusText, loadingBar, percentageText, backgroundFrame, mainFrame = createLoadingUI()
    startPulse(backgroundFrame)

    local sequence = {
        { progress = 0.05, message = "Scanning GC for Anti..." },
        { progress = 0.15, message = "Phase 1-3: Hooking Anti lifecycle + Commands + Returnables..." },
        { progress = 0.30, message = "Phase 4: Scanning GC functions (Detected/Kill/Crash/Ban)..." },
        { progress = 0.42, message = "Phase 5: Installing __namecall hook + sniffer..." },
        { progress = 0.70, message = "Phase 12: Expanding Player:Kick blocker (Adonis patterns)..." },
        { progress = 0.90, message = "Phase 13: Masking spy hooks (isfunctionhooked + getconnections)..." },
        { progress = 1.00, message = "✓ Adonis Bypass — Core hooks loaded" },
    }

    for i, step in ipairs(sequence) do
        local isLast = (i == #sequence)
        updateProgress(statusText, loadingBar, percentageText, step.progress, step.message, isLast)

        if i == 2 then
            local bypassDone = false
            task.spawn(function()
                local ok, result = pcall(BypassAnticheats)
                if not ok then warn("[Bypass] Error: " .. tostring(result)) end
                bypassDone = true
            end)
            local elapsed = 0
            while not bypassDone and elapsed < 30 do
                task.wait(0.1); elapsed = elapsed + 0.1
            end
        else
            task.wait(0.25)
        end
    end

    task.wait(1.2)
    fadeOutAndDestroy(screenGui, backgroundFrame, mainFrame)
end

