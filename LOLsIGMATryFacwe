                        local mode = rawget(arg,"Mode") or rawget(arg,"mode")
                        if type(mode)=="string" then
                            local ml = mode:lower()
                            if ml=="checkspy" or ml=="isspy" or ml=="spycheck" or ml=="hookdetect" or ml=="remotespy" then return end
                        end
                    end
                end
            end
            -- Sniffer + spy callback
            if (method == "FireServer" or method == "InvokeServer")
                and (self.ClassName == "RemoteEvent" or self.ClassName == "RemoteFunction") then
                local rn = ""; pcall(function() rn = self.Name end)
                local rp = ""; pcall(function() rp = self:GetFullName() end)
                local isA, why = false, ""
                if rn:lower():find("adonis") or rp:lower():find("adonis") then isA=true; why="name" end
                if rn:match("^%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x$") then isA=true; why="GUID" end
                local d1 = args[1]
                if type(d1)=="table" and (d1.Mode=="Fire" or d1.Mode=="Get") then isA=true; why="Mode" end
                for _,a in ipairs(args) do
                    if typeof(a)=="buffer" then isA=true; why="buffer" end
                end
                if isA then print(string.format("[Sniffer] %s %s:%s() '%s' [%s]", os.date("%H:%M:%S"), self.ClassName, method, rn, why)) end
                -- Spy callback
                local spyCb = rawget(getgenv(), "_RSCallback")
                if spyCb and type(spyCb) == "function" then pcall(spyCb, self, method, args) end
            end
            -- Block detection/kick fire signals
            if (method == "FireServer" or method == "fireServer") and self.ClassName == "RemoteEvent" then
                local d1 = args[1]
                if type(d1) == "table" and (d1.Mode == "Fire" or d1.Mode == "Get") then
                    for _, a in ipairs(args) do
                        if type(a) == "string" and (a:find("Detected") or a:find("kick") or a:find("ban") or a:find("crash")) then
                            BypassNotify("BLOCKED detection fire → "..a:sub(1,40)); return
                        end
                    end
                end
            end
            return oldNamecall(self, ...)
        end)
        logHook("__namecall", "game metatable")

        -- ═══════════════════════════════════════════════════════
        -- PHASE 6: Player:Kick SELECTIVE BLOCK
        -- ═══════════════════════════════════════════════════════
        if not isfunctionhooked(LocalPlayer.Kick) then
            local origKick = LocalPlayer.Kick
            hookfunction(LocalPlayer.Kick, function(self, msg)
                msg = tostring(msg or ""):lower()
                if self == LocalPlayer and (msg:find("adonis") or msg:find("anti%-cheat") or msg:find("0x")
                    or msg:find("exploit") or msg:find("cheat")) then
                    local detail = string.format(
                        "Blocked Player:Kick() → Message: '%s'",
                        tostring(msg):sub(1, 100)
                    )
                    warn("[Bypass] " .. detail)
                    BypassNotify(detail)
                    return
                end
                return origKick(self, msg)
            end)
            logHook("Player:Kick", "LocalPlayer")
        end

        -- ═══════════════════════════════════════════════════════
        -- PHASE 7: MASK SPY HOOKS — isfunctionhooked + getconnections
        -- Prevents Adonis from detecting our __namecall hook or extra
        -- listeners added by remote spy tools (Simple Spy, etc.)
        -- ═══════════════════════════════════════════════════════
        do
            -- ── isfunctionhooked masking ─────────────────────────────
            -- Adonis calls isfunctionhooked(remote.OnClientEvent.callback)
            -- to detect if a spy has hooked in. We intercept it and return
            -- false for any function sourced from Adonis/Client modules.
            local origIsFH = isfunctionhooked
            local isFH_hooked = false
            pcall(function()
                origIsFH = hookfunction(isfunctionhooked, function(f)
                    if type(f) == "function" then
                        local ok, src = pcall(debug.info, f, "s")
                        if ok and type(src) == "string" then
                            -- Adonis checking its own module functions → lie
                            if src:find("Client") or src:find("Adonis") or src:find("Remote") then
                                return false
                            end
                        end
                        -- If Adonis is checking our injected __namecall hook
                        -- (source will be empty or from exploit), return false
                        local ok2, src2 = pcall(debug.info, f, "s")
                        if ok2 and (src2 == nil or src2 == "") then
                            return false
                        end
                    end
                    return origIsFH(f)
                end)
                isFH_hooked = true
            end)
            if isFH_hooked then
                logHook("isfunctionhooked (spy mask)", "Phase 7")
            end

            -- ── getconnections masking ───────────────────────────────
            -- Adonis may enumerate connections on its remotes to count
            -- how many listeners there are (spy adds one extra).
            -- We filter out connections with no Adonis source.
            if getconnections then
                local origGetConn = getconnections
                local gc_hooked = false
                pcall(function()
                    origGetConn = hookfunction(getconnections, function(signal)
                        local conns = origGetConn(signal)
                        if type(conns) ~= "table" then return conns end
                        local clean = {}
                        for _, c in ipairs(conns) do
                            local keep = true
                            pcall(function()
                                local cf = c.Function
                                if cf then
                                    local ok, src = pcall(debug.info, cf, "s")
                                    -- Drop connections with no/empty source (injected spy)
                                    if ok and (src == nil or src == "") then
                                        keep = false
                                    end
                                end
                            end)
                            if keep then
                                table.insert(clean, c)
                            end
                        end
                        return clean
                    end)
                    gc_hooked = true
                end)
                if gc_hooked then
                    logHook("getconnections (spy mask)", "Phase 7")
                end
            end
        end

        -- ═══════════════════════════════════════════════════════
        -- PHASE 12: Player:Kick EXPANDED BLOCK (catches ACLI + Adonis patterns)
        -- ═══════════════════════════════════════════════════════
        if not isfunctionhooked(LocalPlayer.Kick) then
            local origKick = LocalPlayer.Kick
            pcall(function()
                origKick = hookfunction(LocalPlayer.Kick, function(self, msg)
                msg = tostring(msg or ""):lower()
                if self == LocalPlayer and (
                    msg:find("adonis") or msg:find("anti%-cheat") or msg:find("0x")
                    or msg:find("exploit") or msg:find("cheat") or msg:find("acli")
                    or msg:find("integrity") or msg:find("loading error")
                    or msg:find("locked") or msg:find("check caller")
                    or msg:find("bad module") or msg:find("proxy meth")
                    or msg:find("environment") or msg:find("tamper")
                ) then
                    local detail = "Blocked Kick → " .. msg:sub(1, 80)
                    warn("[Bypass] " .. detail); BypassNotify(detail)
                    return
                end
                return origKick(self, msg)
                end)
            end)
            logHook("Player:Kick (expanded)", "Phase 12")
        end



        -- ─── SUMMARY ───
        print("═══════════════════════════════════════════════════")
        print("[Bypass 5.0] COMPLETE — Total hooks: " .. hooked)
        print("[Bypass 5.0] Hooked targets:")
        for i, name in ipairs(hookLog) do
            print(string.format("  %d. %s", i, name))
        end
        print("═══════════════════════════════════════════════════")

        rawset(getgenv(), "_BypassActive", true)
        return true
    end

    table.insert(GeneralPurposeBypasses, Adonis)

    for _, Data in GeneralPurposeBypasses do
        if Data.Detect() then
            if Data.Bypass() then
                AnticheatData.Name = Data.Name
                AnticheatData.Disabled = true
                if Data.Name == "Adonis" then ShowAdonisBypassNotification() end
                break
            end
        end
    end

    return AnticheatData
end

