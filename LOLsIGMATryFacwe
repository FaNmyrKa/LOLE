local function chunkedIterate(tbl, callback)
    local i = 0
    for _, v in tbl do
        callback(v)
        i = i + 1
        if i % CHUNK_SIZE == 0 then
            task.wait()
        end
    end
end

local function serializeArg(arg, depth)
    depth = depth or 0
    if depth > 2 then return "[...]" end
    if type(arg) == "table" then
        local parts = {}
        local count = 0
        for k, v in pairs(arg) do
            count = count + 1
            if count > 6 then table.insert(parts, "...") break end
            table.insert(parts, tostring(k) .. "=" .. serializeArg(v, depth + 1))
        end
        return "{" .. table.concat(parts, ", ") .. "}"
    elseif type(arg) == "string" then
        return '"' .. arg:sub(1, 80) .. '"'
    else
        return tostring(arg)
    end
end

local function serializeArgs(args)
    local parts = {}
    for i, arg in ipairs(args) do
        table.insert(parts, string.format("[%d] %s (%s)", i, serializeArg(arg), type(arg)))
    end
    return table.concat(parts, " | ")
end

